@page "/asesores-imagen"
@attribute [Authorize(Policy = "TenantMember")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using CubotNails.Application.Tenancy
@using CubotNails.Domain.Enums
@inject IResourceService Resources
@inject IServiceCatalogService Services
@inject IJSRuntime JS

<PageTitle>Asesores de imagen - CUBOT.nails</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 0 0-16 0"/><path d="m17 3 1.5 1.5L20 3"/></svg>
            </div>
            <span>Configuracion del salon</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Asesores de imagen</h1>
        <p class="page-sub" style="margin-bottom:0;">Define el equipo, asigna servicios y permite precios personalizados por asesor. Las estaciones usan siempre el precio base.</p>
    </div>
    <button class="btn btn-primary" @onclick="() => OpenForm(null)" disabled="@(_services.Count == 0)">+ Nuevo asesor</button>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else
{
    @if (_services.Count == 0)
    {
        <p class="text-muted">Primero crea servicios en "Servicios"; luego podras habilitarlos por asesor.</p>
    }
    else if (_items.Count == 0)
    {
        <p class="text-muted">Aun no hay asesores. Crea el primero con "+ Nuevo asesor".</p>
    }
    else
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;max-width:1080px;">
            @foreach (var a in _items)
            {
                <div class="card" style="padding:16px;cursor:pointer;" @onclick="() => OpenForm(a)">
                    <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
                        <span style="width:46px;height:46px;border-radius:50%;flex-shrink:0;display:grid;place-items:center;color:#fff;font-weight:800;background:@(string.IsNullOrWhiteSpace(a.Color) ? "#A03DC9" : a.Color)">@Initials(a.Name)</span>
                        <div style="min-width:0;flex:1;">
                            <div style="font-weight:700;">@a.Name</div>
                            <div class="text-muted" style="font-size:12px;">@(string.IsNullOrWhiteSpace(a.Phone) ? "-" : a.Phone)</div>
                        </div>
                        @if (a.Kind == ResourceKind.Image)
                        {
                            <span class="badge bg-warning">Imagen</span>
                        }
                        else
                        {
                            <span class="badge bg-info">Estacion</span>
                        }
                    </div>
                    <div style="font-size:13px;">
                        <strong>Servicios:</strong>
                        @if (a.Services.Count == 0)
                        {
                            <em class="text-muted">Sin servicios</em>
                        }
                        else
                        {
                            @string.Join(", ", a.Services.Select(s => s.ServiceName))
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(a.Notes))
                    {
                        <div class="text-muted" style="font-size:12px;font-style:italic;margin-top:6px;">"@a.Notes"</div>
                    }
                </div>
            }
        </div>
    }
}

@if (_formOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:720px;">
            <div class="modal-head">
                <h3>@(_editingId is null ? "Nuevo asesor" : "Editar asesor")</h3>
                <button class="modal-close" @onclick="() => _formOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;" class="ase-cols">
                    <div>
                        <div class="field">
                            <label class="form-label">Nombre *</label>
                            <input class="form-control" @bind="_form.Name" />
                        </div>
                        <div class="field">
                            <label class="form-label">Telefono</label>
                            <input class="form-control" @bind="_form.Phone" placeholder="+57 300 000 0000" />
                        </div>
                        <div class="field">
                            <label class="form-label">Tipo</label>
                            <select class="form-control" @bind="_form.Kind">
                                <option value="@ResourceKind.Image">Asesor de imagen (puede alterar precios)</option>
                                <option value="@ResourceKind.Station">Estacion / Cabina</option>
                            </select>
                        </div>
                        <div class="field">
                            <label class="form-label">Color en la agenda</label>
                            <input class="form-control" type="color" @bind="_form.Color" style="height:42px;padding:4px;" />
                        </div>
                        <div class="field">
                            <label class="form-label">Notas</label>
                            <textarea class="form-control" rows="2" @bind="_form.Notes"></textarea>
                        </div>
                    </div>
                    <div>
                        <label class="form-label">Servicios habilitados y precio personalizado</label>
                        <div class="text-muted" style="font-size:12px;margin-bottom:8px;">
                            @(_form.Kind == ResourceKind.Image
                                ? "Deja el override vacio para usar el precio base del catalogo."
                                : "Las estaciones usan siempre el precio base; el override se ignora.")
                        </div>
                        <div style="max-height:320px;overflow-y:auto;border:1px solid var(--border);border-radius:10px;padding:8px;">
                            @foreach (var row in _form.Links)
                            {
                                <div style="display:flex;align-items:center;gap:10px;padding:7px 4px;border-bottom:1px solid var(--border);">
                                    <input type="checkbox" @bind="row.Enabled" />
                                    <div style="flex:1;min-width:0;">
                                        <div style="font-weight:600;font-size:13px;">@row.ServiceName</div>
                                        <div class="text-muted" style="font-size:11px;">Base $@row.BasePrice.ToString("N0") - @row.DurationMinutes min</div>
                                    </div>
                                    <input class="form-control form-control-sm" type="number" min="0" style="width:120px;"
                                           placeholder="Override" @bind="row.PriceOverride"
                                           disabled="@(!row.Enabled || _form.Kind != ResourceKind.Image)" />
                                </div>
                            }
                        </div>
                    </div>
                </div>
                @if (_error is not null)
                {
                    <div class="text-danger small" style="margin-top:10px;">@_error</div>
                }
            </div>
            <div class="modal-foot">
                @if (_editingId is not null)
                {
                    <button class="btn btn-outline-danger" style="margin-right:auto;" @onclick="DeleteAsync" disabled="@_busy">Eliminar</button>
                }
                <button class="btn btn-outline-secondary" @onclick="() => _formOpen = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_form.Name))">Guardar asesor</button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _busy;
    private bool _formOpen;
    private string? _error;
    private Guid? _editingId;
    private List<ResourceDto> _items = new();
    private List<ServiceDto> _services = new();
    private FormModel _form = new();

    protected override async Task OnInitializedAsync()
    {
        _services = (await Services.ListAsync()).ToList();
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _items = (await Resources.ListAsync()).ToList();
        _loading = false;
    }

    private void OpenForm(ResourceDto? a)
    {
        _error = null;
        _editingId = a?.Id;
        var existing = a?.Services.ToDictionary(s => s.ServiceId) ?? new();
        _form = new FormModel
        {
            Name = a?.Name ?? "",
            Phone = a?.Phone,
            Kind = a?.Kind ?? ResourceKind.Image,
            Color = string.IsNullOrWhiteSpace(a?.Color) ? "#A03DC9" : a!.Color!,
            Notes = a?.Notes,
            Links = _services.Select(s => new LinkRow
            {
                ServiceId = s.Id,
                ServiceName = s.Name,
                BasePrice = s.Price,
                DurationMinutes = s.DurationMinutes,
                Enabled = existing.ContainsKey(s.Id),
                PriceOverride = existing.TryGetValue(s.Id, out var l) ? l.PriceOverride : null
            }).ToList()
        };
        _formOpen = true;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Name)) { _error = "Escribe el nombre del asesor."; return; }
        _busy = true;
        try
        {
            var links = _form.Links.Where(r => r.Enabled)
                .Select(r => new ResourceLinkInput(r.ServiceId, _form.Kind == ResourceKind.Image ? r.PriceOverride : null))
                .ToList();
            var req = new SaveResourceRequest(_form.Name, _form.Kind, _form.Color, _form.Phone, _form.Notes, links);
            var result = _editingId is Guid id ? await Resources.UpdateAsync(id, req, await ActorAsync()) : await Resources.CreateAsync(req, await ActorAsync());
            if (result is null) { _error = "No se pudo guardar."; return; }
            _formOpen = false;
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private async Task DeleteAsync()
    {
        if (_editingId is not Guid id) { return; }
        if (!await JS.InvokeAsync<bool>("confirm", "Eliminar este asesor? Se quitaran sus turnos base y servicios habilitados.")) { return; }
        _busy = true;
        try { await Resources.DeleteAsync(id, await ActorAsync()); _formOpen = false; await ReloadAsync(); }
        finally { _busy = false; }
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private static string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) { return "?"; }
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1
            ? parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant()
            : $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
    }

    private sealed class FormModel
    {
        public string Name { get; set; } = "";
        public string? Phone { get; set; }
        public ResourceKind Kind { get; set; } = ResourceKind.Image;
        public string Color { get; set; } = "#A03DC9";
        public string? Notes { get; set; }
        public List<LinkRow> Links { get; set; } = new();
    }

    private sealed class LinkRow
    {
        public Guid ServiceId { get; set; }
        public string ServiceName { get; set; } = "";
        public decimal BasePrice { get; set; }
        public int DurationMinutes { get; set; }
        public bool Enabled { get; set; }
        public decimal? PriceOverride { get; set; }
    }
}
