@page "/excepciones"
@attribute [Authorize(Policy = "TenantMember")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using CubotNails.Application.Tenancy
@using CubotNails.Domain.Enums
@inject IScheduleExceptionService Exceptions
@inject IResourceService Resources
@inject IJSRuntime JS

<PageTitle>Excepciones - CUBOT.nails</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M8 2v4"/><path d="M16 2v4"/><path d="m14 14-4 4"/><path d="m10 14 4 4"/></svg>
            </div>
            <span>Configuracion del salon</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Excepciones y bloqueos</h1>
        <p class="page-sub" style="margin-bottom:0;">Bloqueos por asesor o <strong>globales del salon</strong> (festivos, cierre del local, vacaciones). Reducen la disponibilidad real.</p>
    </div>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div style="display:grid;grid-template-columns:minmax(280px,360px) 1fr;gap:22px;align-items:start;" class="exc-cols">
        <div class="card" style="padding:20px;">
            <h3 style="margin-top:0;font-size:1.05rem;">Nueva excepcion</h3>
            <div class="field">
                <label class="form-label">Aplica a</label>
                <select class="form-control" @bind="_form.Scope" @bind:after="OnScopeChanged">
                    <option value="@ExceptionScope.Global">Todos los asesores (excepcion general)</option>
                    <option value="@ExceptionScope.Resource">Un asesor especifico</option>
                </select>
            </div>
            @if (_form.Scope == ExceptionScope.Resource)
            {
                <div class="field">
                    <label class="form-label">Asesor</label>
                    @if (_resources.Count == 0)
                    {
                        <div class="text-muted small">No hay asesores. Crea uno en "Asesores de imagen".</div>
                    }
                    else
                    {
                        <select class="form-control" @bind="_form.ResourceId">
                            @foreach (var r in _resources)
                            {
                                <option value="@r.Id">@r.Name</option>
                            }
                        </select>
                    }
                </div>
            }
            <div class="field-row">
                <div class="field">
                    <label class="form-label">Desde</label>
                    <input class="form-control" type="date" @bind="_form.DateFrom" />
                </div>
                <div class="field">
                    <label class="form-label">Hasta</label>
                    <input class="form-control" type="date" @bind="_form.DateTo" />
                </div>
            </div>
            <div class="field">
                <label class="form-label">Motivo</label>
                <select class="form-control" @bind="_form.Reason">
                    @foreach (var r in Enum.GetValues<ExceptionReason>())
                    {
                        <option value="@r">@ReasonText(r)</option>
                    }
                </select>
            </div>
            <div class="field">
                <label class="form-label">Nota (opcional)</label>
                <textarea class="form-control" rows="2" @bind="_form.Note" placeholder="Festivo nacional, cierre del local, capacitacion..."></textarea>
            </div>
            @if (_error is not null)
            {
                <div class="text-danger small" style="margin-bottom:8px;">@_error</div>
            }
            <button class="btn btn-primary" style="width:100%;" @onclick="SaveAsync" disabled="@_busy">Registrar bloqueo</button>
        </div>

        <div class="card" style="padding:6px 16px;">
            @if (_items.Count == 0)
            {
                <p class="text-muted" style="padding:16px;">Sin bloqueos registrados.</p>
            }
            else
            {
                <table class="table table-hover align-middle" style="margin-bottom:0;">
                    <thead>
                        <tr><th>Alcance</th><th>Fechas</th><th>Motivo</th><th class="text-end">Acciones</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var e in _items)
                        {
                            <tr>
                                <td>
                                    @if (e.Scope == ExceptionScope.Global)
                                    {
                                        <span class="badge bg-danger">TODO EL SALON</span>
                                    }
                                    else
                                    {
                                        <strong>@(e.ResourceName ?? "Asesor")</strong>
                                    }
                                </td>
                                <td>
                                    @if (e.DateFrom == e.DateTo)
                                    {
                                        @e.DateFrom.ToString("dd MMM yyyy")
                                    }
                                    else
                                    {
                                        @($"{e.DateFrom:dd MMM} - {e.DateTo:dd MMM yyyy}")
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@ReasonText(e.Reason)</span>
                                    @if (!string.IsNullOrWhiteSpace(e.Note))
                                    {
                                        <span class="text-muted" style="font-size:12px;margin-left:6px;">@e.Note</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(e)" disabled="@_busy">Eliminar</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _busy;
    private string? _error;
    private List<ScheduleExceptionDto> _items = new();
    private List<ResourceDto> _resources = new();
    private FormModel _form = new();

    protected override async Task OnInitializedAsync()
    {
        _resources = (await Resources.ListAsync()).ToList();
        _form = NewForm();
        await ReloadAsync();
    }

    private FormModel NewForm()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        return new FormModel
        {
            Scope = ExceptionScope.Global,
            ResourceId = _resources.FirstOrDefault()?.Id,
            DateFrom = today,
            DateTo = today,
            Reason = ExceptionReason.Closed
        };
    }

    private void OnScopeChanged()
    {
        if (_form.Scope == ExceptionScope.Resource && _form.ResourceId is null)
        {
            _form.ResourceId = _resources.FirstOrDefault()?.Id;
        }
    }

    private async Task ReloadAsync()
    {
        _items = (await Exceptions.ListAsync()).ToList();
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _error = null;
        if (_form.DateTo < _form.DateFrom) { _error = "La fecha 'Hasta' no puede ser anterior a 'Desde'."; return; }
        if (_form.Scope == ExceptionScope.Resource && _form.ResourceId is null) { _error = "Elige un asesor o usa una excepcion general."; return; }
        _busy = true;
        try
        {
            var req = new SaveExceptionRequest(_form.Scope, _form.ResourceId, _form.DateFrom, _form.DateTo, _form.Reason, _form.Note);
            var result = await Exceptions.CreateAsync(req, await ActorAsync());
            if (result is null) { _error = "No se pudo registrar el bloqueo."; return; }
            _form = NewForm();
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private async Task DeleteAsync(ScheduleExceptionDto e)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Eliminar este bloqueo?")) { return; }
        _busy = true;
        try { await Exceptions.DeleteAsync(e.Id, await ActorAsync()); await ReloadAsync(); }
        finally { _busy = false; }
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private static string ReasonText(ExceptionReason r) => r switch
    {
        ExceptionReason.Vacation => "Vacaciones",
        ExceptionReason.Sick => "Incapacidad",
        ExceptionReason.Training => "Capacitacion",
        ExceptionReason.Closed => "Cierre",
        ExceptionReason.Holiday => "Festivo",
        _ => r.ToString()
    };

    private sealed class FormModel
    {
        public ExceptionScope Scope { get; set; } = ExceptionScope.Global;
        public Guid? ResourceId { get; set; }
        public DateOnly DateFrom { get; set; }
        public DateOnly DateTo { get; set; }
        public ExceptionReason Reason { get; set; } = ExceptionReason.Closed;
        public string? Note { get; set; }
    }
}
