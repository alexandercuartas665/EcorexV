@page "/servicios"
@attribute [Authorize(Policy = "TenantMember")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using CubotNails.Application.Tenancy
@using CubotNails.Domain.Enums
@inject IServiceCatalogService Svc
@inject IJSRuntime JS
@inject IWebHostEnvironment Env

<PageTitle>Servicios - CUBOT.nails</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/></svg>
            </div>
            <span>Configuracion del salon</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Servicios</h1>
        <p class="page-sub" style="margin-bottom:0;">Catalogo del salon: precio base, duracion y categoria. Cada asesor de imagen puede ajustar su propio precio en su ficha.</p>
    </div>
    <button class="btn btn-primary" @onclick="() => OpenForm(null)">+ Nuevo servicio</button>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="kpi-grid" style="margin-bottom:22px;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));max-width:620px;">
        <div class="kpi-card">
            <div class="kpi-label">Servicios activos</div>
            <div class="kpi-value">@_items.Count(s => s.IsActive)</div>
            <div class="kpi-hint">En el catalogo</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Duracion promedio</div>
            <div class="kpi-value">@(_items.Count == 0 ? 0 : (int)_items.Average(s => s.DurationMinutes)) min</div>
            <div class="kpi-hint">Por servicio</div>
        </div>
    </div>

    @if (_items.Count == 0)
    {
        <p class="text-muted">Aun no hay servicios. Crea el primero con "+ Nuevo servicio".</p>
    }
    else
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:16px;">
            @foreach (var s in _items)
            {
                <div class="card" style="padding:16px;display:flex;flex-direction:column;gap:9px;@(s.IsActive ? "" : "opacity:.65;")">
                    @{ var thumb = s.Images?.FirstOrDefault()?.Url; }
                    @if (thumb is not null)
                    {
                        <div style="position:relative;margin:-16px -16px 4px;height:130px;border-radius:12px 12px 0 0;overflow:hidden;background:var(--muted);">
                            <img src="@thumb" alt="@s.Name" style="width:100%;height:100%;object-fit:cover;" />
                            @if (s.Images!.Count > 1)
                            {
                                <span style="position:absolute;bottom:6px;right:6px;font-size:10.5px;font-weight:700;padding:2px 8px;border-radius:999px;background:rgba(0,0,0,.6);color:#fff;">@s.Images.Count fotos</span>
                            }
                        </div>
                    }
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;">
                        <div style="display:flex;align-items:center;gap:9px;min-width:0;">
                            <span style="flex:none;width:12px;height:12px;border-radius:4px;background:@(string.IsNullOrWhiteSpace(s.Color) ? "#A03DC9" : s.Color)"></span>
                            <div style="font-weight:800;font-size:15px;line-height:1.25;min-width:0;">@s.Name</div>
                        </div>
                        <span style="flex:none;font-size:11px;font-weight:700;padding:2px 9px;border-radius:999px;@(s.IsActive ? "background:#10b98122;color:#10b981;" : "background:var(--muted);color:var(--muted-foreground);")">@(s.IsActive ? "Activo" : "Inactivo")</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(s.Description))
                    {
                        <div class="text-muted" style="font-size:12px;">@Trim(s.Description!, 120)</div>
                    }
                    <div style="display:flex;flex-wrap:wrap;gap:6px 16px;font-size:12.5px;">
                        <span><span class="text-muted">Categoria:</span> <strong>@(string.IsNullOrWhiteSpace(s.Category) ? "-" : s.Category)</strong></span>
                        @if (s.PriceTiers is { Count: > 0 } pt)
                        {
                            <span><span class="text-muted">Precio:</span> <strong>desde $@(pt.Min(t => t.Price).ToString("N0"))</strong> <span class="text-muted">(por largo)</span></span>
                        }
                        else
                        {
                            <span><span class="text-muted">Duracion:</span> <strong>@s.DurationMinutes min</strong></span>
                            <span><span class="text-muted">Precio:</span> <strong>$@s.Price.ToString("N0")</strong></span>
                        }
                    </div>
                    @if (s.PriceTiers is { Count: > 0 } tiers2)
                    {
                        <div style="display:flex;flex-wrap:wrap;gap:4px;">
                            @foreach (var t in tiers2)
                            {
                                <span style="font-size:11px;background:var(--muted);border-radius:6px;padding:2px 7px;">@LengthLabel(t.Length): <strong>$@t.Price.ToString("N0")</strong>@(t.DurationMinutes > 0 ? $" · {t.DurationMinutes}min" : "")</span>
                            }
                        </div>
                    }
                    <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:auto;padding-top:4px;">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenForm(s)">Editar</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleActiveAsync(s)" disabled="@_busy">@(s.IsActive ? "Desactivar" : "Activar")</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(s)" disabled="@_busy" title="Eliminar servicio">&times;</button>
                    </div>
                </div>
            }
        </div>
    }
}

@if (_formOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog">
            <div class="modal-head">
                <h3>@(_editingId is null ? "Nuevo servicio" : "Editar servicio")</h3>
                <button class="modal-close" @onclick="() => _formOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Nombre *</label>
                    <input class="form-control" @bind="_form.Name" placeholder="Manicure semipermanente" />
                </div>
                <div class="field">
                    <label class="form-label">Descripcion</label>
                    <RichTextArea @bind-Value="_form.Description" Rows="3" Placeholder="En que consiste el servicio..." />
                </div>
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Duracion (min)</label>
                        <input class="form-control" type="number" min="0" @bind="_form.DurationMinutes" />
                    </div>
                    <div class="field">
                        <label class="form-label">Precio base</label>
                        <input class="form-control" type="number" min="0" @bind="_form.Price" />
                    </div>
                </div>
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Categoria</label>
                        <input class="form-control" @bind="_form.Category" placeholder="Unas, cabello, spa..." />
                    </div>
                    <div class="field">
                        <label class="form-label">Color en la agenda</label>
                        <input class="form-control" type="color" @bind="_form.Color" style="height:42px;padding:4px;" />
                    </div>
                </div>

                <div style="border-top:1px solid var(--border);padding-top:12px;margin-top:12px;">
                    <label class="form-label">Precios por largo de cabello (opcional)</label>
                    <div class="text-muted" style="font-size:11.5px;margin-bottom:8px;">Si el servicio cambia segun el largo, define el precio y el tiempo por cada largo. Las filas que dejes vacias no se guardan y se usa el precio/duracion base de arriba.</div>
                    <table style="width:100%;border-collapse:collapse;font-size:13px;">
                        <thead>
                            <tr style="text-align:left;color:var(--muted-foreground);font-size:11px;text-transform:uppercase;letter-spacing:.03em;">
                                <th style="padding:4px 6px;font-weight:700;">Largo</th>
                                <th style="padding:4px 6px;font-weight:700;width:38%;">Precio</th>
                                <th style="padding:4px 6px;font-weight:700;width:30%;">Tiempo (min)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _form.Tiers)
                            {
                                <tr>
                                    <td style="padding:4px 6px;font-weight:600;">@LengthLabel(row.Length)</td>
                                    <td style="padding:4px 6px;"><input class="form-control" type="number" min="0" step="1000" @bind="row.Price" style="height:34px;" placeholder="—" /></td>
                                    <td style="padding:4px 6px;"><input class="form-control" type="number" min="0" @bind="row.Minutes" style="height:34px;" placeholder="—" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div style="border-top:1px solid var(--border);padding-top:12px;margin-top:12px;">
                    <label class="form-label">Imagenes</label>
                    @if (_editingId is null)
                    {
                        <div class="text-muted small">Guarda el servicio y luego podras agregar sus imagenes.</div>
                    }
                    else
                    {
                        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:8px;">
                            @foreach (var img in _images)
                            {
                                <div style="position:relative;width:84px;height:84px;border-radius:10px;overflow:hidden;border:1px solid var(--border);">
                                    <img src="@img.Url" alt="@img.FileName" style="width:100%;height:100%;object-fit:cover;" />
                                    <button type="button" title="Quitar" @onclick="() => RemoveImageAsync(img.Id)" disabled="@_busy"
                                            style="position:absolute;top:2px;right:2px;width:20px;height:20px;border-radius:50%;border:none;background:rgba(0,0,0,.6);color:#fff;cursor:pointer;line-height:1;">&times;</button>
                                </div>
                            }
                        </div>
                        <InputFile OnChange="OnImagesSelectedAsync" accept="image/*" multiple />
                        @if (_imgMsg is not null) { <div class="text-muted small" style="margin-top:4px;">@_imgMsg</div> }
                    }
                </div>
                @if (_error is not null)
                {
                    <div class="text-danger small">@_error</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _formOpen = false">@(_editingId is null ? "Cancelar" : "Listo")</button>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_form.Name))">Guardar</button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _busy;
    private bool _formOpen;
    private string? _error;
    private Guid? _editingId;
    private List<ServiceDto> _items = new();
    private FormModel _form = new();
    private List<ServiceImageDto> _images = new();
    private string? _imgMsg;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _items = (await Svc.ListAsync(includeInactive: true)).ToList();
        _loading = false;
    }

    private void OpenForm(ServiceDto? s)
    {
        _error = null;
        _imgMsg = null;
        _editingId = s?.Id;
        _images = s?.Images?.ToList() ?? new();
        _form = s is null
            ? new FormModel { Color = "#A03DC9", DurationMinutes = 45 }
            : new FormModel { Name = s.Name, Description = s.Description, DurationMinutes = s.DurationMinutes, Price = s.Price, Category = s.Category, Color = string.IsNullOrWhiteSpace(s.Color) ? "#A03DC9" : s.Color };
        // Carga las tarifas por largo guardadas (sobre las 4 filas por defecto).
        if (s?.PriceTiers is not null)
        {
            foreach (var t in s.PriceTiers)
            {
                var row = _form.Tiers.FirstOrDefault(r => r.Length == t.Length);
                if (row is not null) { row.Price = t.Price; row.Minutes = t.DurationMinutes; }
            }
        }
        _formOpen = true;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Name)) { _error = "Escribe el nombre del servicio."; return; }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var tiers = _form.Tiers.Select(r => new ServicePriceTierDto(r.Length, r.Price, r.Minutes)).ToList();
            var req = new SaveServiceRequest(_form.Name, _form.DurationMinutes, _form.Price, _form.Category, _form.Color, _form.Description, tiers);
            if (_editingId is Guid id)
            {
                var updated = await Svc.UpdateAsync(id, req, actor);
                if (updated is null) { _error = "No se pudo guardar."; return; }
                _images = updated.Images?.ToList() ?? _images;
            }
            else
            {
                // Tras crear, dejamos el modal ABIERTO para que se puedan agregar imagenes (ya hay Id).
                var created = await Svc.CreateAsync(req, actor);
                if (created is null) { _error = "No se pudo crear el servicio."; return; }
                _editingId = created.Id;
                _images = created.Images?.ToList() ?? new();
            }
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private async Task OnImagesSelectedAsync(InputFileChangeEventArgs e)
    {
        if (_editingId is not Guid id) { return; }
        _busy = true; _imgMsg = null;
        try
        {
            var actor = await ActorAsync();
            foreach (var file in e.GetMultipleFiles(8))
            {
                var saved = await SaveImageFileAsync(file);
                if (saved is null) { _imgMsg = "Alguna imagen no se pudo subir (max 10MB)."; continue; }
                await Svc.AddImageAsync(id, saved.Value.Url, saved.Value.Name, actor);
            }
            var fresh = await Svc.GetAsync(id);
            _images = fresh?.Images?.ToList() ?? _images;
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private async Task RemoveImageAsync(Guid imageId)
    {
        _busy = true;
        try
        {
            await Svc.RemoveImageAsync(imageId, await ActorAsync());
            if (_editingId is Guid id) { var fresh = await Svc.GetAsync(id); _images = fresh?.Images?.ToList() ?? new(); }
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private async Task<(string Url, string Name)?> SaveImageFileAsync(IBrowserFile file)
    {
        const long max = 10L * 1024 * 1024;
        if (file.Size <= 0 || file.Size > max) { return null; }
        using var ms = new MemoryStream();
        await file.OpenReadStream(max).CopyToAsync(ms);
        var ext = System.IO.Path.GetExtension(file.Name);
        var dir = System.IO.Path.Combine(Env.WebRootPath, "uploads", "services");
        System.IO.Directory.CreateDirectory(dir);
        var name = $"svc-{Guid.NewGuid():N}{ext}";
        await System.IO.File.WriteAllBytesAsync(System.IO.Path.Combine(dir, name), ms.ToArray());
        return ($"/uploads/services/{name}", file.Name);
    }

    private async Task ToggleActiveAsync(ServiceDto s)
    {
        _busy = true;
        try { await Svc.SetActiveAsync(s.Id, !s.IsActive, await ActorAsync()); await ReloadAsync(); }
        finally { _busy = false; }
    }

    private async Task DeleteAsync(ServiceDto s)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Eliminar el servicio \"{s.Name}\"? Se quitara de las fichas de los asesores.")) { return; }
        _busy = true;
        try { await Svc.DeleteAsync(s.Id, await ActorAsync()); await ReloadAsync(); }
        finally { _busy = false; }
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private static string Trim(string s, int max) => s.Length <= max ? s : s[..max] + "...";

    private static string LengthLabel(HairLength l) => l switch
    {
        HairLength.Corto => "Corto",
        HairLength.Medio => "Medio",
        HairLength.Largo => "Largo",
        HairLength.MuyLargo => "Muy largo",
        _ => l.ToString()
    };

    private sealed class FormModel
    {
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public int DurationMinutes { get; set; } = 45;
        public decimal Price { get; set; }
        public string? Category { get; set; }
        public string? Color { get; set; } = "#A03DC9";
        public List<TierRow> Tiers { get; set; } = DefaultTiers();

        public static List<TierRow> DefaultTiers() => new()
        {
            new TierRow { Length = HairLength.Corto },
            new TierRow { Length = HairLength.Medio },
            new TierRow { Length = HairLength.Largo },
            new TierRow { Length = HairLength.MuyLargo }
        };
    }

    private sealed class TierRow
    {
        public HairLength Length { get; set; }
        public decimal Price { get; set; }
        public int Minutes { get; set; }
    }
}
