@page "/turnos-base"
@attribute [Authorize(Policy = "TenantMember")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using CubotNails.Application.Tenancy
@inject IResourceService Resources
@inject IShiftTemplateService Shifts
@inject IJSRuntime JS

<PageTitle>Turnos base - CUBOT.nails</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <span>Configuracion del salon</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Turnos base</h1>
        <p class="page-sub" style="margin-bottom:0;">Horarios recurrentes por dia y tamano del bloque de cita. Los cupos se calculan como (fin - inicio) / bloque.</p>
    </div>
    @if (_resources.Count > 0)
    {
        <select class="form-control" style="max-width:280px;" @bind="_selectedResourceId" @bind:after="LoadShiftsAsync">
            @foreach (var r in _resources)
            {
                <option value="@r.Id">@r.Name</option>
            }
        </select>
    }
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else if (_resources.Count == 0)
{
    <p class="text-muted">Aun no hay asesores. Crea uno en "Asesores de imagen" para definir sus turnos.</p>
}
else
{
    <div class="card" style="max-width:860px;padding:0;overflow:hidden;">
        @foreach (var (day, label) in Week)
        {
            var dayShifts = _shifts.Where(s => s.DayOfWeek == day).OrderBy(s => s.StartTime).ToList();
            var total = dayShifts.Sum(s => s.Slots);
            <div style="padding:18px 20px;border-bottom:1px solid var(--border);">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:@(dayShifts.Count > 0 ? "12px" : "0")">
                    <div>
                        <span style="font-weight:700;font-size:1.05rem;">@label</span>
                        @if (total > 0)
                        {
                            <span class="badge bg-secondary" style="margin-left:8px;">@total cupos</span>
                        }
                        else
                        {
                            <span class="text-muted" style="margin-left:8px;font-size:13px;font-style:italic;">Dia no operativo</span>
                        }
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenAdd(day)">+ Anadir turno</button>
                </div>
                @foreach (var sh in dayShifts)
                {
                    <div style="display:flex;align-items:center;gap:14px;background:var(--muted);padding:10px 14px;border-radius:10px;margin-bottom:8px;">
                        <span style="font-weight:700;">@sh.StartTime.ToString("HH:mm") &ndash; @sh.EndTime.ToString("HH:mm")</span>
                        <span class="text-muted" style="font-size:13px;">bloque @sh.SlotMinutes min</span>
                        <span class="badge bg-success" style="margin-left:auto;">@sh.Slots cupos</span>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenEdit(sh)">Editar</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(sh)" disabled="@_busy">Quitar</button>
                    </div>
                }
            </div>
        }
    </div>
}

@if (_shiftFormOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog">
            <div class="modal-head">
                <h3>@(_shiftForm.ShiftId is null ? "Nuevo turno" : "Editar turno") &middot; @DayLabel(_shiftForm.Day)</h3>
                <button class="modal-close" @onclick="() => _shiftFormOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Desde</label>
                        <input class="form-control" type="time" @bind="_shiftForm.Start" />
                    </div>
                    <div class="field">
                        <label class="form-label">Hasta</label>
                        <input class="form-control" type="time" @bind="_shiftForm.End" />
                    </div>
                </div>
                <div class="field">
                    <label class="form-label">Tamano de bloque (min)</label>
                    <input class="form-control" type="number" min="5" step="5" @bind="_shiftForm.SlotMinutes" />
                </div>
                <div class="text-muted" style="font-size:13px;">Cupos resultantes: <strong>@PreviewSlots()</strong></div>
                @if (_error is not null)
                {
                    <div class="text-danger small" style="margin-top:8px;">@_error</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _shiftFormOpen = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveShiftAsync" disabled="@_busy">Guardar turno</button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private static readonly (DayOfWeek Day, string Label)[] Week =
    {
        (DayOfWeek.Monday, "Lunes"),
        (DayOfWeek.Tuesday, "Martes"),
        (DayOfWeek.Wednesday, "Miercoles"),
        (DayOfWeek.Thursday, "Jueves"),
        (DayOfWeek.Friday, "Viernes"),
        (DayOfWeek.Saturday, "Sabado"),
        (DayOfWeek.Sunday, "Domingo")
    };

    private bool _loading = true;
    private bool _busy;
    private bool _shiftFormOpen;
    private string? _error;
    private List<ResourceDto> _resources = new();
    private Guid _selectedResourceId;
    private List<ShiftDto> _shifts = new();
    private ShiftForm _shiftForm = new();

    protected override async Task OnInitializedAsync()
    {
        _resources = (await Resources.ListAsync()).ToList();
        if (_resources.Count > 0)
        {
            _selectedResourceId = _resources[0].Id;
            await LoadShiftsAsync();
        }
        _loading = false;
    }

    private async Task LoadShiftsAsync()
    {
        if (_selectedResourceId == Guid.Empty) { _shifts = new(); return; }
        _shifts = (await Shifts.ListAsync(_selectedResourceId)).ToList();
    }

    private void OpenAdd(DayOfWeek day)
    {
        _error = null;
        _shiftForm = new ShiftForm { ShiftId = null, Day = day, Start = new TimeOnly(9, 0), End = new TimeOnly(13, 0), SlotMinutes = 45 };
        _shiftFormOpen = true;
    }

    private void OpenEdit(ShiftDto sh)
    {
        _error = null;
        _shiftForm = new ShiftForm { ShiftId = sh.Id, Day = sh.DayOfWeek, Start = sh.StartTime, End = sh.EndTime, SlotMinutes = sh.SlotMinutes };
        _shiftFormOpen = true;
    }

    private int PreviewSlots() => ShiftTemplateService.SlotsOf(_shiftForm.Start, _shiftForm.End, _shiftForm.SlotMinutes);

    private async Task SaveShiftAsync()
    {
        _error = null;
        if (_shiftForm.End <= _shiftForm.Start) { _error = "La hora 'Hasta' debe ser mayor que 'Desde'."; return; }
        if (_shiftForm.SlotMinutes <= 0) { _error = "El bloque debe ser mayor a 0."; return; }
        _busy = true;
        try
        {
            var req = new SaveShiftRequest(_shiftForm.Day, _shiftForm.Start, _shiftForm.End, _shiftForm.SlotMinutes);
            var actor = await ActorAsync();
            var result = _shiftForm.ShiftId is Guid id
                ? await Shifts.UpdateAsync(id, req, actor)
                : await Shifts.AddAsync(_selectedResourceId, req, actor);
            if (result is null) { _error = "No se pudo guardar el turno."; return; }
            _shiftFormOpen = false;
            await LoadShiftsAsync();
        }
        finally { _busy = false; }
    }

    private async Task DeleteAsync(ShiftDto sh)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Quitar este turno?")) { return; }
        _busy = true;
        try { await Shifts.DeleteAsync(sh.Id, await ActorAsync()); await LoadShiftsAsync(); }
        finally { _busy = false; }
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private static string DayLabel(DayOfWeek d) => Week.First(w => w.Day == d).Label;

    private sealed class ShiftForm
    {
        public Guid? ShiftId { get; set; }
        public DayOfWeek Day { get; set; }
        public TimeOnly Start { get; set; } = new(9, 0);
        public TimeOnly End { get; set; } = new(13, 0);
        public int SlotMinutes { get; set; } = 45;
    }
}
