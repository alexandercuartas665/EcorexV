@inherits LayoutComponentBase

<div class="cubot-shell">
    <aside class="cubot-sidebar">
        <NavMenu />
    </aside>

    <div class="cubot-main">
        <div class="cubot-topbar">
            <AuthorizeView>
                <Authorized>
                    <span class="cubot-user-chip">Super Admin · <strong>@context.User.Identity?.Name</strong></span>
                    <form method="post" action="/auth/logout" class="m-0">
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Salir</button>
                    </form>
                </Authorized>
            </AuthorizeView>
        </div>

        <div class="cubot-content">
            @Body
        </div>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Ha ocurrido un error.
    <a href="." class="reload">Recargar</a>
    <span class="dismiss">🗙</span>
</div>
