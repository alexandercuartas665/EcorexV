@page "/"
@attribute [Authorize]
@inject ITenantAdminService TenantsSvc
@inject IPlanAdminService PlansSvc

<PageTitle>Dashboard - CUBOT.travels</PageTitle>

<h1>Dashboard</h1>
<p class="text-muted">Resumen operativo de la plataforma.</p>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="row g-3" style="max-width:780px;">
        <div class="col-md-4">
            <div class="card text-bg-light"><div class="card-body">
                <div class="text-muted small">Agencias</div>
                <div style="font-size:2rem;font-weight:600;">@_totalTenants</div>
            </div></div>
        </div>
        <div class="col-md-4">
            <div class="card text-bg-light"><div class="card-body">
                <div class="text-muted small">Agencias activas</div>
                <div style="font-size:2rem;font-weight:600;">@_activeTenants</div>
            </div></div>
        </div>
        <div class="col-md-4">
            <div class="card text-bg-light"><div class="card-body">
                <div class="text-muted small">Planes</div>
                <div style="font-size:2rem;font-weight:600;">@_totalPlans</div>
            </div></div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private int _totalTenants;
    private int _activeTenants;
    private int _totalPlans;

    protected override async Task OnInitializedAsync()
    {
        var tenants = await TenantsSvc.ListAsync();
        var plans = await PlansSvc.ListAsync();
        _totalTenants = tenants.Count;
        _activeTenants = tenants.Count(t => t.Status == TenantStatus.Active);
        _totalPlans = plans.Count;
        _loading = false;
    }
}
