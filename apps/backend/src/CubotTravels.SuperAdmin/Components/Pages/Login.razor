@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]

<PageTitle>Ingresar - CUBOT.travels</PageTitle>

<div class="login-wrap">
    <div class="login-card">
        <div class="login-logo">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
        </div>
        <div class="login-title">CUBOT<span>.travels</span></div>
        <p class="text-muted" style="margin:4px 0 22px;">Consola Super Admin</p>

        @if (Error == 1)
        {
            <div class="alert alert-danger py-2">Credenciales invalidas o sin permisos de Super Admin.</div>
        }

        <form method="post" action="/auth/login">
            <div class="mb-3">
                <label class="form-label">Correo</label>
                <input class="form-control" name="email" type="email" required autofocus />
            </div>
            <div class="mb-3">
                <label class="form-label">Clave</label>
                <input class="form-control" name="password" type="password" required />
            </div>
            <button class="btn btn-primary w-100" type="submit">Ingresar</button>
        </form>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public int? Error { get; set; }
}
