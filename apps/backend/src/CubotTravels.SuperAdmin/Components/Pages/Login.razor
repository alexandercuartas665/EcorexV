@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]

<PageTitle>Ingresar - CUBOT.travels</PageTitle>

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:#f3f4f6;">
    <div style="width:360px;background:#fff;padding:32px;border-radius:12px;box-shadow:0 10px 30px rgba(0,0,0,.08);">
        <h1 style="font-size:1.5rem;margin-bottom:4px;">CUBOT.travels</h1>
        <p class="text-muted" style="margin-bottom:24px;">Consola Super Admin</p>

        @if (Error == 1)
        {
            <div class="alert alert-danger py-2">Credenciales invalidas o sin permisos de Super Admin.</div>
        }

        <form method="post" action="/auth/login">
            <div class="mb-3">
                <label class="form-label">Correo</label>
                <input class="form-control" name="email" type="email" required autofocus />
            </div>
            <div class="mb-3">
                <label class="form-label">Clave</label>
                <input class="form-control" name="password" type="password" required />
            </div>
            <button class="btn btn-primary w-100" type="submit">Ingresar</button>
        </form>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public int? Error { get; set; }
}
