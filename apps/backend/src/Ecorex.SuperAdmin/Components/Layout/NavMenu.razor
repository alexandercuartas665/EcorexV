@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    // El menu se arma por rol: el operador de plataforma (platform_role) ve el grupo
    // Super Admin SaaS y previsualiza el workspace del tenant; el usuario de empresa
    // (tenant_id) ve las secciones Principal / Modulos / Sistema y el CRM heredado.
    private bool _showAdmin;
    private bool _showTenant;
    private bool _isSuperAdmin;
    private string? _userName;
    private string? _tenantName;
    private string? _planName;
    // Marca de la plataforma (Super Admin -> Marca): logo, nombre y bajada del sidebar.
    private string? _brandName;
    private string? _brandTagline;
    private string? _brandLogoUrl;
    private string _roleLabel = "Operador de plataforma";
    private string _avatar = "SA";

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;

        // Marca de la plataforma configurada en Super Admin -> Marca (logo + nombre + bajada). Scope
        // aislado para no compartir el DbContext del circuito. Si falla, el markup usa los valores por defecto.
        try
        {
            await using var brandScope = ScopeFactory.CreateAsyncScope();
            var branding = brandScope.ServiceProvider.GetRequiredService<Ecorex.Application.Admin.IPlatformBrandingService>();
            var b = await branding.GetAsync();
            _brandName = b.PlatformName;
            _brandTagline = b.Tagline;
            _brandLogoUrl = b.LoginLogoUrl;
        }
        catch { /* sin branding: se usa el logo/nombre por defecto */ }

        if (AuthState is null)
        {
            return;
        }

        var state = await AuthState;
        var isPlatformOperator = state.User.FindFirst("platform_role") is not null;
        var tenantClaim = state.User.FindFirst("tenant_id")?.Value;
        var isTenantUser = tenantClaim is not null;

        _showAdmin = isPlatformOperator;
        _showTenant = isPlatformOperator || isTenantUser;
        _isSuperAdmin = state.User.FindFirst("platform_role")?.Value == "SuperAdmin";

        _userName = state.User.Identity?.Name;
        _avatar = Initials(_userName);

        if (isPlatformOperator)
        {
            _roleLabel = "Operador de plataforma";
        }
        else if (isTenantUser)
        {
            _roleLabel = state.User.FindFirst("tenant_role")?.Value ?? "Miembro";
            if (Guid.TryParse(tenantClaim, out var tenantId))
            {
                var tenant = await TenantsSvc.GetAsync(tenantId);
                _tenantName = tenant?.Name;

                // Plan activo para la cabecera del workspace ("Plan Empresa - ECOREX").
                // Si no hay suscripcion (o falla), se muestra la bajada generica.
                try
                {
                    var sub = (await SubsSvc.ListByTenantAsync(tenantId)).FirstOrDefault();
                    if (sub is not null)
                    {
                        _planName = (await PlansSvc.GetAsync(sub.PlanId))?.Name;
                    }
                }
                catch { /* sin plan visible: bajada generica */ }
            }
        }
    }

    /// <summary>Inicial del tenant para el tile cuadrado del header (prototipo: "S" de SKY SYSTEM).</summary>
    private string TenantInitial => string.IsNullOrWhiteSpace(_tenantName) ? "E" : _tenantName.Trim()[..1].ToUpperInvariant();

    /// <summary>
    /// Estado inicial (server-side) de cada acordeon de MODULOS: abierto si contiene la ruta
    /// activa o si es uno de los grupos abiertos por defecto en el fuente (misproc/auto; el
    /// subgrupo Comercial abre por defecto como en el prototipo).
    /// El toggle del usuario se persiste en localStorage y lo reaplica el script de MainLayout.
    /// </summary>
    private bool IsGroupOpen(string key)
    {
        var rel = Navigation.ToBaseRelativePath(Navigation.Uri)
            .Split('?', '#')[0]
            .TrimEnd('/')
            .ToLowerInvariant();
        var containsActive = GroupRoutes.TryGetValue(key, out var routes)
            && routes.Any(r => rel == r || rel.StartsWith(r + "/", StringComparison.Ordinal));
        return containsActive || key is "misproc" or "auto" or "sg-comercial";
    }

    // Rutas contenidas por cada grupo del menu (para abrir el acordeon de la ruta activa).
    private static readonly Dictionary<string, string[]> GroupRoutes = new()
    {
        ["misproc"] = ["crear-actividad", "proyectos", "actividades", "modulo/programar-actividad"],
        ["sg-comercial"] = ["actividades"],
        ["nego"] = ["modulo/creacion-de-clientes", "modulo/seguimiento-de-clientes", "pipeline"],
        ["auto"] = ["flujos", "formularios", "modulo/power-bi-service", "agentes"],
        ["inv"] = ["inventario-bodegas", "inventario-grupos", "inventario-marcas", "inventario-subgrupos", "inventario-tipos", "inventario-items"],
        ["act"] = ["modulo/prioridades", "modulo/tipos-de-proyecto", "conceptos", "modulo/estados"],
        ["syscrm"] = ["modulo/conceptos-actividades", "modulo/estados-crm", "modulo/perfiles-cliente-prov", "modulo/servicios-o-productos",
                      "modulo/tipos-de-empresas", "modulo/vendedores", "modulo/origen-clientes", "modulo/grupos-de-actividades"],
        ["gen"] = ["configuracion", "modulo/crear-empresas", "extraccion-datos", "plantillas", "dependencias",
                   "modulo/roles-y-permisos", "modulo/administracion-de-usuarios"],
        ["dev"] = ["modulo/autocompletado-formularios", "modulos-web", "modulo/notificaciones-config", "modulo/objetos-del-sistema",
                   "modulo/parametros-xml", "reglas", "metricas", "modulo/servicios-web", "modulo/sql-admin", "modulo/consecutivos"],
        ["crm"] = ["asesores", "conversaciones", "lineas", "plantillas-whatsapp", "bitacora-agente", "automatizaciones", "lista-negra"],
    };

    // Paleta AVPAL del prototipo (avatares con color solido mate): (char0 + char1) % 8.
    private static readonly string[] AvatarPalette =
    [
        "#E0876B", "#7E78E6", "#3FA39B", "#5B8DEF", "#C77FD0", "#D9A441", "#5FAE6E", "#E07A9B"
    ];

    private string AvatarBg
    {
        get
        {
            if (string.IsNullOrEmpty(_avatar)) { return AvatarPalette[0]; }
            var sum = _avatar[0] + (_avatar.Length > 1 ? _avatar[1] : 0);
            return AvatarPalette[sum % AvatarPalette.Length];
        }
    }

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1
            ? parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant()
            : $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e) => StateHasChanged();
    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;
}
