@implements IDisposable
@inject NavigationManager Navigation
@inject ITenantAdminService TenantsSvc
@inject ISubscriptionAdminService SubsSvc
@inject IPlanAdminService PlansSvc
@inject IServiceScopeFactory ScopeFactory
@using Microsoft.Extensions.DependencyInjection

@if (_showAdmin)
{
    @* Consola de plataforma: marca configurable (Super Admin -> Marca) con icono de tablero. *@
    <div class="ecorex-brand">
        <div class="ecorex-logo">
            @if (!string.IsNullOrWhiteSpace(_brandLogoUrl))
            {
                <img src="@_brandLogoUrl" alt="@(_brandName ?? "Logo")" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;" />
            }
            else
            {
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="3"/><path d="m7.5 12 2 2 4-4.5"/><path d="M16.5 16h.01"/></svg>
            }
        </div>
        <div>
            @if (string.IsNullOrWhiteSpace(_brandName) || _brandName == "ECOREX.tareas")
            {
                <div class="ecorex-brand-name">ECOREX<span>.tareas</span></div>
            }
            else
            {
                <div class="ecorex-brand-name">@_brandName</div>
            }
            <div class="ecorex-brand-sub">@(_brandTagline ?? "Sistema de Tareas")</div>
        </div>
    </div>
}
else
{
    @* Cabecera del workspace (fuente ECOREX.dc.html): tile 36px radio 11 con fondo
       var(--ink) + inicial, nombre 14.5/700 y "{plan} (punto medio) ECOREX" (el nombre del plan
       ya trae la palabra "Plan"; separador punto medio como el prototipo). *@
    <div class="ecorex-ws-head">
        <div class="ecorex-ws-row" title="@(_tenantName ?? "Mi empresa")">
            <div class="ecorex-tenant-tile">@TenantInitial</div>
            <div style="flex:1;min-width:0;">
                <div class="ecorex-tenant-name">@(_tenantName ?? "Mi empresa")</div>
                <div class="ecorex-tenant-sub">@(_planName is null ? "ECOREX Sistema de Tareas" : $"{_planName} \u00b7 ECOREX")</div>
            </div>
            <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/></svg>
        </div>
    </div>
}

@* Buscador global del prototipo (Cmd/Ctrl+K). Placeholder: se activa junto con el contenido real. *@
<div class="ecorex-search" title="Busqueda global (proximamente)">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    <input type="search" placeholder="Buscar" disabled />
    <span class="kbd">Ctrl K</span>
</div>

@if (_showAdmin)
{
    <div class="ecorex-agency">
        <div class="lbl">Plataforma</div>
        <div class="name">ECOREX.tareas</div>
        <div class="meta">Consola de gobierno</div>
    </div>
}

