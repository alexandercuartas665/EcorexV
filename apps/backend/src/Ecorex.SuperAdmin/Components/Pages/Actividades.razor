@page "/actividades"
@page "/tableros-actividades"
@attribute [Authorize(Policy = "Tareas.Ver")]
@* Policy por modulo (paso 1: mismo requisito que TenantMember, nombre estable). TODO: derivar del Module Registry. *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.SuperAdmin.Components.Shared.Tasks
@inject NavigationManager Nav

@* Ola 2 (prototipo corregido, pantalla 'work'): la experiencia de /actividades es el
   INDICE DE TABLEROS + DETALLE DE TABLERO por columnas propias (ADR-0020). El kanban
   por estado (TaskKanban) queda desconectado de esta ruta; sigue vivo en ProyectoDetalle.
   El wizard de 3 pasos (tipo + flujo BPMN) sobrevive como "Actividad completa" en el
   indice. Deep-link: /actividades?board={id}. *@

<PageTitle>Tableros - ECOREX.tareas</PageTitle>

@if (BoardIdOrNull is Guid boardId)
{
    <ActivityBoardDetail BoardId="boardId" OnBack="BackToIndex" />
}
else
{
    <ActivityBoardsIndex OnOpenBoard="OpenBoard" />
}

@code {
    [SupplyParameterFromQuery(Name = "board")]
    public string? Board { get; set; }

    private Guid? BoardIdOrNull => Guid.TryParse(Board, out var id) ? id : null;

    private void OpenBoard(Guid boardId)
        => Nav.NavigateTo($"/actividades?board={boardId}");

    private void BackToIndex()
        => Nav.NavigateTo("/actividades");
}
