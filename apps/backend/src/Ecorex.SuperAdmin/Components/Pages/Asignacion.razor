@page "/asignacion"
@attribute [Authorize(Policy = "TenantMember")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.Application.Tenancy
@using Ecorex.Domain.Enums
@inject IResourceService Resources
@inject IAgendaService Agenda

<PageTitle>Asignacion - ECOREX.tareas</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M8 2v4"/><path d="M16 2v4"/><path d="m9 16 2 2 4-4"/></svg>
            </div>
            <span>Operacion diaria</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Asignacion por asesor</h1>
        <p class="page-sub" style="margin-bottom:0;">Elige el asesor y un dia (verde = hay cupos) para reservar las citas.</p>
    </div>
    @if (_resources.Count > 0)
    {
        <select class="form-control" style="max-width:260px;" @bind="_selectedResourceId" @bind:after="OnResourceChanged">
            @foreach (var r in _resources)
            {
                <option value="@r.Id">@r.Name</option>
            }
        </select>
    }
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else if (_resources.Count == 0)
{
    <p class="text-muted">Aun no hay asesores. Crea uno en "Asesores de imagen".</p>
}
else
{
    <div style="display:grid;grid-template-columns:minmax(300px,420px) 1fr;gap:22px;align-items:start;" class="asg-cols">
        <div class="card" style="padding:18px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
                <h3 style="margin:0;font-size:1.05rem;">@_monthLabel</h3>
                <div style="display:flex;gap:6px;">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ChangeMonth(-1)">&lsaquo;</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ChangeMonth(1)">&rsaquo;</button>
                </div>
            </div>
            <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:6px;text-align:center;">
                @foreach (var h in _dayHeaders)
                {
                    <div class="text-muted" style="font-size:11px;font-weight:700;">@h</div>
                }
                @for (var i = 0; i < _leadingBlanks; i++)
                {
                    <div></div>
                }
                @foreach (var d in _monthDays)
                {
                    <div style="@DayCellStyle(d)" @onclick="() => SelectDay(d)">
                        <span style="font-weight:700;">@d.Day</span>
                        @if (d.Status != "closed")
                        {
                            <span style="font-size:10px;opacity:.85;">@d.Free libres</span>
                        }
                    </div>
                }
            </div>
            <div style="display:flex;gap:14px;margin-top:14px;font-size:12px;" class="text-muted">
                <span><span style="display:inline-block;width:11px;height:11px;border-radius:3px;background:#DCFCE7;border:1px solid #166534;vertical-align:middle;"></span> Disponible</span>
                <span><span style="display:inline-block;width:11px;height:11px;border-radius:3px;background:#FCE7F0;border:1px solid #9D174D;vertical-align:middle;"></span> Lleno</span>
                <span><span style="display:inline-block;width:11px;height:11px;border-radius:3px;background:#F1ECE4;vertical-align:middle;"></span> Cerrado</span>
            </div>
        </div>

        <div class="card" style="padding:18px;">
            <h3 style="margin-top:0;font-size:1.05rem;">Citas del dia: <span style="color:var(--primary);">@(_selectedDate is null ? "Selecciona un dia" : _selectedDate.Value.ToString("dddd dd MMM"))</span></h3>
            @if (_selectedDate is null)
            {
                <p class="text-muted" style="padding:24px 0;text-align:center;">Haz clic en un dia con cupos para ver y reservar citas.</p>
            }
            else if (_slots.Count == 0)
            {
                <p class="text-muted">No hay cupos configurados ese dia (revisa Turnos base).</p>
            }
            else
            {
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:10px;">
                    @foreach (var s in _slots)
                    {
                        <div class="card" style="@SlotCardStyle(s.Occupied)" @onclick="() => OnSlotClick(s)">
                            <strong style="display:block;">@s.Time.ToString("HH\\:mm")</strong>
                            @if (s.Occupied)
                            {
                                <span style="font-size:12px;font-weight:700;color:var(--accent-foreground);">@(s.ClientName ?? "?")</span>
                                <span class="text-muted" style="display:block;font-size:11px;">@s.ServicesText</span>
                                <span class="badge bg-@StatusBadge(s.Status)" style="margin-top:4px;">@StatusText(s.Status)</span>
                            }
                            else
                            {
                                <span class="text-muted" style="font-size:12px;font-weight:700;text-transform:uppercase;">Libre</span>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<BookingModal @ref="_modal" Resources="_resources" OnSaved="OnBookingSaved" />

@code {
    private bool _loading = true;
    private List<ResourceDto> _resources = new();
    private Guid _selectedResourceId;
    private DateOnly _monthDate = new(DateOnly.FromDateTime(DateTime.Today).Year, DateOnly.FromDateTime(DateTime.Today).Month, 1);
    private List<MonthDayDto> _monthDays = new();
    private int _leadingBlanks;
    private string _monthLabel = "";
    private DateOnly? _selectedDate;
    private List<SlotDto> _slots = new();
    private BookingModal _modal = default!;

    private static readonly string[] _dayHeaders = { "D", "L", "M", "M", "J", "V", "S" };

    protected override async Task OnInitializedAsync()
    {
        _resources = (await Resources.ListAsync()).ToList();
        if (_resources.Count > 0)
        {
            _selectedResourceId = _resources[0].Id;
            await LoadMonthAsync();
        }
        _loading = false;
    }

    private async Task OnResourceChanged()
    {
        _selectedDate = null; _slots = new();
        await LoadMonthAsync();
    }

    private async Task LoadMonthAsync()
    {
        _monthLabel = _monthDate.ToString("MMMM yyyy");
        _leadingBlanks = (int)_monthDate.DayOfWeek; // Domingo = 0
        _monthDays = (await Agenda.GetMonthAvailabilityAsync(_selectedResourceId, _monthDate.Year, _monthDate.Month)).ToList();
    }

    private async Task ChangeMonth(int dir)
    {
        _monthDate = _monthDate.AddMonths(dir);
        _selectedDate = null; _slots = new();
        await LoadMonthAsync();
    }

    private async Task SelectDay(MonthDayDto d)
    {
        if (d.Status == "closed") { return; }
        _selectedDate = d.Date;
        _slots = (await Agenda.GetDaySlotsAsync(_selectedResourceId, d.Date)).ToList();
    }

    private async Task OnSlotClick(SlotDto s)
    {
        if (s.Occupied && s.AppointmentId is Guid id)
        {
            await _modal.OpenForEditAsync(id);
        }
        else if (_selectedDate is DateOnly date)
        {
            var name = _resources.FirstOrDefault(r => r.Id == _selectedResourceId)?.Name ?? "";
            await _modal.OpenForNewAsync(_selectedResourceId, date, s.Time, name);
        }
    }

    private async Task OnBookingSaved()
    {
        await LoadMonthAsync();
        if (_selectedDate is DateOnly date)
        {
            _slots = (await Agenda.GetDaySlotsAsync(_selectedResourceId, date)).ToList();
        }
    }

    private string DayCellStyle(MonthDayDto d)
    {
        var (bg, fg) = CellColors(d.Status);
        var cursor = d.Status == "closed" ? "default" : "pointer";
        var sel = _selectedDate == d.Date ? "outline:2px solid var(--primary);font-weight:800;" : "";
        return $"aspect-ratio:1;display:flex;flex-direction:column;align-items:center;justify-content:center;border-radius:8px;background:{bg};color:{fg};cursor:{cursor};{sel}";
    }

    private static string SlotCardStyle(bool occupied) =>
        "padding:11px;cursor:pointer;" + (occupied ? "background:var(--primary-soft);border-color:var(--primary);" : "");

    private static (string bg, string fg) CellColors(string status) => status switch
    {
        "available" => ("#DCFCE7", "#166534"),
        "full" => ("#FCE7F0", "#9D174D"),
        _ => ("#F1ECE4", "#9A938A")
    };

    private static string StatusText(AppointmentStatus? s) => s switch
    {
        AppointmentStatus.Scheduled => "Programada",
        AppointmentStatus.Confirmed => "Confirmada",
        AppointmentStatus.Completed => "Completada",
        AppointmentStatus.NoShow => "No-show",
        _ => "-"
    };

    private static string StatusBadge(AppointmentStatus? s) => s switch
    {
        AppointmentStatus.Confirmed => "info",
        AppointmentStatus.Completed => "success",
        AppointmentStatus.NoShow => "danger",
        _ => "warning"
    };
}
