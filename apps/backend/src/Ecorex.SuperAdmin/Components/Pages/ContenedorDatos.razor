    private Task OnDataExcelAsync(InputFileChangeEventArgs e) => GuardAsync(async () =>
    {
        if (_dataTable is null) { return; }
        _dataError = _dataFlash = null;
        _busy = true;
        try
        {
            using var ms = new MemoryStream();
            await using (var rs = e.File.OpenReadStream(maxAllowedSize: 8 * 1024 * 1024))
            {
                await rs.CopyToAsync(ms);
            }
            ms.Position = 0;
            var res = await ContainerSvc.ImportFromExcelAsync(_dataTable.Id, ms, _actor);
            if (res.Success)
            {
                _dataFlash = $"Importadas {res.RowsImported} filas" + (res.RowsFailed > 0 ? $" ({res.RowsFailed} con error)" : "") + ".";
            }
            if (res.Errors.Count > 0) { _dataError = string.Join(" | ", res.Errors.Take(4)); }
            _dataRows = (await ContainerSvc.ListRowsAsync(_dataTable.Id)).ToList();
        }
        catch (Exception ex) { _dataError = ex.Message; }
        finally { _busy = false; }
    });

