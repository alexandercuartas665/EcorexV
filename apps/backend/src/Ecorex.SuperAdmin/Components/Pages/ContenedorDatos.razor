    private int _apiCount;
    private string? _apiSample;
    private string _apiArrayPath = "";
    private bool _apiProbed;
    private Guid? _apiTargetTableId;
    private readonly Dictionary<Guid, string> _apiMap = new();
    private string? _apiError;
