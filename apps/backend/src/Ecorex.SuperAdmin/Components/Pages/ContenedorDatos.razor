    // Paginacion (para traer todas las paginas del API).
    private bool _apiPageAll;
    private PagingMode _apiPagingMode = PagingMode.Offset;
    private string _apiOffsetParam = "start";
    private string _apiPageParam = "page";
    private string _apiLimitParam = "limit";
    private int _apiPageSize = 30;
    private int _apiStartValue = 1;
