    private string? GetVal(Guid colId) => _rowValues.TryGetValue(colId, out var v) ? v : null;
    private void SetVal(Guid colId, string? v) => _rowValues[colId] = string.IsNullOrWhiteSpace(v) ? null : v;
    private void SetBoolVal(Guid colId, ChangeEventArgs e) => _rowValues[colId] = (e.Value is bool b && b) ? "true" : "false";
    private bool IsLinked(Guid colId, Guid targetId) => _rowLinks.TryGetValue(colId, out var s) && s.Contains(targetId);

    private void ToggleLink(Guid colId, Guid targetId, bool on)
    {
        if (!_rowLinks.TryGetValue(colId, out var s)) { s = new HashSet<Guid>(); _rowLinks[colId] = s; }
        if (on) { s.Add(targetId); } else { s.Remove(targetId); }
    }

    private Task SaveRowAsync() => SaveRowCoreAsync(keepOpen: false);
    private Task SaveRowAndNewAsync() => SaveRowCoreAsync(keepOpen: true);

    private Task SaveRowCoreAsync(bool keepOpen) => GuardAsync(async () =>
    {
        if (_dataTable is null) { return; }
        _rowError = null;
        _rowFlash = null;
        foreach (var col in EditableColumns())
        {
            if (!col.IsRequired) { continue; }
            if (col.Type == DataContainerColumnType.RelationMany)
            {
                if (!_rowLinks.TryGetValue(col.Id, out var s) || s.Count == 0) { _rowError = $"'{col.Name}' es obligatorio."; return; }
            }
            else if (string.IsNullOrWhiteSpace(GetVal(col.Id))) { _rowError = $"'{col.Name}' es obligatorio."; return; }
        }
        _busy = true;
        try
        {
            var values = new Dictionary<Guid, string?>();
            foreach (var col in EditableColumns())
            {
                if (col.Type == DataContainerColumnType.RelationMany) { continue; }
                values[col.Id] = GetVal(col.Id);
            }
            IReadOnlyDictionary<Guid, IReadOnlyList<Guid>>? links = _rowLinks.Count == 0
                ? null
                : _rowLinks.ToDictionary(kv => kv.Key, kv => (IReadOnlyList<Guid>)kv.Value.ToList());
            var req = new SaveDataRowRequest(_dataTable.Id, _rowEditId, values, null, null, links);
            var saved = await ContainerSvc.SaveRowAsync(req, _actor);
            if (saved is null) { _rowError = "No se pudo guardar la fila."; return; }
            _dataRows = (await ContainerSvc.ListRowsAsync(_dataTable.Id)).ToList();
            if (keepOpen)
            {
                // Deja el formulario limpio y en modo "nueva fila" para capturar la siguiente sin cerrar.
                _rowEditId = null;
                _rowValues.Clear();
                _rowLinks.Clear();
                _rowFlash = $"Fila guardada. Van {_dataRows.Count} en la tabla.";
            }
            else
            {
                _rowEditOpen = false;
            }
        }
        catch (Exception ex) { _rowError = ex.Message; }
        finally { _busy = false; }
    });

