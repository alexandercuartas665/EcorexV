@page "/contenedor-datos"
@attribute [Authorize(Policy = "Perm:contenedor-datos:View")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Globalization
@using System.Security.Claims
@using Ecorex.Application.DataContainers
@using Ecorex.Application.Roles
@using Ecorex.Domain.Enums
@using Ecorex.SuperAdmin.Auth
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable
@inject IDataModelService ModelSvc
@inject IDataContainerService ContainerSvc
@inject IDataImportConfigService ConfigSvc
@inject IApiImportService ApiSvc
@inject ICurrentPermissions Perms
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider

<PageTitle>Contenedor de datos - ECOREX.tareas</PageTitle>

<nav class="ecorex-breadcrumb" aria-label="Ruta de navegacion">
    <a href="/inicio">Workspace</a>
    <span class="sep">/</span>
    <span>Sistema</span>
    <span class="sep">/</span>
    <span class="cur">Contenedor de datos</span>
</nav>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/></svg>
            </div>
            <span>Sistema &#183; Datos personalizados</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Contenedor de datos</h1>
        <p class="page-sub" style="margin-bottom:0;">Un contenedor agrupa varias tablas relacionadas (modelo ER) y define como se alimentan: Excel, API REST o base de datos.</p>
    </div>
    <div style="display:flex;gap:8px;align-items:center;">
        @if (_canCreate)
        {
            <button class="btn btn-primary" @onclick="OpenCreate">+ Nuevo contenedor</button>
        }
    </div>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else if (_models.Count == 0)
{
    <div class="coming-soon" style="padding:40px 24px;">
        <h3>Sin contenedores</h3>
        <p>Aun no tienes contenedores. Crea el primero con "+ Nuevo contenedor".</p>
    </div>
}
else
{
    <div class="dc-grid">
        @foreach (var m in _models)
        {
            <div class="dc-card">
                <div class="dc-card-head">
                    <div class="dc-card-name">@m.Name</div>
                    <span class="dc-badge">@m.TableCount tablas</span>
                </div>
                <div class="dc-card-desc">@(string.IsNullOrWhiteSpace(m.Description) ? "(sin descripcion)" : Truncate(m.Description!, 140))</div>
                <div class="dc-card-meta">@m.TableCount tablas &#183; @m.RelationCount relaciones &#183; act. @m.UpdatedAt.LocalDateTime.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)</div>
                <div class="dc-card-actions">
                    <button class="btn btn-sm btn-primary" @onclick="() => OpenModelAsync(m.Id)">Abrir</button>
                    @if (_canDelete)
                    {
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteModelAsync(m.Id, m.Name)" disabled="@_busy">Eliminar</button>
                    }
                </div>
            </div>
        }
    </div>
}

@if (_pageError is not null)
{
    <div class="tk-field-error">@_pageError</div>
}

@* ===== Modal GRANDE del contenedor (2 columnas: lienzo ER | alimentacion) ===== *@
@if (_modalOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog dc-model-dialog" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>@(_mId is null ? "Nuevo contenedor" : _mName)</h3>
                <button class="modal-close" @onclick="CloseModal">&times;</button>
            </div>
            <div class="modal-body dc-model-body">
                @* ---- Cabecera del contenedor (nombre/descripcion) ---- *@
                <div class="dc-model-headform">
                    <div class="field" style="flex:1;min-width:220px;">
                        <label class="form-label">Nombre del contenedor</label>
                        <input class="form-control" @bind="_mName" maxlength="120" placeholder="Ej. Facturacion" />
                    </div>
                    <div class="field" style="flex:2;min-width:260px;">
                        <label class="form-label">Descripcion (opcional)</label>
                        <input class="form-control" @bind="_mDescription" maxlength="400" placeholder="Para que sirve este contenedor..." />
                    </div>
                    <div style="display:flex;align-items:flex-end;">
                        <button class="btn btn-primary" @onclick="SaveModelHeaderAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_mName))">
                            @(_busy ? "..." : (_mId is null ? "Crear contenedor" : "Guardar"))
                        </button>
                    </div>
                </div>
                @if (_headError is not null)
                {
                    <div class="tk-field-error">@_headError</div>
                }

                @if (_mId is null)
                {
                    <div class="coming-soon" style="padding:26px 20px;margin-top:14px;">
                        <p style="margin:0;">Guarda el contenedor para empezar a agregar tablas y configurar su alimentacion.</p>
                    </div>
                }
                else
                {
                    <div class="dc-model-grid">
                        @* ================= IZQUIERDA: LIENZO ER ================= *@
                        <div class="dc-model-left">
                            <div class="dc-left-head">
                                <div class="dc-cfg-title" style="margin:0;border:0;padding:0;">Modelo ER (@(_detail?.Tables.Count ?? 0) tablas)</div>
                                <div style="display:flex;gap:6px;">
                                    @if (_canEdit)
                                    {
                                        <button class="btn btn-sm btn-primary" @onclick="OpenNewTable">+ Tabla</button>
                                    }
                                </div>
                            </div>
                            <div class="dc-canvas">
                                @if (_detail is not null)
                                {
                                    @* Capa SVG con las lineas de relacion (debajo de las cajas). *@
                                    <svg class="dc-canvas-svg" width="3000" height="2000" xmlns="http://www.w3.org/2000/svg">
                                        @foreach (var rel in _detail.Relations)
                                        {
                                            @if (TryEdge(rel, out var x1, out var y1, out var x2, out var y2))
                                            {
                                                var stroke = rel.Kind == DataModelRelationKind.ManyToMany ? "#e08b2f" : "#7c5cff";
                                                var mx = (x1 + x2) / 2;
                                                var my = (y1 + y2) / 2;
                                                <line x1="@F(x1)" y1="@F(y1)" x2="@F(x2)" y2="@F(y2)" stroke="@stroke" stroke-width="2"
                                                      stroke-dasharray="@(rel.Kind == DataModelRelationKind.ManyToMany ? "6 4" : "0")" />
                                                <circle cx="@F(x2)" cy="@F(y2)" r="4" fill="@stroke" />
                                                @((MarkupString)$"<text x=\"{F(mx)}\" y=\"{F(my - 4)}\" fill=\"{stroke}\" font-size=\"11\" text-anchor=\"middle\">{System.Net.WebUtility.HtmlEncode(rel.Name ?? "")}</text>")
                                            }
                                        }
                                    </svg>

                                    @foreach (var t in _detail.Tables)
                                    {
                                        <div class="dc-table-node" data-table-id="@t.Id"
                                             style="left:@Px(GetX(t.Id))px; top:@Px(GetY(t.Id))px;">
                                            <div class="dc-node-head">
                                                <span class="dc-node-title" title="@t.Name">@t.Name</span>
                                                <span class="dc-node-tools">
                                                    <button class="dc-node-btn" title="Ver datos / importar Excel" @onclick="() => OpenData(t)">&#9636;</button>
                                                    @if (_canEdit)
                                                    {
                                                        <button class="dc-node-btn" title="Editar tabla" @onclick="() => OpenEditTable(t)">&#9998;</button>
                                                    }
                                                    @if (_canDelete)
                                                    {
                                                        <button class="dc-node-btn dc-node-btn-del" title="Eliminar tabla" @onclick="() => DeleteTableAsync(t.Id, t.Name)">&times;</button>
                                                    }
                                                </span>
                                            </div>
                                            <div class="dc-node-fields">
                                                @if (t.Columns.Count == 0)
                                                {
                                                    <div class="dc-node-empty">sin campos</div>
                                                }
                                                else
                                                {
                                                    @foreach (var col in t.Columns.OrderBy(c => c.SortOrder))
                                                    {
                                                        <div class="dc-node-field">
                                                            <span class="dc-field-name">@col.Name</span>
                                                            <span class="dc-field-type">@TypeShort(col.Type)</span>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    }

                                    @if (_detail.Tables.Count == 0)
                                    {
                                        <div class="dc-canvas-hint">Sin tablas todavia. Usa "+ Tabla" para crear la primera.</div>
                                    }
                                }
                            </div>
                            <div class="dc-legend">
                                <span><i class="dc-lg dc-lg-ref"></i> Referencia (N:1)</span>
                                <span><i class="dc-lg dc-lg-many"></i> Relacion (N:N)</span>
                                <span class="text-muted">Arrastra el encabezado de una caja para moverla.</span>
                            </div>

                            @* ----- Relaciones (aristas del ER): entidad propia, ortogonal al tipo de dato ----- *@
                            <div class="dc-section-title" style="margin-top:14px;">Relaciones</div>
                            @if (_detail.Relations.Count == 0)
                            {
                                <div class="text-muted" style="font-size:12px;margin-bottom:8px;">Sin relaciones. Crea una uniendo dos tablas abajo.</div>
                            }
                            else
                            {
                                <div class="dc-rel-list">
                                    @foreach (var rel in _detail.Relations)
                                    {
                                        <div class="dc-rel-item">
                                            <span class="dc-rel-badge @(rel.Kind == DataModelRelationKind.ManyToMany ? "nn" : "n1")">@(rel.Kind == DataModelRelationKind.ManyToMany ? "N:N" : "N:1")</span>
                                            <span class="dc-rel-text">@TableName(rel.FromTableId) &rarr; @TableName(rel.ToTableId)@(string.IsNullOrWhiteSpace(rel.Name) ? "" : $" ({rel.Name})")</span>
                                            @if (_canDelete)
                                            {
                                                <button class="btn btn-sm btn-outline-danger" title="Eliminar relacion" @onclick="() => DeleteRelationAsync(rel.Id)" disabled="@_busy">&times;</button>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            @if (_canEdit && _detail.Tables.Count >= 2)
                            {
                                <div class="dc-rel-add">
                                    <select class="form-control" @bind="_relFrom">
                                        <option value="">Tabla origen</option>
                                        @foreach (var t in _detail.Tables) { <option value="@t.Id">@t.Name</option> }
                                    </select>
                                    <span class="text-muted">&rarr;</span>
                                    <select class="form-control" @bind="_relTo">
                                        <option value="">Tabla destino</option>
                                        @foreach (var t in _detail.Tables) { <option value="@t.Id">@t.Name</option> }
                                    </select>
                                    <select class="form-control" @bind="_relKind" style="max-width:120px;">
                                        <option value="@DataModelRelationKind.ManyToOne">N:1</option>
                                        <option value="@DataModelRelationKind.ManyToMany">N:N</option>
                                    </select>
                                    <input class="form-control" placeholder="Etiqueta (opcional)" @bind="_relName" style="max-width:150px;" />
                                    <button class="btn btn-sm btn-primary" @onclick="AddRelationAsync" disabled="@_busy">+ Relacion</button>
                                </div>
                            }
                            else if (_canEdit)
                            {
                                <div class="text-muted" style="font-size:12px;">Crea al menos <strong>2 tablas</strong> para poder relacionarlas.</div>
                            }
                            @if (_relError is not null) { <div class="tk-field-error" style="margin-top:6px;">@_relError</div> }
                        </div>

                        @* ================= DERECHA: ALIMENTACION ================= *@
                        <div class="dc-model-right">
                            <div class="dc-cfg-title">Alimentacion</div>

                            @* ----- Conectores ----- *@
                            <div class="dc-section-title">Conectores</div>
                            @if (_connectors.Count > 0)
                            {
                                <ul class="dc-mini-list">
                                    @foreach (var c in _connectors)
                                    {
                                        <li>
                                            <div>
                                                <strong>@c.Name</strong> <span class="dc-badge">@ConnectorKindLabel(c.Kind)</span>
                                                <div class="text-muted" style="font-size:11px;">
                                                    @ConnectorSummary(c)@(c.HasCredentials ? " · con credenciales" : "")@(c.IsActive ? "" : " · inactivo")
                                                </div>
                                            </div>
                                            <div style="display:flex;gap:4px;">
                                                @if (_canEdit && c.Kind == ConnectorKind.RestApi && c.IsActive)
                                                {
                                                    <button class="btn btn-sm btn-primary" @onclick="() => OpenApiImport(c)" disabled="@_busy" title="Traer datos del API a una tabla">Importar</button>
                                                }
                                                @if (_canEdit)
                                                {
                                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditConnector(c)" disabled="@_busy">Editar</button>
                                                }
                                                @if (_canDelete)
                                                {
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteConnectorAsync(c.Id)" disabled="@_busy">&times;</button>
                                                }
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                            @if (_canEdit)
                            {
                                <div class="dc-mini-form">
                                    <div class="dc-section-sub">@(_conEditId is null ? "Nuevo conector" : "Editar conector")</div>
                                    <input class="form-control" placeholder="Nombre" @bind="_conName" />
                                    <select class="form-control" @bind="_conKind">
                                        <option value="@ConnectorKind.Excel">Excel</option>
                                        <option value="@ConnectorKind.RestApi">API REST</option>
                                        <option value="@ConnectorKind.Database">Base de datos</option>
                                    </select>

                                    @if (_conKind == ConnectorKind.RestApi)
                                    {
                                        <input class="form-control" placeholder="Endpoint URL" @bind="_conEndpoint" />
                                        <div style="display:flex;gap:6px;">
                                            <input class="form-control" placeholder="Metodo (GET)" @bind="_conMethod" style="max-width:110px;" />
                                            <select class="form-control" @bind="_conAuth">
                                                <option value="@ConnectorAuthKind.None">Sin auth</option>
                                                <option value="@ConnectorAuthKind.ApiKey">API Key</option>
                                                <option value="@ConnectorAuthKind.Bearer">Bearer</option>
                                                <option value="@ConnectorAuthKind.Basic">Basic</option>
                                            </select>
                                        </div>
                                        <input class="form-control" type="password" placeholder="@(_conEditId is null ? "Credenciales" : "Credenciales (vacio = conservar)")" @bind="_conCreds" />
                                        <textarea class="form-control" rows="2" placeholder="Mapeo JSON (opcional)" @bind="_conMapping"></textarea>
                                    }
                                    else if (_conKind == ConnectorKind.Database)
                                    {
                                        <select class="form-control" @bind="_conEngine">
                                            <option value="">Motor...</option>
                                            @foreach (var e in Enum.GetValues<DbEngine>())
                                            {
                                                <option value="@e">@e</option>
                                            }
                                        </select>
                                        <div style="display:flex;gap:6px;">
                                            <input class="form-control" placeholder="Host" @bind="_conHost" />
                                            <input class="form-control" placeholder="Puerto" @bind="_conPort" style="max-width:100px;" />
                                        </div>
                                        <input class="form-control" placeholder="Base de datos" @bind="_conDatabase" />
                                        <input class="form-control" placeholder="Usuario" @bind="_conUser" />
                                        <input class="form-control" type="password" placeholder="@(_conEditId is null ? "Credenciales" : "Credenciales (vacio = conservar)")" @bind="_conCreds" />
                                    }

                                    <label class="dc-req"><input type="checkbox" @bind="_conActive" /> Activo</label>
                                    @if (_conError is not null)
                                    {
                                        <div class="tk-field-error">@_conError</div>
                                    }
                                    <div style="display:flex;gap:6px;">
                                        <button class="btn btn-sm btn-primary" @onclick="SaveConnectorAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_conName))">@(_conEditId is null ? "+ Agregar" : "Guardar")</button>
                                        @if (_conEditId is not null)
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="ResetConnectorForm">Cancelar</button>
                                        }
                                    </div>
                                </div>
                            }

                            @* ----- Destino ----- *@
                            <div class="dc-section-title" style="margin-top:14px;">Destino</div>
                            <div class="dc-mini-form">
                                <select class="form-control" @bind="_destKind">
                                    <option value="@DestinationKind.System">Sistema (tablas del contenedor)</option>
                                    <option value="@DestinationKind.AlliedDatabase">Base de datos aliada</option>
                                </select>
                                @if (_destKind == DestinationKind.AlliedDatabase)
                                {
                                    <select class="form-control" @bind="_destEngine">
                                        <option value="">Motor...</option>
                                        @foreach (var e in Enum.GetValues<DbEngine>())
                                        {
                                            <option value="@e">@e</option>
                                        }
                                    </select>
                                    <div style="display:flex;gap:6px;">
                                        <input class="form-control" placeholder="Host" @bind="_destHost" />
                                        <input class="form-control" placeholder="Puerto" @bind="_destPort" style="max-width:100px;" />
                                    </div>
                                    <input class="form-control" placeholder="Base de datos" @bind="_destDatabase" />
                                    <input class="form-control" placeholder="Usuario" @bind="_destUser" />
                                    <input class="form-control" type="password" placeholder="@(_destHasCreds ? "Credenciales (vacio = conservar)" : "Credenciales")" @bind="_destCreds" />
                                }
                                @if (_destError is not null)
                                {
                                    <div class="tk-field-error">@_destError</div>
                                }
                                @if (_canEdit)
                                {
                                    <button class="btn btn-sm btn-primary" @onclick="SaveDestinationAsync" disabled="@_busy">Guardar destino</button>
                                }
                            </div>

                            @* ----- Clientes ----- *@
                            <div class="dc-section-title" style="margin-top:14px;">Clientes remotos</div>
                            @if (_revealedSecret is not null)
                            {
                                <div class="dc-secret">
                                    <div style="font-size:12px;font-weight:700;">Guarda este secreto ahora (no se vuelve a mostrar):</div>
                                    <div class="dc-secret-row"><code>ClientId: @_revealedSecret.ClientId</code></div>
                                    <div class="dc-secret-row">
                                        <code>Secret: @_revealedSecret.ClientSecret</code>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => CopyAsync(_revealedSecret!.ClientSecret)">Copiar</button>
                                    </div>
                                </div>
                            }
                            @if (_clients.Count > 0)
                            {
                                <ul class="dc-mini-list">
                                    @foreach (var c in _clients)
                                    {
                                        <li>
                                            <div>
                                                <strong>@c.Name</strong> @(c.IsActive ? "" : "(inactivo)")
                                                <div class="text-muted" style="font-size:11px;">@c.ClientId @(c.HasSecret ? "· con secreto" : "")</div>
                                            </div>
                                            <div style="display:flex;gap:4px;">
                                                @if (_canEdit)
                                                {
                                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => RotateSecretAsync(c.Id)" disabled="@_busy">Rotar</button>
                                                }
                                                @if (_canDelete)
                                                {
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteClientAsync(c.Id)" disabled="@_busy">&times;</button>
                                                }
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                            @if (_canCreate)
                            {
                                <div class="dc-mini-form">
                                    <div class="dc-section-sub">Nuevo cliente</div>
                                    <input class="form-control" placeholder="Nombre" @bind="_clName" />
                                    <input class="form-control" placeholder="Descripcion (opcional)" @bind="_clDescription" />
                                    <label class="dc-req"><input type="checkbox" @bind="_clActive" /> Activo</label>
                                    @if (_clError is not null)
                                    {
                                        <div class="tk-field-error">@_clError</div>
                                    }
                                    <button class="btn btn-sm btn-primary" @onclick="CreateClientAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_clName))">+ Crear cliente</button>
                                </div>
                            }

                            @* ----- Procesos ----- *@
                            <div class="dc-section-title" style="margin-top:14px;">Procesos (horarios)</div>
                            @if (_processes.Count > 0)
                            {
                                <ul class="dc-mini-list">
                                    @foreach (var p in _processes)
                                    {
                                        <li>
                                            <div>
                                                <strong>@p.Name</strong> <span class="dc-badge">@ScheduleLabel(p.ScheduleKind)</span>
                                                <div class="text-muted" style="font-size:11px;">
                                                    @(p.ConnectorName ?? "sin conector")@(p.ClientName is not null ? " · " + p.ClientName : "")
                                                    @(p.ScheduleKind == ImportScheduleKind.Interval && p.IntervalMinutes is int m ? $" · cada {m} min" : "")
                                                    @(p.ScheduleKind == ImportScheduleKind.Cron && !string.IsNullOrWhiteSpace(p.CronExpression) ? $" · {p.CronExpression}" : "")
                                                    @(p.IsActive ? "" : " · inactivo")
                                                </div>
                                            </div>
                                            <div style="display:flex;gap:4px;">
                                                @if (_canEdit)
                                                {
                                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditProcess(p)" disabled="@_busy">Editar</button>
                                                }
                                                @if (_canDelete)
                                                {
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteProcessAsync(p.Id)" disabled="@_busy">&times;</button>
                                                }
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                            @if (_canEdit)
                            {
                                <div class="dc-mini-form">
                                    <div class="dc-section-sub">@(_procEditId is null ? "Nuevo proceso" : "Editar proceso")</div>
                                    <input class="form-control" placeholder="Nombre" @bind="_procName" />
                                    <select class="form-control" @bind="_procConnector">
                                        <option value="">(Sin conector)</option>
                                        @foreach (var c in _connectors)
                                        {
                                            <option value="@c.Id">@c.Name</option>
                                        }
                                    </select>
                                    <select class="form-control" @bind="_procClient">
                                        <option value="">(Sin cliente)</option>
                                        @foreach (var c in _clients)
                                        {
                                            <option value="@c.Id">@c.Name</option>
                                        }
                                    </select>
                                    <select class="form-control" @bind="_procSchedule">
                                        <option value="@ImportScheduleKind.Manual">Manual</option>
                                        <option value="@ImportScheduleKind.Interval">Intervalo</option>
                                        <option value="@ImportScheduleKind.Cron">Cron</option>
                                    </select>
                                    @if (_procSchedule == ImportScheduleKind.Interval)
                                    {
                                        <input class="form-control" type="number" min="1" placeholder="Minutos" @bind="_procIntervalText" />
                                    }
                                    else if (_procSchedule == ImportScheduleKind.Cron)
                                    {
                                        <input class="form-control" placeholder="Expresion cron (ej. 0 * * * *)" @bind="_procCron" />
                                    }
                                    <label class="dc-req"><input type="checkbox" @bind="_procActive" /> Activo</label>
                                    @if (_procError is not null)
                                    {
                                        <div class="tk-field-error">@_procError</div>
                                    }
                                    <div style="display:flex;gap:6px;">
                                        <button class="btn btn-sm btn-primary" @onclick="SaveProcessAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_procName))">@(_procEditId is null ? "+ Agregar" : "Guardar")</button>
                                        @if (_procEditId is not null)
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="ResetProcessForm">Cancelar</button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="CloseModal" disabled="@_busy">Cerrar</button>
            </div>
        </div>
    </div>
}

@* ===== Sub-modal: editor de una tabla (campos) ===== *@
@if (_tblOpen)
{
    <div class="modal-overlay" style="z-index:1060;">
        <div class="modal-dialog" style="max-width:640px;" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>@(_tblId is null ? "Nueva tabla" : "Editar tabla")</h3>
                <button class="modal-close" @onclick="() => _tblOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Nombre de la tabla</label>
                    <input class="form-control" @bind="_tblName" maxlength="120" placeholder="Ej. Facturas" />
                </div>
                <div class="field">
                    <label class="form-label">Descripcion (opcional)</label>
                    <input class="form-control" @bind="_tblDescription" maxlength="400" />
                </div>
                <div class="field">
                    <label class="form-label">Campos</label>
                    <div class="dc-cols">
                        @for (var i = 0; i < _tblColumns.Count; i++)
                        {
                            var idx = i;
                            var item = _tblColumns[idx];
                            <div class="dc-col-row">
                                <input class="form-control" placeholder="Nombre" @bind="item.Name" />
                                <select class="form-control" @bind="item.Type">
                                    <option value="@DataContainerColumnType.Text">Texto</option>
                                    <option value="@DataContainerColumnType.Number">Numero</option>
                                    <option value="@DataContainerColumnType.Decimal">Decimal</option>
                                    <option value="@DataContainerColumnType.Date">Fecha</option>
                                    <option value="@DataContainerColumnType.Boolean">Booleano</option>
                                    <option value="@DataContainerColumnType.Submodel">Submodelo</option>
                                </select>
                                <label class="dc-req"><input type="checkbox" @bind="item.IsRequired" /> Oblig.</label>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveColumn(idx)" title="Quitar campo">&times;</button>
                            </div>
                        }
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="AddColumn" style="margin-top:6px;">+ Agregar campo</button>
                </div>
                @if (_tblError is not null)
                {
                    <div class="tk-field-error">@_tblError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _tblOpen = false" disabled="@_busy">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveTableAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_tblName))">@(_busy ? "Guardando..." : "Guardar tabla")</button>
            </div>
        </div>
    </div>
}

@* ===== Sub-modal: DATOS de una tabla. La grilla y el editor de filas viven en el componente
     compartido DataRecordsGrid: aqui solo se pone el marco del modal. El mismo componente lo
     reusara el modulo publicado (la tabla colgada del menu), asi no hay dos editores. ===== *@
@if (_dataOpen && _dataTable is not null)
{
    <div class="modal-overlay" style="z-index:1070;">
        <div class="modal-dialog dc-data-dialog" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>Datos &#183; @_dataTable.Name</h3>
                <button class="modal-close" @onclick="() => _dataOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <DataRecordsGrid @ref="_recordsGrid"
                                 ContainerId="@_dataTable.Id"
                                 ActorUserId="@_actor"
                                 CanCreate="@_canEdit"
                                 CanEdit="@_canEdit"
                                 CanDelete="@_canDelete"
                                 EmptyText="Sin filas. Importa un Excel o usa &quot;+ Fila&quot;." />
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _dataOpen = false" disabled="@_busy">Cerrar</button>
            </div>
        </div>
    </div>
}

@* ===== Sub-modal: Importar desde API REST (descubrir campos + mapeo + importar) ===== *@
@if (_apiOpen && _apiConnector is not null)
{
    <div class="modal-overlay" style="z-index:1075;">
        <div class="modal-dialog dc-data-dialog" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>Importar desde API &#183; @_apiConnector.Name</h3>
                <button class="modal-close" @onclick="() => _apiOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="text-muted" style="font-size:12px;margin-bottom:8px;word-break:break-all;">
                    @(string.IsNullOrWhiteSpace(_apiConnector.HttpMethod) ? "GET" : _apiConnector.HttpMethod!.ToUpperInvariant()) @_apiConnector.EndpointUrl
                </div>
                <div style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;margin-bottom:8px;">
                    <div class="field" style="flex:1;min-width:180px;margin:0;">
                        <label class="form-label">Ruta del arreglo (opcional)</label>
                        <input class="form-control" @bind="_apiArrayPath" placeholder="vacio = auto (ej. data)" />
                    </div>
                    <button class="btn btn-outline-secondary" @onclick="ProbeApiAsync" disabled="@_busy">@(_busy ? "..." : "Descubrir campos")</button>
                </div>
                @if (_apiFlash is not null) { <div class="dc-flash-ok">@_apiFlash</div> }
                @if (_apiError is not null) { <div class="tk-field-error">@_apiError</div> }

                @if (_apiProbed)
                {
                    <div class="dc-section-title">Campos detectados (@_apiFields.Count) &#183; @_apiCount registros en el API</div>
                    <div style="display:flex;gap:16px;flex-wrap:wrap;">
                        <div style="flex:1;min-width:300px;">
                            <div class="field">
                                <label class="form-label">Tabla destino</label>
                                <select class="form-control" value="@(_apiTargetTableId?.ToString() ?? "")" @onchange="OnApiTargetChanged">
                                    <option value="">(elige tabla)</option>
                                    @foreach (var t in (_detail?.Tables ?? Enumerable.Empty<ModelTableDto>()))
                                    {
                                        <option value="@t.Id">@t.Name</option>
                                    }
                                </select>
                            </div>
                            @if (_apiTargetTableId is not null)
                            {
                                <div class="dc-section-title" style="margin-top:8px;">Mapeo: columna &#8592; campo del API</div>
                                @if (!ApiTargetColumns().Any())
                                {
                                    <div class="text-muted" style="font-size:12px;">La tabla destino no tiene columnas escalares. Agrega campos (Texto/Numero/...) a la tabla.</div>
                                }
                                @foreach (var col in ApiTargetColumns())
                                {
                                    <div class="dc-map-row">
                                        <span class="dc-map-col">@col.Name <span class="dc-th-type">@TypeShort(col.Type)</span></span>
                                        <select class="form-control" value="@GetMap(col.Id)" @onchange="e => SetMap(col.Id, e.Value?.ToString())">
                                            <option value="">(no importar)</option>
                                            @foreach (var f in _apiFields)
                                            {
                                                <option value="@f">@f</option>
                                            }
                                        </select>
                                    </div>
                                }
                                <div class="dc-section-title" style="margin-top:10px;">Modo de importacion (re-cargas)</div>
                                <div class="dc-map-row"><span class="dc-map-col">Al re-importar</span>
                                    <select class="form-control" @bind="_apiImportMode">
                                        <option value="@ApiImportMode.Append">Agregar (puede duplicar)</option>
                                        <option value="@ApiImportMode.Replace">Reemplazar (vaciar tabla antes)</option>
                                        <option value="@ApiImportMode.Upsert">Upsert (actualizar por clave)</option>
                                    </select>
                                </div>
                                @if (_apiImportMode == ApiImportMode.Upsert)
                                {
                                    <div class="dc-map-row"><span class="dc-map-col">Columna clave</span>
                                        <select class="form-control" value="@(_apiKeyColumnId?.ToString() ?? "")" @onchange="e => _apiKeyColumnId = Guid.TryParse(e.Value?.ToString(), out var g) ? g : (Guid?)null">
                                            <option value="">(elige columna clave)</option>
                                            @foreach (var col in ApiTargetColumns())
                                            {
                                                <option value="@col.Id">@col.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="text-muted" style="font-size:11px;">La clave debe estar mapeada a un campo (ej. id). Si el valor ya existe, la fila se actualiza; si no, se inserta.</div>
                                }

                                <div class="dc-section-title" style="margin-top:10px;">Paginacion</div>
                                <label class="dc-req"><input type="checkbox" @bind="_apiPageAll" /> Traer TODAS las paginas (recorre el API pagina por pagina)</label>
                                @if (_apiPageAll)
                                {
                                    <div class="dc-map-row"><span class="dc-map-col">Estilo</span>
                                        <select class="form-control" @bind="_apiPagingMode">
                                            <option value="@PagingMode.Offset">Desplazamiento (start/limit)</option>
                                            <option value="@PagingMode.Page">Numero de pagina (page)</option>
                                        </select>
                                    </div>
                                    @if (_apiPagingMode == PagingMode.Offset)
                                    {
                                        <div class="dc-map-row"><span class="dc-map-col">Parametro desplazamiento</span><input class="form-control" @bind="_apiOffsetParam" /></div>
                                    }
                                    else
                                    {
                                        <div class="dc-map-row"><span class="dc-map-col">Parametro pagina</span><input class="form-control" @bind="_apiPageParam" /></div>
                                        <div class="dc-map-row"><span class="dc-map-col">Pagina inicial</span><input class="form-control" type="number" @bind="_apiStartValue" /></div>
                                    }
                                    <div class="dc-map-row"><span class="dc-map-col">Parametro limite</span><input class="form-control" @bind="_apiLimitParam" /></div>
                                    <div class="dc-map-row"><span class="dc-map-col">Tamano de pagina</span><input class="form-control" type="number" @bind="_apiPageSize" /></div>
                                    <div class="dc-map-row"><span class="dc-map-col">Max paginas (tope)</span><input class="form-control" type="number" @bind="_apiMaxPages" /></div>
                                }
                                <button class="btn btn-primary" style="margin-top:10px;" @onclick="ImportApiAsync" disabled="@(_busy || _apiMap.Count == 0)">@(_busy ? "Importando..." : (_apiPageAll ? "Importar TODAS las paginas ahora" : $"Importar {_apiCount} registros ahora"))</button>
                            }
                        </div>
                        <div style="flex:1;min-width:280px;">
                            <div class="dc-section-title">Muestra (primer registro)</div>
                            <pre class="dc-api-sample">@_apiSample</pre>
                        </div>
                    </div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _apiOpen = false" disabled="@_busy">Cerrar</button>
            </div>
        </div>
    </div>
}

<style>
    .dc-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; }
    .dc-card { padding: 16px 18px; display: flex; flex-direction: column; gap: 8px; min-height: 150px; border: 1px solid var(--line, var(--border)); border-radius: 12px; background: var(--surface, var(--card)); }
