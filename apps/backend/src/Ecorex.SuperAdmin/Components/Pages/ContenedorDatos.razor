    private string CellDisplay(DataContainerRowDto row, DataContainerColumnDto col)
    {
        if (col.Type == DataContainerColumnType.RelationMany)
        {
            var ids = row.LinksByColumnId is not null && row.LinksByColumnId.TryGetValue(col.Id, out var l)
                ? l : (IReadOnlyList<Guid>)Array.Empty<Guid>();
            if (ids.Count == 0) { return "<span class=\"dc-cell-empty\">-</span>"; }
            var opts = RefOptions(col.Id);
            var labels = ids.Select(id => opts.FirstOrDefault(o => o.Id == id)?.Label ?? id.ToString()[..8]);
            return string.Join(" ", labels.Select(x => $"<span class=\"dc-chip\">{System.Net.WebUtility.HtmlEncode(x)}</span>"));
        }
        var raw = row.ValuesByColumnId.TryGetValue(col.Id, out var v) ? v : null;
        if (string.IsNullOrWhiteSpace(raw)) { return "<span class=\"dc-cell-empty\">-</span>"; }
        if (col.Type == DataContainerColumnType.Reference)
        {
            var opts = RefOptions(col.Id);
            var label = Guid.TryParse(raw, out var gid) ? (opts.FirstOrDefault(o => o.Id == gid)?.Label ?? raw) : raw;
            return $"<span class=\"dc-chip dc-chip-ref\">{System.Net.WebUtility.HtmlEncode(label)}</span>";
        }
        if (col.Type == DataContainerColumnType.Boolean) { return raw == "true" ? "Si" : "No"; }
        return System.Net.WebUtility.HtmlEncode(raw);
    }

