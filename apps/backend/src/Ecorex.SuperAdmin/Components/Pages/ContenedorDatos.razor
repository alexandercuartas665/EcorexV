    private static string Px(double v) => v.ToString("0.##", CultureInfo.InvariantCulture);
    private static string F(double v) => v.ToString("0.##", CultureInfo.InvariantCulture);

    private static string Truncate(string s, int max)
    {
        if (string.IsNullOrWhiteSpace(s)) { return ""; }
        s = s.Trim();
        return s.Length <= max ? s : s[..max] + "...";
    }

    private static string TypeShort(DataContainerColumnType t) => t switch
    {
        DataContainerColumnType.Text => "texto",
        DataContainerColumnType.Number => "num",
        DataContainerColumnType.Decimal => "dec",
        DataContainerColumnType.Date => "fecha",
        DataContainerColumnType.Boolean => "bool",
        DataContainerColumnType.Submodel => "submodelo",
        DataContainerColumnType.Reference => "N:1",
        DataContainerColumnType.RelationMany => "N:N",
        _ => t.ToString()
    };

    private static string ConnectorKindLabel(ConnectorKind k) => k switch
    {
        ConnectorKind.Excel => "Excel",
        ConnectorKind.RestApi => "API REST",
        ConnectorKind.Database => "Base de datos",
        _ => k.ToString()
    };

    private static string ConnectorSummary(DataConnectorDto c) => c.Kind switch
    {
        ConnectorKind.Excel => "archivo Excel",
        ConnectorKind.RestApi => string.IsNullOrWhiteSpace(c.EndpointUrl) ? "(sin endpoint)" : c.EndpointUrl!,
        ConnectorKind.Database => $"{c.DbEngine?.ToString() ?? "BD"} {c.Host}{(c.Port is int p ? ":" + p : "")}",
        _ => ""
    };

    private static string ScheduleLabel(ImportScheduleKind k) => k switch
    {
        ImportScheduleKind.Manual => "Manual",
        ImportScheduleKind.Interval => "Intervalo",
        ImportScheduleKind.Cron => "Cron",
        _ => k.ToString()
    };
}
