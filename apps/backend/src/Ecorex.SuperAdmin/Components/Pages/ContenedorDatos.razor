    // ---------- Lienzo: posiciones + aristas ----------
    private double GetX(Guid tableId) => _pos.TryGetValue(tableId, out var p) ? p.X : 40;
    private double GetY(Guid tableId) => _pos.TryGetValue(tableId, out var p) ? p.Y : 40;

    private const double NodeW = 220;

    private double NodeH(Guid tableId)
    {
        var t = _detail?.Tables.FirstOrDefault(x => x.Id == tableId);
        var cols = t?.Columns.Count ?? 0;
        return 40 + Math.Max(1, cols) * 22;
    }

    private bool TryEdge(ModelRelationDto rel, out double x1, out double y1, out double x2, out double y2)
    {
        x1 = y1 = x2 = y2 = 0;
        if (_detail is null) { return false; }
        var from = _detail.Tables.FirstOrDefault(t => t.Id == rel.FromTableId);
        var to = _detail.Tables.FirstOrDefault(t => t.Id == rel.ToTableId);
        if (from is null || to is null) { return false; }
        x1 = GetX(rel.FromTableId) + NodeW / 2;
        y1 = GetY(rel.FromTableId) + NodeH(rel.FromTableId) / 2;
        x2 = GetX(rel.ToTableId) + NodeW / 2;
        y2 = GetY(rel.ToTableId) + NodeH(rel.ToTableId) / 2;
        return true;
    }

    [JSInvokable]
    public async Task OnTableMoved(string tableId, double x, double y)
    {
        if (!Guid.TryParse(tableId, out var tid)) { return; }
        _pos[tid] = (x, y);
        await GuardAsync(async () =>
        {
            try { await ModelSvc.UpdateTablePositionAsync(new UpdateTablePositionRequest(tid, x, y)); }
            catch (Exception ex) { _pageError = ex.Message; }
        });
        StateHasChanged();
    }

