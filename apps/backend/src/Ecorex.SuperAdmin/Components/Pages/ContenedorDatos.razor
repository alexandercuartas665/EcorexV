    // Serializa el acceso a la BD del circuito (evita "A second operation was started on this context").
    private readonly SemaphoreSlim _dbGate = new(1, 1);

    private sealed class ColumnDraft
    {
        public Guid? Id { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public DataContainerColumnType Type { get; set; } = DataContainerColumnType.Text;
        public bool IsRequired { get; set; }
        public Guid? ChildContainerId { get; set; }
    }

    private async Task GuardAsync(Func<Task> op)
    {
        await _dbGate.WaitAsync();
        try { await op(); }
        finally { _dbGate.Release(); }
    }

    public void Dispose()
    {
        _selfRef?.Dispose();
        _dbGate.Dispose();
    }

    protected override async Task OnInitializedAsync()
    {
        var eff = await Perms.GetAsync();
        _canCreate = eff.Can(ModuleKey, PermissionAction.Create);
        _canEdit = eff.Can(ModuleKey, PermissionAction.Edit);
        _canDelete = eff.Can(ModuleKey, PermissionAction.Delete);

        var state = await AuthProvider.GetAuthenticationStateAsync();
        _actor = Guid.TryParse(state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;

        _models = (await ModelSvc.ListAsync()).ToList();
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
        }
        if (_modalOpen && _detail is not null && _selfRef is not null && !_canvasInit)
        {
            _canvasInit = true;
            try { await JS.InvokeVoidAsync("ecorexDcCanvas.init", _selfRef); }
            catch { /* JS no disponible: el arrastre no funcionara, pero la pagina sigue */ }
        }
    }

