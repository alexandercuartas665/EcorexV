    private void OpenApiImport(DataConnectorDto c)
    {
        _apiConnector = c;
        _apiFields = Array.Empty<string>();
        _apiCount = 0;
        _apiSample = null;
        _apiArrayPath = "";
        _apiProbed = false;
        _apiTargetTableId = null;
        _apiMap.Clear();
        _apiError = null;
        _apiFlash = null;
        // Paginacion: por defecto activada con desplazamiento, tomando el limite del propio endpoint si existe.
        _apiPageAll = true;
        _apiPagingMode = PagingMode.Offset;
        _apiOffsetParam = "start";
        _apiPageParam = "page";
        _apiLimitParam = "limit";
        _apiPageSize = ReadLimitFromUrl(c.EndpointUrl) ?? 30;
        _apiStartValue = 1;
        _apiMaxPages = 100;
        _apiImportMode = ApiImportMode.Append;
        _apiKeyColumnId = null;
        _apiOpen = true;
    }

    private static int? ReadLimitFromUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url) || !Uri.TryCreate(url, UriKind.Absolute, out var uri)) { return null; }
        foreach (var part in uri.Query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var eq = part.IndexOf('=');
            if (eq <= 0) { continue; }
            var key = Uri.UnescapeDataString(part[..eq]);
            if (string.Equals(key, "limit", StringComparison.OrdinalIgnoreCase)
                && int.TryParse(Uri.UnescapeDataString(part[(eq + 1)..]), out var v) && v > 0)
            {
                return v;
            }
        }
        return null;
    }

    private Task ProbeApiAsync() => GuardAsync(async () =>
    {
        if (_apiConnector is null) { return; }
        _apiError = null; _apiFlash = null;
        _busy = true;
        try
        {
            var r = await ApiSvc.ProbeAsync(_apiConnector.Id, string.IsNullOrWhiteSpace(_apiArrayPath) ? null : _apiArrayPath.Trim());
            if (!r.Success) { _apiError = r.Error ?? "No se pudo leer el API."; _apiProbed = false; return; }
            _apiFields = r.Fields;
            _apiCount = r.Count;
            _apiSample = r.SamplePretty;
            if (string.IsNullOrWhiteSpace(_apiArrayPath) && !string.IsNullOrEmpty(r.DetectedArrayPath)) { _apiArrayPath = r.DetectedArrayPath!; }
            _apiProbed = true;
            _apiFlash = $"Se detectaron {_apiFields.Count} campos y {_apiCount} registros.";
            AutoMapIfPossible();
        }
        catch (Exception ex) { _apiError = ex.Message; }
        finally { _busy = false; }
    });

    private void OnApiTargetChanged(ChangeEventArgs e)
    {
        _apiTargetTableId = Guid.TryParse(e.Value?.ToString(), out var g) ? g : (Guid?)null;
        _apiMap.Clear();
        AutoMapIfPossible();
    }

    private IEnumerable<DataContainerColumnDto> ApiTargetColumns()
    {
        var t = _detail?.Tables.FirstOrDefault(x => x.Id == _apiTargetTableId);
        if (t is null) { return Enumerable.Empty<DataContainerColumnDto>(); }
        return t.Columns
            .Where(c => c.Type is DataContainerColumnType.Text or DataContainerColumnType.Number
                or DataContainerColumnType.Decimal or DataContainerColumnType.Date or DataContainerColumnType.Boolean)
            .OrderBy(c => c.SortOrder);
    }

    private void AutoMapIfPossible()
    {
        if (_apiTargetTableId is null || _apiFields.Count == 0) { return; }
        foreach (var col in ApiTargetColumns())
        {
            if (_apiMap.ContainsKey(col.Id)) { continue; }
            var match = _apiFields.FirstOrDefault(f => string.Equals(f, col.Name, StringComparison.OrdinalIgnoreCase));
            if (match is not null) { _apiMap[col.Id] = match; }
        }
    }

    private string GetMap(Guid colId) => _apiMap.TryGetValue(colId, out var v) ? v : "";
    private void SetMap(Guid colId, string? field)
    {
        if (string.IsNullOrWhiteSpace(field)) { _apiMap.Remove(colId); }
        else { _apiMap[colId] = field.Trim(); }
    }

    private Task ImportApiAsync() => GuardAsync(async () =>
    {
        if (_apiConnector is null || _apiTargetTableId is null) { _apiError = "Elige la tabla destino."; return; }
        if (_apiMap.Count == 0) { _apiError = "Mapea al menos una columna."; return; }
        if (_apiImportMode == ApiImportMode.Upsert && (_apiKeyColumnId is null || !_apiMap.ContainsKey(_apiKeyColumnId.Value)))
        {
            _apiError = "Para Upsert elige una columna clave que este mapeada a un campo.";
            return;
        }
        _apiError = null; _apiFlash = null;
        _busy = true;
        try
        {
            ApiPaging? paging = _apiPageAll
                ? new ApiPaging(
                    _apiPagingMode,
                    _apiPagingMode == PagingMode.Offset ? (string.IsNullOrWhiteSpace(_apiOffsetParam) ? "start" : _apiOffsetParam.Trim()) : null,
                    _apiPagingMode == PagingMode.Page ? (string.IsNullOrWhiteSpace(_apiPageParam) ? "page" : _apiPageParam.Trim()) : null,
                    string.IsNullOrWhiteSpace(_apiLimitParam) ? null : _apiLimitParam.Trim(),
                    Math.Max(1, _apiPageSize),
                    _apiPagingMode == PagingMode.Offset ? 0 : Math.Max(0, _apiStartValue),
                    Math.Max(1, _apiMaxPages))
                : null;
            var req = new ApiImportRequest(_apiConnector.Id, _apiTargetTableId.Value,
                new Dictionary<Guid, string>(_apiMap),
                string.IsNullOrWhiteSpace(_apiArrayPath) ? null : _apiArrayPath.Trim(),
                paging,
                _apiImportMode,
                _apiImportMode == ApiImportMode.Upsert ? _apiKeyColumnId : null);
            var res = await ApiSvc.ImportAsync(req, _actor);
            if (res.Success)
            {
                var parts = new List<string>();
                if (res.Deleted > 0) { parts.Add($"{res.Deleted} borradas"); }
                if (res.Inserted > 0) { parts.Add($"{res.Inserted} insertadas"); }
                if (res.Updated > 0) { parts.Add($"{res.Updated} actualizadas"); }
                if (res.Failed > 0) { parts.Add($"{res.Failed} con error"); }
                _apiFlash = parts.Count > 0 ? "Listo: " + string.Join(", ", parts) + "." : "Sin cambios.";
            }
            if (res.Errors.Count > 0) { _apiError = string.Join(" | ", res.Errors.Take(4)); }
            // Si el panel de datos de esa tabla esta abierto, refresca las filas visibles.
            if (_recordsGrid is not null && _dataTable is not null && _dataTable.Id == _apiTargetTableId)
            {
                await _recordsGrid.ReloadAsync();
            }
        }
        catch (Exception ex) { _apiError = ex.Message; }
        finally { _busy = false; }
    });

    // ---------- Helpers ----------
    private async Task CopyAsync(string text)
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", text); }
        catch { /* clipboard bloqueado: se ignora */ }
    }

    private static bool IsRelationType(DataContainerColumnType t)
        => t is DataContainerColumnType.Reference or DataContainerColumnType.RelationMany;

    private static DbEngine? ParseEngine(string s) => Enum.TryParse<DbEngine>(s, out var e) ? e : null;

    private static string? NullIfBlank(string? s) => string.IsNullOrWhiteSpace(s) ? null : s.Trim();

    private static string Px(double v) => v.ToString("0.##", CultureInfo.InvariantCulture);
    private static string F(double v) => v.ToString("0.##", CultureInfo.InvariantCulture);

    private static string Truncate(string s, int max)
    {
        if (string.IsNullOrWhiteSpace(s)) { return ""; }
        s = s.Trim();
        return s.Length <= max ? s : s[..max] + "...";
    }

    private static string TypeShort(DataContainerColumnType t) => t switch
    {
        DataContainerColumnType.Text => "texto",
        DataContainerColumnType.Number => "num",
        DataContainerColumnType.Decimal => "dec",
        DataContainerColumnType.Date => "fecha",
        DataContainerColumnType.Boolean => "bool",
        DataContainerColumnType.Submodel => "submodelo",
        DataContainerColumnType.Reference => "N:1",
        DataContainerColumnType.RelationMany => "N:N",
        _ => t.ToString()
    };

    private static string ConnectorKindLabel(ConnectorKind k) => k switch
    {
        ConnectorKind.Excel => "Excel",
        ConnectorKind.RestApi => "API REST",
        ConnectorKind.Database => "Base de datos",
        _ => k.ToString()
    };

    private static string ConnectorSummary(DataConnectorDto c) => c.Kind switch
    {
        ConnectorKind.Excel => "archivo Excel",
        ConnectorKind.RestApi => string.IsNullOrWhiteSpace(c.EndpointUrl) ? "(sin endpoint)" : c.EndpointUrl!,
        ConnectorKind.Database => $"{c.DbEngine?.ToString() ?? "BD"} {c.Host}{(c.Port is int p ? ":" + p : "")}",
        _ => ""
    };

    private static string ScheduleLabel(ImportScheduleKind k) => k switch
    {
        ImportScheduleKind.Manual => "Manual",
        ImportScheduleKind.Interval => "Intervalo",
        ImportScheduleKind.Cron => "Cron",
        _ => k.ToString()
    };
