@page "/cursos"
@attribute [Authorize(Policy = "TenantMember")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using Ecorex.Application.Tenancy
@inject ICourseService Courses

<PageTitle>Cursos - ECOREX.tareas</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
            </div>
            <span>Configuracion del salon</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Cursos</h1>
        <p class="page-sub" style="margin-bottom:0;">Cursos eventuales del salon: dia, cupo, valor e inscritos con su estado de pago.</p>
    </div>
    <div style="display:flex;align-items:flex-start;">
        <button class="btn btn-primary" @onclick="() => OpenForm(null)">+ Nuevo curso</button>
    </div>
</div>

<div style="display:flex;gap:8px;margin-bottom:16px;">
    <button class="btn btn-sm @(_view == "activos" ? "btn-primary" : "btn-outline-secondary")" @onclick='() => SetViewAsync("activos")'>Activos</button>
    <button class="btn btn-sm @(_view == "archivados" ? "btn-primary" : "btn-outline-secondary")" @onclick='() => SetViewAsync("archivados")'>Archivados</button>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else if (_courses.Count == 0)
{
    <div class="card" style="padding:24px;text-align:center;color:var(--muted-foreground);">
        @(_view == "archivados" ? "No hay cursos archivados." : "Aun no hay cursos. Crea el primero con \"+ Nuevo curso\".")
    </div>
}
else
{
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:16px;">
        @foreach (var c in _courses)
        {
            <div class="card" style="padding:16px;display:flex;flex-direction:column;gap:9px;">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;">
                    <div style="font-weight:800;font-size:15px;line-height:1.25;min-width:0;">@c.Name</div>
                    @if (c.IsArchived)
                    {
                        <span style="flex:none;font-size:11px;font-weight:700;padding:2px 9px;border-radius:999px;background:var(--muted);color:var(--muted-foreground);">Archivado</span>
                    }
                    else
                    {
                        <span style="flex:none;font-size:11px;font-weight:700;padding:2px 9px;border-radius:999px;@(c.SpotsLeft > 0 ? "background:#10b98122;color:#10b981;" : "background:#ef444422;color:#ef4444;")">@(c.SpotsLeft > 0 ? $"{c.SpotsLeft} libres" : "Sin cupo")</span>
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(c.Description))
                {
                    <div class="text-muted" style="font-size:12px;">@Trim(c.Description!, 110)</div>
                }
                <div style="display:flex;flex-wrap:wrap;gap:6px 16px;font-size:12.5px;">
                    <span><span class="text-muted">Fecha:</span> <strong>@c.Date.ToString("dd MMM yyyy")@(c.StartTime is { } t ? $" {t:HH\\:mm}" : "")</strong></span>
                    <span><span class="text-muted">Valor:</span> <strong>@(c.Price is decimal p ? "$" + p.ToString("N0") : "-")</strong></span>
                </div>
                <div style="display:flex;gap:8px;">
                    <div style="flex:1;text-align:center;background:var(--muted);border-radius:8px;padding:6px 4px;">
                        <div style="font-weight:800;font-size:15px;">@c.RegisteredCount/@c.Capacity</div>
                        <div class="text-muted" style="font-size:10.5px;text-transform:uppercase;letter-spacing:.04em;">Inscritos</div>
                    </div>
                    <div style="flex:1;text-align:center;background:var(--muted);border-radius:8px;padding:6px 4px;">
                        <div style="font-weight:800;font-size:15px;">@c.PaidCount</div>
                        <div class="text-muted" style="font-size:10.5px;text-transform:uppercase;letter-spacing:.04em;">Pagados</div>
                    </div>
                </div>
                <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:auto;padding-top:4px;">
                    <button class="btn btn-sm btn-primary" @onclick="() => OpenDetailAsync(c.Id)">Ver inscritos</button>
                    @if (!c.IsArchived)
                    {
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenForm(c)">Editar</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ArchiveAsync(c, true)" disabled="@_busy">Archivar</button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ArchiveAsync(c, false)" disabled="@_busy">Desarchivar</button>
                    }
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(c)" disabled="@_busy" title="Eliminar">&times;</button>
                </div>
            </div>
        }
    </div>
}

@* ===== Modal: crear / editar curso ===== *@
@if (_formOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog">
            <div class="modal-head">
                <h3>@(_editId is null ? "Nuevo curso" : "Editar curso")</h3>
                <button class="modal-close" @onclick="() => _formOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Nombre del curso *</label>
                    <input class="form-control" @bind="_cf.Name" autocomplete="off" />
                </div>
                <div class="field">
                    <label class="form-label">Detalle / que se da en el curso</label>
                    <RichTextArea @bind-Value="_cf.Description" Rows="3" Placeholder="Que aprende, requisitos, que incluye..." />
                </div>
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Dia del curso *</label>
                        <input class="form-control" type="date" @bind="_cf.Date" />
                    </div>
                    <div class="field">
                        <label class="form-label">Hora</label>
                        <input class="form-control" type="time" @bind="_cf.Time" />
                    </div>
                </div>
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Cupo (personas) *</label>
                        <input class="form-control" type="number" min="0" @bind="_cf.Capacity" />
                    </div>
                    <div class="field">
                        <label class="form-label">Valor</label>
                        <input class="form-control" type="number" min="0" step="any" @bind="_cf.Price" />
                    </div>
                </div>
                @if (_formError is not null)
                {
                    <div class="text-danger small">@_formError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _formOpen = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveCourseAsync" disabled="@_busy">@(_editId is null ? "Crear curso" : "Guardar")</button>
            </div>
        </div>
    </div>
}

@* ===== Modal: detalle del curso + inscritos ===== *@
@if (_detailOpen && _detail is not null)
{
    <div class="modal-overlay">
        <div class="modal-dialog">
            <div class="modal-head">
                <div style="min-width:0;">
                    <h3 style="margin:0;">@_detail.Course.Name</h3>
                    <div class="text-muted" style="font-size:12.5px;margin-top:3px;">
                        @_detail.Course.Date.ToString("dd MMM yyyy")@(_detail.Course.StartTime is { } t ? $" {t:HH\\:mm}" : "")
                        &middot; @(_detail.Course.Price is decimal p ? "$" + p.ToString("N0") : "sin valor")
                        &middot; @_detail.Course.RegisteredCount/@_detail.Course.Capacity inscritos (@_detail.Course.SpotsLeft libres)
                    </div>
                </div>
                <button class="modal-close" @onclick="() => _detailOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrWhiteSpace(_detail.Course.Description))
                {
                    <div class="text-muted" style="font-size:12.5px;margin-bottom:12px;">@_detail.Course.Description</div>
                }
                <div class="pl-stagegroup-title" style="margin-bottom:8px;">Personas registradas</div>
                @if (_detail.Registrations.Count == 0)
                {
                    <div class="text-muted small" style="margin-bottom:12px;">Aun no hay inscritos.</div>
                }
                else
                {
                    <div style="border:1px solid var(--border);border-radius:8px;margin-bottom:14px;overflow:hidden;">
                        @foreach (var r in _detail.Registrations)
                        {
                            <div style="display:flex;align-items:center;gap:10px;padding:8px 10px;border-bottom:1px solid var(--border);">
                                <div style="flex:1;min-width:0;">
                                    <div style="font-weight:600;">@r.PersonName</div>
                                    <div class="text-muted" style="font-size:11.5px;">@(string.IsNullOrWhiteSpace(r.Phone) ? "Sin telefono" : r.Phone)</div>
                                </div>
                                <span style="font-size:11px;font-weight:700;padding:2px 9px;border-radius:999px;@(r.IsPaid ? "background:#10b98122;color:#10b981;" : "background:#f59e0b22;color:#b45309;")">@(r.IsPaid ? "Pagado" : "Pendiente")</span>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => TogglePaidAsync(r)" disabled="@_busy">@(r.IsPaid ? "Marcar pendiente" : "Marcar pagado")</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveRegAsync(r)" disabled="@_busy">&times;</button>
                            </div>
                        }
                    </div>
                }
                <div class="pl-stagegroup-title" style="margin-bottom:8px;">Inscribir manualmente</div>
                <div class="field-row">
                    <div class="field" style="flex:2 1 auto;">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" @bind="_regName" autocomplete="off" />
                    </div>
                    <div class="field">
                        <label class="form-label">Telefono</label>
                        <input class="form-control" @bind="_regPhone" autocomplete="off" />
                    </div>
                    <div class="field" style="flex:0 0 auto;align-self:flex-end;">
                        <button class="btn btn-primary" @onclick="AddRegAsync" disabled="@(_busy || _detail.Course.SpotsLeft <= 0)">Inscribir</button>
                    </div>
                </div>
                @if (_regError is not null)
                {
                    <div class="text-danger small">@_regError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _detailOpen = false">Cerrar</button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _busy;
    private string _view = "activos";
    private List<CourseDto> _courses = new();

    private bool _formOpen;
    private Guid? _editId;
    private string? _formError;
    private CourseForm _cf = new();

    private bool _detailOpen;
    private CourseDetailDto? _detail;
    private string? _regName;
    private string? _regPhone;
    private string? _regError;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
        _loading = false;
    }

    private async Task ReloadAsync() => _courses = (await Courses.ListAsync(archived: _view == "archivados")).ToList();

    private async Task SetViewAsync(string view)
    {
        _view = view;
        await ReloadAsync();
    }

    private async Task ArchiveAsync(CourseDto c, bool archived)
    {
        _busy = true;
        try { await Courses.SetArchivedAsync(c.Id, archived, await ActorAsync()); await ReloadAsync(); }
        finally { _busy = false; }
    }

    private void OpenForm(CourseDto? c)
    {
        _formError = null;
        if (c is null)
        {
            _editId = null;
            _cf = new CourseForm { Date = DateOnly.FromDateTime(DateTime.Today).AddDays(7), Time = new TimeOnly(10, 0), Capacity = 10 };
        }
        else
        {
            _editId = c.Id;
            _cf = new CourseForm { Name = c.Name, Description = c.Description, Date = c.Date, Time = c.StartTime ?? new TimeOnly(10, 0), Capacity = c.Capacity, Price = c.Price };
        }
        _formOpen = true;
    }

    private async Task SaveCourseAsync()
    {
        _formError = null;
        if (string.IsNullOrWhiteSpace(_cf.Name)) { _formError = "El nombre es obligatorio."; return; }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var req = new SaveCourseRequest(_cf.Name.Trim(), _cf.Description, _cf.Date, _cf.Time, _cf.Capacity, _cf.Price);
            if (_editId is Guid id) { await Courses.UpdateAsync(id, req, actor); }
            else { await Courses.CreateAsync(req, actor); }
            await ReloadAsync();
            _formOpen = false;
        }
        finally { _busy = false; }
    }

    private async Task DeleteAsync(CourseDto c)
    {
        _busy = true;
        try { await Courses.DeleteAsync(c.Id, await ActorAsync()); await ReloadAsync(); }
        finally { _busy = false; }
    }

    private async Task OpenDetailAsync(Guid id)
    {
        _regName = null; _regPhone = null; _regError = null;
        _detail = await Courses.GetAsync(id);
        _detailOpen = _detail is not null;
    }

    private async Task TogglePaidAsync(CourseRegistrationDto r)
    {
        _busy = true;
        try
        {
            await Courses.SetRegistrationPaidAsync(r.Id, !r.IsPaid, await ActorAsync());
            if (_detail is not null) { await OpenDetailAsync(_detail.Course.Id); }
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private async Task RemoveRegAsync(CourseRegistrationDto r)
    {
        _busy = true;
        try
        {
            await Courses.RemoveRegistrationAsync(r.Id, await ActorAsync());
            if (_detail is not null) { await OpenDetailAsync(_detail.Course.Id); }
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private async Task AddRegAsync()
    {
        _regError = null;
        if (_detail is null) { return; }
        if (string.IsNullOrWhiteSpace(_regName)) { _regError = "El nombre es obligatorio."; return; }
        _busy = true;
        try
        {
            var added = await Courses.AddRegistrationAsync(_detail.Course.Id, _regName!.Trim(), _regPhone, isPaid: false, await ActorAsync());
            if (added is null) { _regError = "No se pudo inscribir (curso lleno?)."; return; }
            _regName = null; _regPhone = null;
            await OpenDetailAsync(_detail.Course.Id);
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private static string Trim(string s, int n) => string.IsNullOrEmpty(s) ? "" : (s.Length <= n ? s : s[..n] + "...");

    private sealed class CourseForm
    {
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public DateOnly Date { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public TimeOnly Time { get; set; } = new(10, 0);
        public int Capacity { get; set; } = 10;
        public decimal? Price { get; set; }
    }
}
