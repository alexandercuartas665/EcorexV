@page "/extraccion-datos"
@attribute [Authorize(Policy = "ExtraccionDatos.Editar")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Text.Json
@using Ecorex.Application.Scraping
@using Ecorex.Domain.Enums
@inject IScrapeService ScrapeSvc

<PageTitle>Extraccion de datos - ECOREX.tareas</PageTitle>

<div class="xd-page">

    @* ===== Topbar del modulo (proto: breadcrumb + MOD 000730 + acciones) ===== *@
    <div class="xd-topbar">
        <nav class="xd-crumb" aria-label="Ruta de navegacion">
            <span>Home</span>
            <span class="sep">/</span>
            <span>Utilidades</span>
            <span class="sep">/</span>
            <span class="last">Extraccion de datos</span>
            <span class="xd-mod-code">MOD 000730</span>
        </nav>
        <div class="xd-top-actions">
            <button class="xd-btn xd-new-btn primary" @onclick="NewSource">+ Nueva fuente</button>
        </div>
    </div>

    @if (_flash is not null)
    {
        <div class="xd-flash @(_flashError ? "err" : "ok")" role="status">
            <span>@_flash</span>
            <button class="xd-flash-x" @onclick="() => _flash = null" title="Cerrar">x</button>
        </div>
    }

    <div class="xd-layout">

        @* ---- Sidebar (proto .side 300px sticky): lista de fuentes ---- *@
        <aside class="xd-side">
            <div class="xd-side-head">
                <div class="xd-side-title">Fuentes <span class="xd-side-count">@_sources.Count</span></div>
            </div>
            <div class="xd-side-search">
                <input placeholder="Buscar..." @bind="_search" @bind:event="oninput" />
            </div>
            <div class="xd-side-list">
                @if (FilteredSources.Count == 0)
                {
                    <div class="xd-empty">@(_sources.Count == 0 ? "Aun no hay fuentes. Crea la primera con + Nueva fuente." : "Sin resultados para la busqueda.")</div>
                }
                @foreach (var s in FilteredSources)
                {
                    <div class="xd-item @(_selected?.Id == s.Id && !_isNew ? "active" : "")" @onclick="() => SelectSourceAsync(s.Id)">
                        <div class="xd-item-icon">@Initial(s.Name)</div>
                        <div class="xd-item-body">
                            <div class="xd-item-name" title="@s.Name">@s.Name</div>
                            <div class="xd-item-meta">
                                <span class="xd-dot @DotClass(s)"></span>
                                @StatusLabel(s.Status) &middot; @KindLabel(s.Kind)
                            </div>
                        </div>
                    </div>
                }
            </div>
        </aside>

        @* ---- Panel principal ---- *@
        <div class="xd-main">

            @* Hero de la fuente seleccionada (proto .hero: gradiente + KPIs) *@
            <div class="xd-hero">
                <div class="xd-hero-head">
                    <div class="xd-hero-id">
                        <h1>
                            <span class="xd-hero-name">@(_isNew ? "Nueva fuente" : _selected?.Name ?? "Extraccion de datos")</span>
                            @if (!_isNew && _selected is not null)
                            {
                                <span class="xd-hero-badge">@KindLabel(_selected.Kind)</span>
                                <span class="xd-hero-badge">@StatusLabel(_selected.Status)</span>
                            }
                        </h1>
                        @if (!_isNew && _selected is not null)
                        {
                            <div class="xd-hero-url" title="@_selected.Url">@_selected.Url</div>
                        }
                        else
                        {
                            <div class="xd-hero-sub">Define nombre, URL y tipo en el panel de configuracion y guarda la fuente.</div>
                        }
                    </div>
                    @if (!_isNew && _selected is not null)
                    {
                        <div class="xd-hero-actions">
                            <button class="xd-btn xd-hero-btn xd-run" disabled="@_busy" @onclick="RunSelectedAsync">
                                @(_busy ? "Ejecutando..." : "Ejecutar ahora")
                            </button>
                        </div>
                    }
                </div>
                <div class="xd-kpis">
                    <div class="xd-kpi"><div class="lbl">Ejecuciones</div><div class="val">@(_selected?.RunCount ?? 0)</div></div>
                    <div class="xd-kpi"><div class="lbl">Exitosas 30d</div><div class="val">@SuccessRateLabel</div></div>
                    <div class="xd-kpi"><div class="lbl">Registros extraidos</div><div class="val">@((_selected?.TotalItems ?? 0).ToString("N0"))</div></div>
                    <div class="xd-kpi"><div class="lbl">Ultima corrida</div><div class="val">@RelativeShort(_selected?.LastRunAt)</div></div>
                </div>
            </div>

            @* Franja de alcance (proto .warning-strip): limites seguros del ejecutor (ADR-0025) *@
            <div class="xd-strip">
                <strong>Ejecutor acotado:</strong>&nbsp;solo GET a URLs publicas http(s) con guard anti-SSRF
                (rechaza IPs privadas, loopback y puertos no estandar), timeout de 15s y respuesta maxima de 2 MB.
                HTML se extrae por selector CSS y JSON se cuenta y previsualiza; no se ejecuta ningun script.
                Programacion automatica: pendiente (ADR-0025).
            </div>

            <div class="xd-cols">

                @* ---- Preview del resultado (tabla / arbol JSON) ---- *@
                <div class="xd-card">
                    <div class="xd-card-head">
                        <div class="xd-card-title">
                            Resultado de la ultima ejecucion
                            @if (_previewItemCount is int total)
                            {
                                <span class="xd-num-badge">@total items</span>
                            }
                        </div>
                        @if (_lastRun is not null)
                        {
                            <span class="xd-pill @(_lastRun.Status == ScrapeRunStatus.Success ? "ok" : "err")">
                                <span class="d"></span>@(_lastRun.Status == ScrapeRunStatus.Success ? "Exitosa" : "Fallida")
                            </span>
                        }
                    </div>

                    @if (_lastRun is null)
                    {
                        <div class="xd-card-empty">Sin ejecuciones todavia. Usa "Ejecutar ahora" para correr la fuente y ver el resultado aqui.</div>
                    }
                    else if (_lastRun.Status == ScrapeRunStatus.Failed)
                    {
                        <div class="xd-error-box">
                            <strong>La corrida fallo:</strong> @_lastRun.ErrorMessage
                        </div>
                    }
                    else if (_previewColumns.Count > 0)
                    {
                        <div class="xd-table-wrap">
                            <table class="xd-preview-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        @foreach (var c in _previewColumns)
                                        {
                                            <th>@c</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < _previewRows.Count; i++)
                                    {
                                        <tr>
                                            <td class="idx">@(i + 1)</td>
                                            @foreach (var cell in _previewRows[i])
                                            {
                                                <td title="@cell">@cell</td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if (_previewItemCount is int count && count > _previewRows.Count)
                        {
                            <div class="xd-more">Mostrando @_previewRows.Count de @count items (preview acotada).</div>
                        }
                        <div class="xd-code" aria-label="Resultado JSON crudo">@_previewRawJson</div>
                    }
                </div>

                @* ---- Configuracion de la fuente (proto .props-panel 380px) ---- *@
                <div class="xd-card xd-props">
                    <div class="xd-card-head">
                        <div class="xd-card-title">Configuracion de la fuente</div>
                    </div>
                    <div class="xd-props-body">
                        <div class="xd-prop">
                            <label for="xd-f-name">Nombre</label>
                            <input id="xd-f-name" @bind="_editName" placeholder="Precios competencia..." maxlength="200" />
                        </div>
                        <div class="xd-prop">
                            <label for="xd-f-url">URL (http/https)</label>
                            <input id="xd-f-url" class="mono" @bind="_editUrl" placeholder="https://ejemplo.com/productos" maxlength="1000" />
                        </div>
                        <div class="xd-prop">
                            <label for="xd-f-kind">Tipo de contenido</label>
                            <select id="xd-f-kind" @bind="_editKind">
                                <option value="@ScrapeSourceKind.Json">JSON (conteo + preview de items)</option>
                                <option value="@ScrapeSourceKind.Html">HTML (extraccion por selector CSS)</option>
                            </select>
                        </div>
                        <div class="xd-prop">
                            <label for="xd-f-selector">Selector CSS @(_editKind == ScrapeSourceKind.Html ? "(obligatorio)" : "(no aplica en JSON)")</label>
                            <input id="xd-f-selector" class="mono" @bind="_editSelector" disabled="@(_editKind != ScrapeSourceKind.Html)"
                                   placeholder="article.product-card h3" maxlength="300" />
                            <div class="xd-help">
                                Se extrae el TEXTO de cada nodo que casa con el selector.
                                Ejemplos: <code>h2.titulo</code>, <code>table#precios td.valor</code>, <code>.card &gt; .price</code>.
                            </div>
                        </div>
                        <div class="xd-prop">
                            <label for="xd-f-status">Estado</label>
                            <select id="xd-f-status" @bind="_editStatus">
                                <option value="@ScrapeSourceStatus.Active">Activa</option>
                                <option value="@ScrapeSourceStatus.Inactive">Inactiva</option>
                                @if (_editStatus == ScrapeSourceStatus.Error)
                                {
                                    <option value="@ScrapeSourceStatus.Error">Con errores (ultima corrida fallida)</option>
                                }
                            </select>
                        </div>
                        <div class="xd-props-actions">
                            <button class="xd-btn primary xd-save-btn" disabled="@_busy" @onclick="SaveAsync">
                                @(_isNew ? "Crear fuente" : "Guardar cambios")
                            </button>
                            @if (!_isNew && _selected is not null)
                            {
                                <button class="xd-btn xd-run" disabled="@_busy" @onclick="RunSelectedAsync">Probar / Ejecutar</button>
                                <button class="xd-btn danger xd-del-btn" disabled="@_busy" @onclick="DeleteAsync">Eliminar</button>
                            }
                        </div>
                    </div>
                </div>

            </div>

            @* ---- Historial de corridas (proto .exec-table, dot verde/rojo) ---- *@
            <div class="xd-card">
                <div class="xd-card-head">
                    <div class="xd-card-title">Seguimiento de ejecuciones <span class="xd-num-badge">ultimas @_runs.Count</span></div>
                </div>
                @if (_runs.Count == 0)
                {
                    <div class="xd-card-empty">El historial de esta fuente esta vacio.</div>
                }
                else
                {
                    <div class="xd-table-wrap">
                        <table class="xd-exec-table">
                            <thead>
                                <tr>
                                    <th>Ejecucion</th>
                                    <th>Cuando</th>
                                    <th>Duracion</th>
                                    <th>Registros</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in _runs)
                                {
                                    <tr>
                                        <td><code>#XD-@r.Id.ToString("N")[..6].ToUpperInvariant()</code></td>
                                        <td>@r.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@DurationLabel(r.DurationMs)</td>
                                        <td class="num">@r.ItemCount.ToString("N0")</td>
                                        <td>
                                            <span class="xd-pill @(r.Status == ScrapeRunStatus.Success ? "ok" : "err")"
                                                  title="@(r.ErrorMessage ?? "Corrida exitosa")">
                                                <span class="d"></span>@(r.Status == ScrapeRunStatus.Success ? "Exitoso" : "Fallido")
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

        </div>
    </div>
</div>

@code {
    private List<ScrapeSourceDto> _sources = [];
    private ScrapeSourceDto? _selected;
    private List<ScrapeRunDto> _runs = [];
    private ScrapeRunDto? _lastRun;

    private bool _isNew;
    private bool _busy;
    private string _search = "";
    private string? _flash;
    private bool _flashError;

    // Editor (panel derecho)
    private string _editName = "";
    private string _editUrl = "";
    private ScrapeSourceKind _editKind = ScrapeSourceKind.Json;
    private string? _editSelector;
    private ScrapeSourceStatus _editStatus = ScrapeSourceStatus.Active;

    // Preview parseada del ResultJson de la ultima corrida
    private int? _previewItemCount;
    private List<string> _previewColumns = [];
    private List<List<string?>> _previewRows = [];
    private string _previewRawJson = "";

    private IReadOnlyList<ScrapeSourceDto> FilteredSources =>
        string.IsNullOrWhiteSpace(_search)
            ? _sources
            : _sources.Where(s => s.Name.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase)).ToList();

    protected override async Task OnInitializedAsync()
    {
        await ReloadSourcesAsync(selectFirst: true);
    }

    private async Task ReloadSourcesAsync(bool selectFirst = false, Guid? keepSelected = null)
    {
        _sources = (await ScrapeSvc.ListSourcesAsync()).ToList();
        var target = keepSelected ?? _selected?.Id;
        if (target is Guid id && _sources.Any(s => s.Id == id))
        {
            await SelectSourceAsync(id);
        }
        else if (selectFirst && _sources.Count > 0)
        {
            await SelectSourceAsync(_sources[0].Id);
        }
        else if (_sources.Count == 0)
        {
            NewSource();
        }
    }

    private async Task SelectSourceAsync(Guid id)
    {
        _isNew = false;
        _selected = _sources.FirstOrDefault(s => s.Id == id) ?? await ScrapeSvc.GetSourceAsync(id);
        if (_selected is null)
        {
            return;
        }
        _editName = _selected.Name;
        _editUrl = _selected.Url;
        _editKind = _selected.Kind;
        _editSelector = _selected.Selector;
        _editStatus = _selected.Status;
        await ReloadRunsAsync();
    }

    private async Task ReloadRunsAsync()
    {
        _runs = _selected is null ? [] : (await ScrapeSvc.ListRunsAsync(_selected.Id)).ToList();
        _lastRun = _runs.FirstOrDefault();
        ParsePreview(_lastRun?.ResultJson);
    }

    private void NewSource()
    {
        _isNew = true;
        _selected = null;
        _runs = [];
        _lastRun = null;
        ParsePreview(null);
        _editName = "";
        _editUrl = "";
        _editKind = ScrapeSourceKind.Json;
        _editSelector = null;
        _editStatus = ScrapeSourceStatus.Active;
    }

    private async Task SaveAsync()
    {
        _busy = true;
        try
        {
            var result = await ScrapeSvc.SaveSourceAsync(new SaveScrapeSourceRequest(
                _isNew ? null : _selected?.Id, _editName, _editUrl, _editKind, _editSelector, _editStatus));
            if (!result.IsOk)
            {
                Flash(result.Error ?? "No se pudo guardar la fuente.", error: true);
                return;
            }
            Flash(_isNew ? $"Fuente \"{result.Value!.Name}\" creada." : "Fuente guardada.");
            _isNew = false;
            await ReloadSourcesAsync(keepSelected: result.Value!.Id);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RunSelectedAsync()
    {
        if (_selected is null)
        {
            return;
        }
        _busy = true;
        try
        {
            var result = await ScrapeSvc.RunAsync(_selected.Id);
            if (!result.IsOk)
            {
                Flash(result.Error ?? "No se pudo ejecutar la fuente.", error: true);
                return;
            }
            var run = result.Value!;
            if (run.Status == ScrapeRunStatus.Success)
            {
                Flash($"Corrida exitosa: {run.ItemCount} items en {run.DurationMs} ms.");
            }
            else
            {
                Flash($"Corrida fallida: {run.ErrorMessage}", error: true);
            }
            await ReloadSourcesAsync(keepSelected: _selected.Id);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (_selected is null)
        {
            return;
        }
        _busy = true;
        try
        {
            var result = await ScrapeSvc.DeleteSourceAsync(_selected.Id);
            if (!result.IsOk)
            {
                // Regla de negocio (ADR-0025, mismo criterio que reglas): con historial no se
                // borra; se ofrece desactivar para conservar la trazabilidad.
                Flash(result.Error ?? "No se pudo eliminar la fuente.", error: true);
                return;
            }
            Flash("Fuente eliminada.");
            _selected = null;
            await ReloadSourcesAsync(selectFirst: true);
        }
        finally
        {
            _busy = false;
        }
    }

    private void Flash(string message, bool error = false)
    {
        _flash = message;
        _flashError = error;
    }

    /// <summary>Parsea el documento ResultJson persistido ({itemCount, columns, rows}) para la tabla de preview.</summary>
    private void ParsePreview(string? resultJson)
    {
        _previewItemCount = null;
        _previewColumns = [];
        _previewRows = [];
        _previewRawJson = "";
        if (string.IsNullOrWhiteSpace(resultJson))
        {
            return;
        }
        try
        {
            using var doc = JsonDocument.Parse(resultJson);
            var root = doc.RootElement;
            _previewItemCount = root.TryGetProperty("itemCount", out var c) ? c.GetInt32() : null;
            if (root.TryGetProperty("columns", out var cols) && cols.ValueKind == JsonValueKind.Array)
            {
                _previewColumns = cols.EnumerateArray().Select(e => e.GetString() ?? "").ToList();
            }
            if (root.TryGetProperty("rows", out var rows) && rows.ValueKind == JsonValueKind.Array)
            {
                foreach (var row in rows.EnumerateArray())
                {
                    _previewRows.Add(row.EnumerateArray()
                        .Select(e => e.ValueKind == JsonValueKind.Null ? null : e.ToString())
                        .ToList());
                }
            }
            _previewRawJson = JsonSerializer.Serialize(root, new JsonSerializerOptions { WriteIndented = true });
        }
        catch (JsonException)
        {
            _previewRawJson = resultJson;
        }
    }

    private string SuccessRateLabel
    {
        get
        {
            if (_selected is null || _selected.RunCount30d == 0)
            {
                return "-";
            }
            return $"{100.0 * _selected.SuccessCount30d / _selected.RunCount30d:0.#}%";
        }
    }

    private static string Initial(string name) =>
        string.IsNullOrWhiteSpace(name) ? "?" : name.Trim()[..1].ToUpperInvariant();

    private static string KindLabel(ScrapeSourceKind kind) => kind == ScrapeSourceKind.Json ? "JSON" : "HTML";

    private static string StatusLabel(ScrapeSourceStatus status) => status switch
    {
        ScrapeSourceStatus.Active => "Activa",
        ScrapeSourceStatus.Inactive => "Inactiva",
        _ => "Con errores"
    };

    private static string DotClass(ScrapeSourceDto s) => s.Status switch
    {
        ScrapeSourceStatus.Error => "err",
        ScrapeSourceStatus.Inactive => "off",
        _ => "ok"
    };

    private static string DurationLabel(int ms) =>
        ms < 1000 ? $"{ms} ms" : $"{ms / 1000.0:0.0} s";

    private static string RelativeShort(DateTimeOffset? at)
    {
        if (at is not DateTimeOffset t)
        {
            return "-";
        }
        var delta = DateTimeOffset.UtcNow - t.ToUniversalTime();
        if (delta < TimeSpan.FromMinutes(1)) { return "ahora"; }
        if (delta < TimeSpan.FromHours(1)) { return $"{(int)delta.TotalMinutes}m"; }
        if (delta < TimeSpan.FromHours(48)) { return $"{(int)delta.TotalHours}h"; }
        return $"{(int)delta.TotalDays}d";
    }
}
