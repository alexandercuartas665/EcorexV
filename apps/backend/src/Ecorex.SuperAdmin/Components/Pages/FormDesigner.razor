    // ---- Publicar por URL ----

    private async void OpenTokenModal()
    {
        _modalError = null;
        _emittedUrl = null;
        _emittedExpiresAt = null;
        _tReference = "";
        _tHours = 24;
        _tSingleUse = false;
        _tAllowAnonymous = true;
        _tokens = (await TokensSvc.ListAsync(Id)).ToList();
        _showTokenModal = true;
        StateHasChanged();
    }

    private void CloseTokenModal()
    {
        // El token en claro desaparece al cerrar: no vuelve a mostrarse.
        _showTokenModal = false;
        _emittedUrl = null;
    }

    private async Task EmitTokenAsync()
    {
        _modalError = null;
        _busy = true;
        try
        {
            var result = await TokensSvc.EmitAsync(Id, new EmitFormTokenRequest(
                string.IsNullOrWhiteSpace(_tReference) ? null : _tReference.Trim(),
                _tHours, _tSingleUse, _tAllowAnonymous));
            if (!result.IsOk || result.Value is null) { _modalError = result.Error; return; }
            _emittedUrl = $"{Nav.BaseUri}f/{result.Value.Token}";
            _emittedExpiresAt = result.Value.ExpiresAt;
            _tokens = (await TokensSvc.ListAsync(Id)).ToList();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RevokeTokenAsync(Guid tokenId)
    {
        _busy = true;
        try
        {
            await TokensSvc.RevokeAsync(tokenId);
            _tokens = (await TokensSvc.ListAsync(Id)).ToList();
        }
        finally
        {
            _busy = false;
        }
    }

    private static string TokenStateLabel(FormTokenDto t)
        => t.RevokedAt is not null ? "Revocado"
            : t.ExpiresAt <= DateTimeOffset.UtcNow ? "Expirado"
            : t.SingleUse && t.UsedAt is not null ? "Usado"
            : "Vigente";

    private static string TokenStateClass(FormTokenDto t)
        => TokenStateLabel(t) == "Vigente" ? "ok" : "off";
}
