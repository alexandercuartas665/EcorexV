@page "/m/{Code}"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Text
@using Ecorex.Application.Forms
@using Ecorex.Domain.Enums
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@using Ecorex.Application.MenuConfig
@inject IFormDefinitionService FormsSvc
@inject IFormResponseService ResponsesSvc
@inject IMenuConfigService MenuSvc
@inject NavigationManager Nav
@inject IJSRuntime JS

@* ============================================================
   Bandeja del formulario-MODULO (Formularios avanzados, ola F4,
   doc 01 D6 / doc 02 s5). Ruta /m/{code}: KPIs + filtros + grid
   de registros + export CSV. "En vivo" por SignalR y policies
   Form.{code}.* quedan para el siguiente incremento.
   ============================================================ *@

<PageTitle>@(_def?.Title ?? "Modulo") - ECOREX.tareas</PageTitle>

@if (_loading)
{
    <p style="padding:24px;"><em>Cargando modulo...</em></p>
}
else if (_denied)
{
    <div style="padding:32px;">
        <h3>Sin acceso</h3>
        <p>No tienes permiso para ver el modulo <strong>@Code</strong> (no esta en tu menu).</p>
    </div>
}
else if (_def is null)
{
    <div style="padding:32px;">
        <h3>Modulo no encontrado</h3>
        <p>No existe un formulario con codigo <strong>@Code</strong> o no esta publicado como modulo.</p>
    </div>
}
else
{
    <div class="fm-wrap">
        <div class="fm-head">
            <div>
                <h2 class="fm-title">@_def.Title</h2>
                <p class="fm-sub">Modulo @_def.Code</p>
            </div>
            <div style="display:flex;gap:8px;">
                <button class="fm-export" @onclick="ExportExcelAsync" disabled="@_exporting">@(_exporting ? "Generando..." : "Exportar Excel")</button>
                <a class="fm-export" href="@CsvDataUri()" download="@($"{_def.Code}-registros.csv")">CSV</a>
            </div>
        </div>

        @* KPIs (doc 01 D6): cantidad, confirmados, anulados y % de crecimiento vs mes anterior. *@
        <div class="fm-kpis">
            <div class="fm-kpi"><span class="fm-kpi-n">@_records.Count</span><span class="fm-kpi-l">Registros</span></div>
            <div class="fm-kpi"><span class="fm-kpi-n">@_records.Count(r => r.RecordStatus == FormRecordStatus.Confirmed)</span><span class="fm-kpi-l">Confirmados</span></div>
            <div class="fm-kpi"><span class="fm-kpi-n">@_records.Count(r => r.RecordStatus == FormRecordStatus.Voided)</span><span class="fm-kpi-l">Anulados</span></div>
            <div class="fm-kpi">
                <span class="fm-kpi-n">@ThisMonthCount <span class="fm-kpi-growth @(GrowthPct >= 0 ? "up" : "down")">@(GrowthPct >= 0 ? "+" : "")@GrowthPct%</span></span>
                <span class="fm-kpi-l">Este mes</span>
            </div>
        </div>

        <div class="fm-filters">
            <select class="fm-filter" @bind="_statusFilter" @bind:after="StateHasChanged">
                <option value="">Todos los estados</option>
                <option value="Confirmed">Confirmados</option>
                <option value="Voided">Anulados</option>
            </select>
            <input class="fm-filter fm-search" placeholder="Buscar numero / referencia..."
                   value="@_search" @oninput="@(e => { _search = e.Value?.ToString(); })" />
            @* Filtros dinamicos por campo configurado (doc 01 D6). *@
            @foreach (var f in _filterFields)
            {
                var code = f.Code;
                <input class="fm-filter" placeholder="@f.Label"
                       value="@(_fieldFilters.GetValueOrDefault(code))"
                       @oninput="@(e => { _fieldFilters[code] = e.Value?.ToString(); })" />
            }
        </div>

        <table class="fm-table">
            <thead>
                <tr>
                    <th>Numero</th><th>Fecha</th><th>Estado</th>
                    @foreach (var c in _columns) { <th>@c.Label</th> }
                    @if (_columns.Count == 0) { <th>Referencia</th> }
                </tr>
            </thead>
            <tbody>
                @if (Filtered.Count == 0)
                {
                    <tr><td colspan="@(3 + (_columns.Count == 0 ? 1 : _columns.Count))" class="fm-empty">Sin registros@(HasFilters ? " que coincidan con el filtro" : " todavia").</td></tr>
                }
                @foreach (var r in Filtered)
                {
                    <tr>
                        <td>@(r.RecordNumber ?? "-")</td>
                        <td>@((r.TransactionDate ?? r.SubmittedAt)?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "-")</td>
                        <td><span class="fm-badge @(r.RecordStatus == FormRecordStatus.Voided ? "void" : r.RecordStatus == FormRecordStatus.Confirmed ? "ok" : "")">@RecordStatusLabel(r.RecordStatus)</span></td>
                        @foreach (var c in _columns) { <td>@(r.Fields.GetValueOrDefault(c.Code) ?? "-")</td> }
                        @if (_columns.Count == 0) { <td>@(r.Reference ?? "-")</td> }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter] public string Code { get; set; } = "";
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private FormDefinitionDetailDto? _def;
    private IReadOnlyList<FormRecordListItemDto> _records = [];
    private bool _loading = true;
    private bool _denied;
    private string? _statusFilter;
    private string? _search;
    private bool _exporting;
    private HubConnection? _hub;
    private string? _tenantId;
    // Columnas y filtros configurados (ola F4): (fieldCode, etiqueta).
    private List<(string Code, string Label)> _columns = new();
    private List<(string Code, string Label)> _filterFields = new();
    private readonly Dictionary<string, string?> _fieldFilters = new(StringComparer.Ordinal);

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        var list = await FormsSvc.ListAsync(includeArchived: true);
        var item = list.FirstOrDefault(d => string.Equals(d.Code, Code, StringComparison.OrdinalIgnoreCase));
        if (item is not null)
        {
            _def = await FormsSvc.GetAsync(item.Id);
            if (_def is { IsModule: true } && !await HasMenuAccessAsync())
            {
                _denied = true;
                _def = null;
                _loading = false;
                return;
            }
            if (_def is { IsModule: true })
            {
                var labels = _def.Questions.ToDictionary(q => q.FieldCode, q => q.Label, StringComparer.Ordinal);
                _columns = ParseCodes(_def.ListColumnsJson).Select(c => (c, labels.GetValueOrDefault(c, c))).ToList();
                _filterFields = ParseCodes(_def.FilterFieldsJson).Select(c => (c, labels.GetValueOrDefault(c, c))).ToList();
                _records = await ResponsesSvc.ListRecordsAsync(_def.Id);
            }
            else
            {
                _def = null; // existe pero no es modulo -> no exponer la bandeja
            }
        }
        _loading = false;
    }

    /// <summary>Bandeja en vivo (ola F4): se suscribe a "FormRecord" y recarga cuando entra un registro de este modulo.</summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Se conecta una sola vez (no gated en _def: OnParametersSetAsync puede seguir cargando en
        // el primer render). El handler chequea _def antes de recargar.
        if (!firstRender || _hub is not null || AuthState is null) { return; }
        var st = await AuthState;
        _tenantId = st.User.FindFirst("tenant_id")?.Value;
        if (_tenantId is null) { return; }
        _hub = new HubConnectionBuilder().WithUrl(Nav.ToAbsoluteUri("/hubs/tasks")).WithAutomaticReconnect().Build();
        _hub.On<string, string>("FormRecord", async (code, _) =>
        {
            if (_def is not null && string.Equals(code, Code, StringComparison.OrdinalIgnoreCase))
            {
                _records = await ResponsesSvc.ListRecordsAsync(_def.Id);
                await InvokeAsync(StateHasChanged);
            }
        });
        await _hub.StartAsync();
        await _hub.SendAsync("JoinTenant", _tenantId);
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
        {
            try { if (_tenantId is not null) { await _hub.SendAsync("LeaveTenant", _tenantId); } } catch { }
            await _hub.DisposeAsync();
        }
    }

    private bool HasFilters => !string.IsNullOrWhiteSpace(_statusFilter) || !string.IsNullOrWhiteSpace(_search)
        || _fieldFilters.Values.Any(v => !string.IsNullOrWhiteSpace(v));

    private IReadOnlyList<FormRecordListItemDto> Filtered
    {
        get
        {
            IEnumerable<FormRecordListItemDto> q = _records;
            if (Enum.TryParse<FormRecordStatus>(_statusFilter, out var st))
            {
                q = q.Where(r => r.RecordStatus == st);
            }
            if (!string.IsNullOrWhiteSpace(_search))
            {
                var s = _search.Trim();
                q = q.Where(r => (r.RecordNumber?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                    || (r.Reference?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false));
            }
            // Filtros dinamicos por campo configurado (ola F4).
            foreach (var (code, val) in _fieldFilters)
            {
                if (string.IsNullOrWhiteSpace(val)) { continue; }
                var v = val.Trim();
                q = q.Where(r => r.Fields.GetValueOrDefault(code)?.Contains(v, StringComparison.OrdinalIgnoreCase) ?? false);
            }
            return q.ToList();
        }
    }

    private static IReadOnlyList<string> ParseCodes(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) { return Array.Empty<string>(); }
        try { return System.Text.Json.JsonSerializer.Deserialize<List<string>>(json) ?? new(); }
        catch (System.Text.Json.JsonException) { return Array.Empty<string>(); }
    }

    /// <summary>
    /// Policy ligera (ola F4): el modulo solo es accesible si su nodo /m/{code} esta VISIBLE en el
    /// menu resuelto del usuario (reusa el sistema de permisos de menu). Fail-open si no se puede
    /// resolver el tenant (no rompe accesos legitimos); deniega solo si el menu resuelve sin el nodo.
    /// </summary>
    private async Task<bool> HasMenuAccessAsync()
    {
        if (AuthState is null) { return true; }
        var st = await AuthState;
        if (!Guid.TryParse(st.User.FindFirst("tenant_id")?.Value, out var tenantId)) { return true; }
        var menu = await MenuSvc.GetMenuForTenantUserAsync(tenantId, null);
        if (menu is null) { return true; }
        var route = $"/m/{Code}";
        bool Contains(IReadOnlyList<MenuNodeDto> nodes)
            => nodes.Any(n => string.Equals(n.Route?.TrimStart('/'), route.TrimStart('/'), StringComparison.OrdinalIgnoreCase)
                || Contains(n.Children));
        return Contains(menu.Roots);
    }

    private async Task ExportExcelAsync()
    {
        if (_def is null) { return; }
        _exporting = true;
        try
        {
            var bytes = await ResponsesSvc.ExportRecordsXlsxAsync(_def.Id);
            if (bytes is not null)
            {
                await JS.InvokeVoidAsync("ecorexDcCanvas.downloadBase64", $"{_def.Code}-registros.xlsx",
                    Convert.ToBase64String(bytes),
                    "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            }
        }
        finally
        {
            _exporting = false;
        }
    }

    private DateTimeOffset MonthStart => new(DateTimeOffset.Now.Year, DateTimeOffset.Now.Month, 1, 0, 0, 0, DateTimeOffset.Now.Offset);
    private int ThisMonthCount => _records.Count(r => (r.TransactionDate ?? r.SubmittedAt) >= MonthStart);
    private int PrevMonthCount => _records.Count(r =>
    {
        var d = r.TransactionDate ?? r.SubmittedAt;
        return d >= MonthStart.AddMonths(-1) && d < MonthStart;
    });
    private int GrowthPct => PrevMonthCount == 0
        ? (ThisMonthCount > 0 ? 100 : 0)
        : (int)Math.Round((ThisMonthCount - PrevMonthCount) * 100.0 / PrevMonthCount);

    private string CsvDataUri()
    {
        var sb = new StringBuilder();
        var head = new List<string> { "Numero", "Fecha", "Estado" };
        head.AddRange(_columns.Count > 0 ? _columns.Select(c => c.Label) : new[] { "Referencia" });
        sb.AppendLine(string.Join(",", head.Select(Csv)));
        foreach (var r in Filtered)
        {
            var fecha = (r.TransactionDate ?? r.SubmittedAt)?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "";
            var cells = new List<string?> { r.RecordNumber, fecha, RecordStatusLabel(r.RecordStatus) };
            cells.AddRange(_columns.Count > 0 ? _columns.Select(c => r.Fields.GetValueOrDefault(c.Code)) : new[] { r.Reference });
            sb.AppendLine(string.Join(",", cells.Select(Csv)));
        }
        return "data:text/csv;charset=utf-8;base64," + Convert.ToBase64String(Encoding.UTF8.GetBytes(sb.ToString()));
    }

    private static string Csv(string? v) => string.IsNullOrEmpty(v) ? "" : (v.Contains(',') ? $"\"{v}\"" : v);

    private static string RecordStatusLabel(FormRecordStatus s) => s switch
    {
        FormRecordStatus.Confirmed => "Confirmado",
        FormRecordStatus.Voided => "Anulado",
        _ => "Borrador",
    };
}
