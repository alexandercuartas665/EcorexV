@page "/inicio"
@attribute [Authorize(Policy = "TenantMember")]
@inject ITenantAdminService TenantsSvc

@* Inicio del workspace del tenant (seccion Principal del prototipo): saludo contextual +
   KPIs placeholder. Los indicadores se conectan a datos reales en la Fase 3. *@

<PageTitle>Inicio - ECOREX.tareas</PageTitle>

<nav class="ecorex-breadcrumb" aria-label="Ruta de navegacion">
    <span>Workspace</span>
    <span class="sep">/</span>
    <span>Principal</span>
    <span class="sep">/</span>
    <span class="cur">Inicio</span>
</nav>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/></svg>
            </div>
            <span>Principal</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">@_greeting@(_firstName is null ? "" : $", {_firstName}")</h1>
        <p class="page-sub" style="margin-bottom:0;">Resumen del workspace @(_tenantName ?? "de tu empresa"). Los indicadores se conectan a datos reales en la Fase 3.</p>
    </div>
    <a class="btn btn-primary" href="/tableros">Ir al gestor de tareas</a>
</div>

<div class="kpi-grid">
    <div class="kpi-card">
        <div class="kpi-top">
            <div class="kpi-icon tone-primary">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="m9 12 2 2 4-4"/></svg>
            </div>
        </div>
        <div class="kpi-label">Tareas activas</div>
        <div class="kpi-value">--</div>
        <div class="kpi-hint">Pendiente Fase 3</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-top">
            <div class="kpi-icon tone-success">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
            </div>
        </div>
        <div class="kpi-label">Proyectos en curso</div>
        <div class="kpi-value">--</div>
        <div class="kpi-hint">Pendiente Fase 3</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-top">
            <div class="kpi-icon tone-gold">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="8" x="3" y="3" rx="2"/><path d="M7 11v4a2 2 0 0 0 2 2h4"/><rect width="8" height="8" x="13" y="13" rx="2"/></svg>
            </div>
        </div>
        <div class="kpi-label">Flujos ejecutandose</div>
        <div class="kpi-value">--</div>
        <div class="kpi-hint">Pendiente Fase 4</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-top">
            <div class="kpi-icon tone-danger">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
            </div>
        </div>
        <div class="kpi-label">Alertas urgentes</div>
        <div class="kpi-value">--</div>
        <div class="kpi-hint">Pendiente Fase 3</div>
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string _greeting = "Hola";
    private string? _firstName;
    private string? _tenantName;

    protected override async Task OnInitializedAsync()
    {
        var hour = DateTime.Now.Hour;
        _greeting = hour < 12 ? "Buenos dias" : hour < 18 ? "Buenas tardes" : "Buenas noches";

        if (AuthState is null) return;
        var state = await AuthState;
        _firstName = state.User.Identity?.Name?.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();

        // El nombre del tenant activo sale del claim tenant_id (misma tecnica que NavMenu/Home).
        if (Guid.TryParse(state.User.FindFirst("tenant_id")?.Value, out var tenantId))
        {
            var tenant = await TenantsSvc.GetAsync(tenantId);
            _tenantName = tenant?.Name;
        }
    }
}
