@page "/mis-pasos"
@attribute [Authorize(Policy = "MisPasos.Ver")]
@* Bandeja operativa de flujos (runtime, ola F2, ADR-0036): mis pasos pendientes + atender.
   Policy MisPasos.Ver = RequireClaim(tenant_id) (cualquier miembro del tenant ve SU bandeja). *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using Ecorex.Application.Forms
@using Ecorex.Application.Tenancy
@using Ecorex.Application.Workflows
@using Ecorex.Domain.Enums
@using Ecorex.SuperAdmin.Components.Shared.Forms
@inject IWorkflowInboxService InboxSvc
@inject IFormResponseService FormResponsesSvc
@inject ITenantUserService TenantUsersSvc

<PageTitle>Mis pasos - ECOREX.tareas</PageTitle>

<nav class="ecorex-breadcrumb" aria-label="Ruta de navegacion">
    <a href="/inicio">Workspace</a>
    <span class="sep">/</span>
    <span>Mis Procesos</span>
    <span class="sep">/</span>
    <span class="cur">Mis pasos</span>
</nav>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            </div>
            <span>Flujos &#183; Runtime</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Mis pasos pendientes</h1>
        <p class="page-sub" style="margin-bottom:0;">Pasos de flujo que esperan tu atencion: reclama, diligencia el formulario o aprueba para que el caso avance.</p>
    </div>
    <div>
        <button class="btn btn-outline-secondary" @onclick="ReloadAsync" disabled="@_busy">Actualizar</button>
    </div>
</div>

@if (_actionError is not null)
{
    <div class="mp-alert" role="alert">
        <span>@_actionError</span>
        <button class="mp-alert-x" @onclick="@(() => _actionError = null)">&times;</button>
    </div>
}

@if (_loading)
{
    <p class="tk-empty-note">Cargando tu bandeja...</p>
}
else if (_meTenantUserId is null)
{
    <div class="mp-empty">
        <h3>Tu usuario no pertenece a este tenant</h3>
        <p>No se pudo resolver tu ficha de usuario del tenant activo, asi que no hay bandeja que mostrar.</p>
    </div>
}
else if (_steps.Count == 0)
{
    <div class="mp-empty">
        <div class="mp-empty-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        </div>
        <h3>No tienes pasos pendientes</h3>
        <p>Cuando un flujo requiera tu atencion, el paso aparecera aqui listo para atender.</p>
    </div>
}
else
{
    <div class="mp-list">
        @foreach (var step in _steps)
        {
            var s = step;
            <div class="mp-card @(_openStepId == s.StepId ? "open" : "")">
                <div class="mp-card-main">
                    <div class="mp-card-body">
                        <div class="mp-card-top">
                            <span class="mp-proc">@s.ProcessName <span class="mp-proc-code">@s.ProcessCode</span></span>
                            @if (s.IsMine)
                            {
                                <span class="tk-status st-progress">Tuyo</span>
                            }
                            else if (s.AssignedToTenantUserId is null)
                            {
                                <span class="tk-status st-pending">Sin reclamar</span>
                            }
                            else
                            {
                                <span class="tk-status st-active">de @s.AssignedToLabel</span>
                            }
                        </div>
                        <div class="mp-node">@(s.NodeName ?? "(paso sin nombre)")</div>
                        <div class="mp-meta">
                            @if (!string.IsNullOrWhiteSpace(s.TaskNumber))
                            {
                                <span class="mp-task">@s.TaskNumber</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(s.TaskTitle))
                            {
                                <span class="mp-task-title">@s.TaskTitle</span>
                            }
                            @if (s.HasForm)
                            {
                                <span class="mp-tag">Formulario</span>
                            }
                            @if (s.IsGatewayAhead)
                            {
                                <span class="mp-tag">Decision</span>
                            }
                            @if (s.CycleIndex > 0)
                            {
                                <span class="mp-tag">Ciclo @s.CycleIndex</span>
                            }
                        </div>
                    </div>
                    <div class="mp-card-actions">
                        @if (s.IsClaimable)
                        {
                            <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => ClaimAsync(s))" disabled="@_busy">Tomar</button>
                        }
                        <button class="btn btn-sm btn-primary" @onclick="@(() => ToggleAttend(s))" disabled="@_busy">
                            @(_openStepId == s.StepId ? "Cerrar" : "Atender")
                        </button>
                    </div>
                </div>

                @if (_openStepId == s.StepId)
                {
                    <div class="mp-attend">
                        @if (s.HasForm)
                        {
                            @if (_stepForm is not null)
                            {
                                <DynamicFormRenderer DefinitionId="@_stepForm.DefinitionId"
                                                     ResponseId="@_stepForm.ResponseId"
                                                     Reference="@_stepForm.Reference"
                                                     Mode="FormRenderMode.Fill"
                                                     SubmittedByTenantUserId="@_meTenantUserId"
                                                     ApprovalOptions="@(_stepForm.IsGatewayAhead ? _stepForm.ApprovalOptions : null)"
                                                     OnSubmitted="OnStepFormSubmittedAsync" />
                            }
                            else
                            {
                                <p class="tk-empty-note">Este paso exige un formulario pero aun no esta disponible su borrador. Actualiza la bandeja.</p>
                            }
                        }
                        else if (s.IsGatewayAhead && s.ApprovalOptions.Count > 0)
                        {
                            <p class="mp-attend-lbl">Decision de aprobacion</p>
                            <textarea class="form-control" rows="2" @bind="_comment" placeholder="Comentario (opcional)..."></textarea>
                            <div class="mp-decision-btns">
                                @foreach (var option in s.ApprovalOptions)
                                {
                                    var opt = option;
                                    <button class="btn btn-sm btn-primary" @onclick="@(() => CompleteAsync(s, opt))" disabled="@_busy">@opt</button>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="mp-attend-lbl">Completar el paso</p>
                            <textarea class="form-control" rows="2" @bind="_comment" placeholder="Comentario (opcional)..."></textarea>
                            <div class="mp-decision-btns">
                                <button class="btn btn-sm btn-primary" @onclick="@(() => CompleteAsync(s, null))" disabled="@_busy">Completar</button>
                            </div>
                        }

                        @if (s.AllowsReassignment && _candidates.Count > 0)
                        {
                            <div class="mp-reassign">
                                <span class="mp-attend-lbl">Reasignar a</span>
                                <select class="form-control form-control-sm" @bind="_reassignTo">
                                    <option value="">Elegir candidato...</option>
                                    @foreach (var c in _candidates.Where(c => c.Id != s.AssignedToTenantUserId))
                                    {
                                        <option value="@c.Id">@(string.IsNullOrWhiteSpace(c.DisplayName) ? c.Email : c.DisplayName)</option>
                                    }
                                </select>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => ReassignAsync(s))" disabled="@(_busy || string.IsNullOrEmpty(_reassignTo))">Reasignar</button>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    // Bandeja operativa de flujos (ola F2, ADR-0036). Es la bandeja del USUARIO: resuelve su
    // ficha de TenantUser del tenant activo (claim NameIdentifier -> PlatformUserId) y lista los
    // pasos que puede atender. Atender un paso con formulario reusa el DynamicFormRenderer (el
    // submit completa el paso y avanza el flujo); sin formulario, completa/aprueba via el servicio.
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _busy;
    private string? _actionError;

    private Guid? _meTenantUserId;
    private List<TenantUserDto> _users = new();
    private List<PendingStepDto> _steps = new();

    private Guid? _openStepId;
    private TaskStepFormDto? _stepForm;
    private string _comment = "";
    private string _reassignTo = "";
    private List<TenantUserDto> _candidates = new();

    protected override async Task OnInitializedAsync()
    {
        _users = (await TenantUsersSvc.ListAsync()).ToList();
        _meTenantUserId = await ResolveMeAsync();
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _busy = true;
        try
        {
            _openStepId = null;
            _stepForm = null;
            _comment = "";
            _reassignTo = "";
            if (_meTenantUserId is Guid me)
            {
                _steps = (await InboxSvc.GetMyPendingStepsAsync(me)).ToList();
            }
        }
        finally
        {
            _busy = false;
            _loading = false;
        }
    }

    private async Task ToggleAttend(PendingStepDto step)
    {
        if (_openStepId == step.StepId)
        {
            _openStepId = null;
            _stepForm = null;
            return;
        }
        _openStepId = step.StepId;
        _stepForm = null;
        _comment = "";
        _reassignTo = "";
        _actionError = null;

        // Formulario del paso (crea borrador + FormFlowLink de forma idempotente).
        if (step.HasForm && step.TaskItemId is Guid taskId)
        {
            var forms = await FormResponsesSvc.GetTaskStepFormsAsync(taskId);
            _stepForm = forms.FirstOrDefault(f => f.WorkflowNodeId != Guid.Empty && f.LinkStatus == FormFlowLinkStatus.Pending)
                ?? forms.FirstOrDefault();
        }

        // Candidatos para reasignar (si el nodo lo permite): todos los usuarios del tenant como
        // universo del selector; el servicio valida que el destino sea candidato real del nodo.
        _candidates = step.AllowsReassignment ? _users : new List<TenantUserDto>();
    }

    private async Task ClaimAsync(PendingStepDto step)
    {
        if (_meTenantUserId is not Guid me) { return; }
        _busy = true;
        _actionError = null;
        try
        {
            var result = await InboxSvc.ClaimStepAsync(step.StepId, me);
            if (!result.IsOk)
            {
                _actionError = result.Error;
            }
            await ReloadAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task CompleteAsync(PendingStepDto step, string? approvalResult)
    {
        if (_meTenantUserId is not Guid me) { return; }
        _busy = true;
        _actionError = null;
        try
        {
            var comment = string.IsNullOrWhiteSpace(_comment) ? null : _comment.Trim();
            var result = await InboxSvc.CompletePendingStepAsync(step.StepId, me, approvalResult, comment);
            if (!result.IsOk && result.Status != WorkflowEngineStatus.StuckDetected)
            {
                _actionError = result.Error;
            }
            await ReloadAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ReassignAsync(PendingStepDto step)
    {
        if (_meTenantUserId is not Guid me || !Guid.TryParse(_reassignTo, out var to)) { return; }
        _busy = true;
        _actionError = null;
        try
        {
            var result = await InboxSvc.ReassignStepAsync(step.StepId, to, me);
            if (!result.IsOk)
            {
                _actionError = result.Error;
            }
            await ReloadAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task OnStepFormSubmittedAsync(FormResponseDto _)
    {
        // El submit del formulario completo el paso del flujo en el servidor: refresca la bandeja.
        await ReloadAsync();
        StateHasChanged();
    }

    private async Task<Guid?> ResolveMeAsync()
    {
        if (AuthState is null) { return null; }
        var state = await AuthState;
        if (!Guid.TryParse(state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var platformUserId))
        {
            return null;
        }
        return _users.FirstOrDefault(u => u.PlatformUserId == platformUserId)?.Id;
    }
}
