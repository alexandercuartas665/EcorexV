@page "/productos"
@attribute [Authorize(Policy = "TenantMember")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.Application.Tenancy
@using Ecorex.Domain.Enums
@inject IProductService Svc
@inject ISedeService SedesSvc
@inject ISalonFieldService Fields
@inject IWebHostEnvironment Env
@inject IJSRuntime JS

<PageTitle>Productos - ECOREX.tareas</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
            </div>
            <span>Configuracion del salon</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Productos</h1>
        <p class="page-sub" style="margin-bottom:0;">Articulos del salon: precio, stock por sede, imagenes y los campos que tu definas.</p>
    </div>
    <div style="display:flex;gap:8px;">
        <button class="btn btn-outline-secondary" @onclick="() => _showFieldsConfig = true">&#9881; Configurar campos</button>
        <button class="btn btn-primary" @onclick="() => OpenForm(null)">+ Nuevo producto</button>
    </div>
</div>

@if (!_loading && _sedes.Count > 0)
{
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:18px;">
        <span class="text-muted" style="font-size:13px;">Disponibles en:</span>
        <select class="form-control" style="max-width:260px;" @bind="_sedeFilter" @bind:after="ReloadAsync">
            <option value="">Todas las sedes</option>
            @foreach (var s in _sedes)
            {
                <option value="@s.Id">@s.City &mdash; @s.Name</option>
            }
        </select>
    </div>
}

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else if (_items.Count == 0)
{
    <p class="text-muted">@(string.IsNullOrEmpty(_sedeFilter) ? "Aun no hay productos. Crea el primero con \"+ Nuevo producto\"." : "No hay productos con stock en esta sede.")</p>
}
else
{
    <div class="prod-grid">
        @foreach (var p in _items)
        {
            var thumb = p.Images.FirstOrDefault()?.Url;
            <div class="prod-card @(p.IsActive ? "" : "prod-off")">
                <div class="prod-thumb" @onclick="() => OpenForm(p)">
                    @if (thumb is not null)
                    {
                        <img src="@thumb" alt="@p.Name" />
                    }
                    else
                    {
                        <div class="prod-thumb-empty">sin foto</div>
                    }
                    @if (p.Images.Count > 1)
                    {
                        <span class="prod-imgcount">@p.Images.Count fotos</span>
                    }
                    @if (!p.IsActive)
                    {
                        <span class="prod-off-badge">Inactivo</span>
                    }
                </div>
                <div class="prod-body">
                    <div class="prod-name">@p.Name</div>
                    <div class="prod-meta">
                        @(string.IsNullOrWhiteSpace(p.Category) ? "Sin categoria" : p.Category)
                        @if (p.Price is decimal pr) { <span> &middot; <strong style="color:var(--primary);">$@pr.ToString("N0")</strong></span> }
                    </div>
                    <div class="prod-sedes">
                        @if (p.AvailableAt.Count == 0)
                        {
                            <span class="text-muted" style="font-size:11.5px;">Sin stock en ninguna sede</span>
                        }
                        else
                        {
                            @foreach (var s in p.AvailableAt)
                            {
                                <span class="prod-chip" title="@s.City">@s.SedeName: <strong>@s.Stock</strong></span>
                            }
                        }
                    </div>
                    <div class="prod-actions">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenForm(p)">Editar</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleActiveAsync(p)" disabled="@_busy">@(p.IsActive ? "Desactivar" : "Activar")</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(p)" disabled="@_busy">&times;</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (_formOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:760px;">
            <div class="modal-head">
                <h3>@(_editingId is null ? "Nuevo producto" : "Editar producto")</h3>
                <button class="modal-close" @onclick="CloseForm">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field-row">
                    <div class="field"><label class="form-label">Nombre *</label><input class="form-control" @bind="_form.Name" placeholder="Shampoo hidratante" /></div>
                    <div class="field"><label class="form-label">SKU / codigo</label><input class="form-control" @bind="_form.Sku" placeholder="SHP-001" /></div>
                </div>
                <div class="field-row">
                    <div class="field"><label class="form-label">Categoria</label><input class="form-control" @bind="_form.Category" placeholder="Cuidado capilar" /></div>
                    <div class="field"><label class="form-label">Precio</label><input class="form-control" type="number" min="0" @bind="_form.Price" /></div>
                </div>
                <div class="field">
                    <label class="form-label">Descripcion</label>
                    <RichTextArea @bind-Value="_form.Description" Rows="2" Placeholder="Que es el producto, beneficios..." />
                </div>
                <div class="field">
                    <label class="form-label">Especificaciones de uso</label>
                    <RichTextArea @bind-Value="_form.Specifications" Rows="3" Placeholder="Modo de uso, frecuencia, advertencias, ingredientes..." />
                </div>

                <div style="border-top:1px solid var(--border);padding-top:12px;margin-top:6px;">
                    <label class="form-label">Stock por sede</label>
                    @if (_sedes.Count == 0)
                    {
                        <div class="text-muted small">No hay sedes. Crea sedes en el modulo Sedes para manejar el stock por local.</div>
                    }
                    else
                    {
                        @foreach (var s in _sedes)
                        {
                            <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">
                                <span style="flex:1;font-size:13px;">@s.City &mdash; @s.Name</span>
                                <input class="form-control" type="number" min="0" style="max-width:120px;" value="@StockFor(s.Id)" @onchange="e => SetStock(s.Id, e.Value?.ToString())" />
                            </div>
                        }
                    }
                </div>

                @if (_productFields.Count > 0)
                {
                    <div style="border-top:1px solid var(--border);padding-top:12px;margin-top:12px;">
                        <label class="form-label">Datos del producto</label>
                        <SalonFieldsEditor Fields="_productFields" Values="_fieldValues" />
                    </div>
                }

                <div style="border-top:1px solid var(--border);padding-top:12px;margin-top:12px;">
                    <label class="form-label">Imagenes</label>
                    @if (_editingId is null)
                    {
                        <div class="text-muted small">Guarda el producto y luego podras agregar sus imagenes.</div>
                    }
                    else
                    {
                        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:8px;">
                            @foreach (var img in _images)
                            {
                                <div style="position:relative;width:84px;height:84px;border-radius:10px;overflow:hidden;border:1px solid var(--border);">
                                    <img src="@img.Url" alt="@img.FileName" style="width:100%;height:100%;object-fit:cover;" />
                                    <button type="button" title="Quitar" @onclick="() => RemoveImageAsync(img.Id)" disabled="@_busy"
                                            style="position:absolute;top:2px;right:2px;width:20px;height:20px;border-radius:50%;border:none;background:rgba(0,0,0,.6);color:#fff;cursor:pointer;line-height:1;">&times;</button>
                                </div>
                            }
                        </div>
                        <InputFile OnChange="OnImagesSelectedAsync" accept="image/*" multiple />
                        @if (_imgMsg is not null) { <div class="text-muted small" style="margin-top:4px;">@_imgMsg</div> }
                    }
                </div>

                @if (_error is not null) { <div class="text-danger small" style="margin-top:8px;">@_error</div> }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="CloseForm">Cerrar</button>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_form.Name))">@(_editingId is null ? "Crear producto" : "Guardar cambios")</button>
            </div>
        </div>
    </div>
}

<SalonFieldsConfig Show="_showFieldsConfig" ActorUserId="_actorId" Scopes="_productScope" OnClose="OnFieldsConfigClosedAsync" />

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private static readonly SalonFieldScope[] _productScope = { SalonFieldScope.Product };

    private bool _loading = true;
    private bool _busy;
    private bool _formOpen;
    private string? _error;
    private string? _imgMsg;
    private string _sedeFilter = "";
    private Guid? _editingId;
    private List<ProductDto> _items = new();
    private List<SedeDto> _sedes = new();
    private FormModel _form = new();
    private List<SalonFieldDto> _productFields = new();
    private Dictionary<string, string?> _fieldValues = new();
    private List<ProductImageDto> _images = new();
    private bool _showFieldsConfig;
    private Guid _actorId;

    protected override async Task OnInitializedAsync()
    {
        _actorId = await ActorAsync();
        _sedes = (await SedesSvc.ListAsync(includeInactive: false)).ToList();
        _productFields = (await Fields.ListAsync(SalonFieldScope.Product)).ToList();
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        Guid? sid = Guid.TryParse(_sedeFilter, out var g) ? g : null;
        _items = (await Svc.ListAsync(sid)).ToList();
        _loading = false;
    }

    private void OpenForm(ProductDto? p)
    {
        _error = null; _imgMsg = null;
        _editingId = p?.Id;
        _form = p is null
            ? new FormModel()
            : new FormModel { Name = p.Name, Sku = p.Sku, Category = p.Category, Price = p.Price, Description = p.Description, Specifications = p.Specifications };
        _form.SedeStocks = p?.Stocks.ToDictionary(s => s.SedeId, s => s.Stock) ?? new();
        _fieldValues = p?.FieldValues is { } fv ? new Dictionary<string, string?>(fv) : new();
        _images = p?.Images.ToList() ?? new();
        _formOpen = true;
    }

    private void CloseForm() => _formOpen = false;

    private int StockFor(Guid sedeId) => _form.SedeStocks.TryGetValue(sedeId, out var v) ? v : 0;
    private void SetStock(Guid sedeId, string? raw) => _form.SedeStocks[sedeId] = int.TryParse(raw, out var n) && n > 0 ? n : 0;

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Name)) { _error = "El nombre es obligatorio."; return; }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var stocks = _form.SedeStocks.Where(kv => kv.Value > 0).ToDictionary(kv => kv.Key, kv => kv.Value);
            var req = new SaveProductRequest(_form.Name, _form.Sku, _form.Description, _form.Specifications, _form.Price, _form.Category, stocks, new Dictionary<string, string?>(_fieldValues));
            if (_editingId is Guid id)
            {
                await Svc.UpdateAsync(id, req, actor);
                await ReloadAsync();
            }
            else
            {
                var created = await Svc.CreateAsync(req, actor);
                if (created is null) { _error = "No se pudo crear el producto."; return; }
                _editingId = created.Id;
                _images = created.Images.ToList();
                await ReloadAsync();
            }
        }
        finally { _busy = false; }
    }

    private async Task ToggleActiveAsync(ProductDto p)
    {
        _busy = true;
        try { await Svc.SetActiveAsync(p.Id, !p.IsActive, await ActorAsync()); await ReloadAsync(); }
        finally { _busy = false; }
    }

    private async Task DeleteAsync(ProductDto p)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Eliminar el producto \"{p.Name}\"?")) { return; }
        _busy = true;
        try { await Svc.DeleteAsync(p.Id, await ActorAsync()); await ReloadAsync(); }
        finally { _busy = false; }
    }

    private async Task OnImagesSelectedAsync(InputFileChangeEventArgs e)
    {
        if (_editingId is not Guid id) { return; }
        _busy = true; _imgMsg = null;
        try
        {
            var actor = await ActorAsync();
            foreach (var file in e.GetMultipleFiles(8))
            {
                var saved = await SaveImageFileAsync(file);
                if (saved is null) { _imgMsg = "Alguna imagen no se pudo subir (max 10MB)."; continue; }
                await Svc.AddImageAsync(id, saved.Value.Url, saved.Value.Name, actor);
            }
            var fresh = await Svc.GetAsync(id);
            _images = fresh?.Images.ToList() ?? _images;
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private async Task RemoveImageAsync(Guid imageId)
    {
        _busy = true;
        try
        {
            await Svc.RemoveImageAsync(imageId, await ActorAsync());
            if (_editingId is Guid id) { var fresh = await Svc.GetAsync(id); _images = fresh?.Images.ToList() ?? new(); }
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private async Task OnFieldsConfigClosedAsync()
    {
        _showFieldsConfig = false;
        _productFields = (await Fields.ListAsync(SalonFieldScope.Product)).ToList();
    }

    private async Task<(string Url, string Name)?> SaveImageFileAsync(IBrowserFile file)
    {
        const long max = 10L * 1024 * 1024;
        if (file.Size <= 0 || file.Size > max) { return null; }
        using var ms = new MemoryStream();
        await file.OpenReadStream(max).CopyToAsync(ms);
        var ext = System.IO.Path.GetExtension(file.Name);
        var dir = System.IO.Path.Combine(Env.WebRootPath, "uploads", "products");
        System.IO.Directory.CreateDirectory(dir);
        var name = $"prod-{Guid.NewGuid():N}{ext}";
        await System.IO.File.WriteAllBytesAsync(System.IO.Path.Combine(dir, name), ms.ToArray());
        return ($"/uploads/products/{name}", file.Name);
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private sealed class FormModel
    {
        public string Name { get; set; } = "";
        public string? Sku { get; set; }
        public string? Category { get; set; }
        public decimal? Price { get; set; }
        public string? Description { get; set; }
        public string? Specifications { get; set; }
        public Dictionary<Guid, int> SedeStocks { get; set; } = new();
    }
}
