    // ---- Regla ----

    private async Task OpenRuleEditorAsync(RuleDto? rule)
    {
        _editingRule = rule;
        _ruleError = null;
        _rName = rule?.Name ?? "";
        _rDescription = rule?.Description ?? "";
        _rVerbName = rule?.VerbName ?? "";
        _rSortOrder = rule?.SortOrder ?? (_rules.Count == 0 ? 0 : _rules.Max(r => r.SortOrder) + 1);
        _rStatus = rule?.Status ?? RuleStatus.Active;
        _paramValues.Clear();
        LoadParamValuesFromJson(rule?.ParamsJson);
        _linkFormDefinitionId = null;
        _linkQuestionId = null;
        _linkWorkflowId = null;
        _linkNodeId = null;
        _questionOptions = [];
        _nodeOptions = [];
        if (rule is not null)
        {
            await LoadLinksAsync(rule.Id);
            _formDefinitionOptions = await RulesSvc.ListFormDefinitionOptionsAsync();
            _workflowOptions = await RulesSvc.ListWorkflowDefinitionOptionsAsync();
        }
        _showRuleEditor = true;
    }

    private void CloseRuleEditor()
