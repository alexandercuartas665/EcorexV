        _dDescription = document?.Description ?? "";
        _dStatus = document?.Status ?? RuleStatus.Active;
        _showDocumentEditor = true;
    }

    private async Task SaveDocumentAsync()
    {
        _documentError = null;
        _busy = true;
        try
        {
            var request = new SaveRuleDocumentRequest(_dCode.Trim(), _dName.Trim(), _dCategory.Trim(),
                string.IsNullOrWhiteSpace(_dDescription) ? null : _dDescription.Trim(), _dStatus);
            var result = _editingDocument is null
                ? await RulesSvc.CreateDocumentAsync(request)
                : await RulesSvc.UpdateDocumentAsync(_editingDocument.Id, request);
