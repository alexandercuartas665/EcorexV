@page "/reprogramaciones"
@attribute [Authorize(Policy = "TenantMember")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.Application.Tenancy
@inject IAgendaService Agenda
@inject IResourceService Resources
@inject IJSRuntime JS

<PageTitle>Reprogramaciones - ECOREX.tareas</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v6h6"/><path d="M3 13a9 9 0 1 0 3-7.7L3 8"/></svg>
            </div>
            <span>Operacion diaria</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Reprogramaciones</h1>
        <p class="page-sub" style="margin-bottom:0;">Citas que el cliente cancelo y quiere reprogramar. Busca un nuevo cupo o descarta la solicitud.</p>
    </div>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else if (_items.Count == 0)
{
    <div class="card" style="padding:48px;text-align:center;max-width:640px;">
        <div style="font-size:2.4rem;color:var(--success);margin-bottom:8px;">&#10003;</div>
        <p class="text-muted" style="margin:0;">Sin reprogramaciones pendientes.</p>
    </div>
}
else
{
    <div style="display:flex;flex-direction:column;gap:12px;max-width:820px;">
        @foreach (var it in _items)
        {
            <div class="card" style="display:flex;align-items:center;gap:16px;padding:16px;">
                <span style="width:46px;height:46px;border-radius:50%;flex-shrink:0;display:grid;place-items:center;color:#fff;font-weight:800;background:var(--gradient-violet);">@Initials(it.ClientName)</span>
                <div style="flex:1;min-width:0;">
                    <div style="font-weight:700;">@(it.ClientName ?? "Cliente") <span class="text-muted" style="font-size:12px;font-weight:500;">@it.ClientPhone</span></div>
                    <div style="font-size:13px;">Cita original: <strong>@it.Date.ToString("dd MMM") @it.StartTime.ToString("HH\\:mm")</strong> con @it.ResourceName</div>
                    <div class="text-muted" style="font-size:12px;">@it.ServicesText</div>
                </div>
                <div style="display:flex;flex-direction:column;gap:6px;">
                    <button class="btn btn-sm btn-primary" @onclick="() => Reprogramar(it)">Buscar cupo</button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DescartarAsync(it)" disabled="@_busy">Descartar</button>
                </div>
            </div>
        }
    </div>
}

<BookingModal @ref="_modal" Resources="_resources" OnSaved="ReloadAsync" />

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _busy;
    private List<RescheduleItemDto> _items = new();
    private List<ResourceDto> _resources = new();
    private BookingModal _modal = default!;

    protected override async Task OnInitializedAsync()
    {
        _resources = (await Resources.ListAsync()).ToList();
        await ReloadAsync();
        _loading = false;
    }

    private async Task ReloadAsync() => _items = (await Agenda.GetRescheduleQueueAsync()).ToList();

    private async Task Reprogramar(RescheduleItemDto it) => await _modal.OpenForRescheduleAsync(it);

    private async Task DescartarAsync(RescheduleItemDto it)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Descartar la solicitud de reprogramacion?")) { return; }
        _busy = true;
        try { await Agenda.DismissRescheduleAsync(it.AppointmentId, await ActorAsync()); await ReloadAsync(); }
        finally { _busy = false; }
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) { return "C"; }
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1 ? parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant() : $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
    }
}
