@page "/r/{Token}"
@layout EmptyLayout
@attribute [AllowAnonymous]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.Application.Tenancy
@using Ecorex.Domain.Enums
@using Ecorex.SuperAdmin.Services
@inject IPublicBookingService Booking

<PageTitle>Reservar cita@(_salon is null ? "" : " - " + _salon.SalonName)</PageTitle>

<div style="min-height:100vh;background:#f5f3ff;padding:24px 12px;">
  <div style="max-width:680px;margin:0 auto;">

    @if (_loading)
    {
        <p style="text-align:center;color:#6b7280;">Cargando...</p>
    }
    else if (_salon is null)
    {
        <div style="background:#fff;border-radius:16px;padding:32px;text-align:center;box-shadow:0 4px 20px rgba(0,0,0,.06);">
            <h2 style="margin:0 0 8px;">Link no disponible</h2>
            <p style="color:#6b7280;margin:0;">Este enlace de reservas no es valido o esta desactivado. Pide al salon el link actualizado.</p>
        </div>
    }
    else if (_done)
    {
        <div style="background:#fff;border-radius:16px;padding:32px;text-align:center;box-shadow:0 4px 20px rgba(0,0,0,.06);">
            <div style="font-size:44px;line-height:1;margin-bottom:10px;">&#10003;</div>
            <h2 style="margin:0 0 6px;">Cita reservada</h2>
            <p style="color:#374151;margin:0 0 4px;">@_doneSummary</p>
            <p style="color:#6b7280;font-size:13px;margin:10px 0 0;">El salon confirmara tu cita. &iexcl;Te esperamos!</p>
        </div>
    }
    else
    {
        <div style="text-align:center;margin-bottom:18px;">
            <h1 style="margin:0;font-size:24px;color:#4c1d95;">@_salon.SalonName</h1>
            <p style="color:#6b7280;margin:4px 0 0;font-size:14px;">Reserva tu cita en linea</p>
        </div>

        @* ---- Paso 1: asesor ---- *@
        <div style="background:#fff;border-radius:16px;padding:18px;margin-bottom:14px;box-shadow:0 4px 20px rgba(0,0,0,.05);">
            <div style="font-weight:700;margin-bottom:12px;color:#111827;">1. Elige con quien</div>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;">
                @foreach (var a in _advisors)
                {
                    var sel = _advisor?.Id == a.Id;
                    <button type="button" @onclick="() => SelectAdvisorAsync(a)"
                            style="text-align:left;border:2px solid @(sel ? "#7c3aed" : "#e5e7eb");background:@(sel ? "#f5f3ff" : "#fff");border-radius:12px;padding:10px;cursor:pointer;display:flex;align-items:center;gap:10px;">
                        @if (a.HasPhoto)
                        {
                            <img src="/media/asesor/@a.Id" alt="@a.Name" style="width:44px;height:44px;border-radius:50%;object-fit:cover;flex-shrink:0;" />
                        }
                        else
                        {
                            <span style="width:44px;height:44px;border-radius:50%;flex-shrink:0;display:grid;place-items:center;background:#ddd6fe;color:#5b21b6;font-weight:800;">@Initials(a.Name)</span>
                        }
                        <span style="min-width:0;">
                            <span style="display:block;font-weight:700;font-size:13px;color:#111827;">@a.Name</span>
                            <span style="display:block;font-size:11px;color:#6b7280;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@(a.Services.Count == 0 ? " " : string.Join(", ", a.Services))</span>
                        </span>
                    </button>
                }
            </div>
        </div>

        @* ---- Paso 2: servicios ---- *@
        @if (_advisor is not null)
        {
            <div style="background:#fff;border-radius:16px;padding:18px;margin-bottom:14px;box-shadow:0 4px 20px rgba(0,0,0,.05);">
                <div style="font-weight:700;margin-bottom:12px;color:#111827;">2. &iquest;Que servicio?</div>
                @if (_services.Count == 0)
                {
                    <p style="color:#6b7280;font-size:13px;margin:0;">Este asesor no tiene servicios configurados.</p>
                }
                else
                {
                    @foreach (var s in _services)
                    {
                        var on = _chosen.Contains(s.Id);
                        var tiered = s.Tiers is { Count: > 0 };
                        <label style="display:flex;align-items:center;gap:10px;padding:9px 4px;border-bottom:1px solid #f3f4f6;cursor:pointer;">
                            <input type="checkbox" checked="@on" @onchange="() => ToggleServiceAsync(s.Id)" />
                            <span style="flex:1;min-width:0;">
                                <span style="font-weight:600;font-size:14px;color:#111827;">@s.Name</span>
                                <span style="display:block;font-size:12px;color:#6b7280;">
                                    @if (tiered) { <text>Precio y duracion segun el largo</text> }
                                    else { <text>@s.DurationMinutes min &middot; $@s.Price.ToString("N0")</text> }
                                </span>
                            </span>
                        </label>
                    }
                }
            </div>
        }

        @* ---- Paso 2b: largo de cabello (si aplica) ---- *@
        @if (_advisor is not null && _needsHair)
        {
            <div style="background:#fff;border-radius:16px;padding:18px;margin-bottom:14px;box-shadow:0 4px 20px rgba(0,0,0,.05);">
                <div style="font-weight:700;margin-bottom:6px;color:#111827;">3. Tu largo de cabello</div>
                <p style="color:#6b7280;font-size:12px;margin:0 0 10px;">El servicio cambia de precio y duracion segun el largo. Sube una foto donde se vea bien tu cabello y lo detectamos.</p>
                <label style="display:inline-block;background:#7c3aed;color:#fff;border-radius:10px;padding:9px 14px;cursor:pointer;font-weight:600;font-size:13px;@(_classifying ? "opacity:.6;pointer-events:none;" : "")">
                    @(_classifying ? "Analizando..." : "Subir foto")
                    <InputFile OnChange="OnPhotoAsync" accept="image/*" style="display:none;" />
                </label>
                @if (_classifyMsg is not null) { <span style="margin-left:10px;font-size:13px;color:#6b7280;">@_classifyMsg</span> }

                <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:12px;">
                    @foreach (var (val, label) in _hairOptions)
                    {
                        var sel = _hairLength == val;
                        <button type="button" @onclick="() => SetHairAsync(val)"
                                style="border:2px solid @(sel ? "#7c3aed" : "#e5e7eb");background:@(sel ? "#f5f3ff" : "#fff");color:#374151;border-radius:99px;padding:6px 14px;cursor:pointer;font-size:13px;font-weight:600;">@label</button>
                    }
                </div>
                <p style="color:#9ca3af;font-size:11px;margin:8px 0 0;">Puedes ajustarlo manualmente si la deteccion no coincide.</p>
            </div>
        }

        @* ---- Paso 3: fecha y hora ---- *@
        @if (_advisor is not null && _chosen.Count > 0 && (!_needsHair || _hairLength is not null))
        {
            <div style="background:#fff;border-radius:16px;padding:18px;margin-bottom:14px;box-shadow:0 4px 20px rgba(0,0,0,.05);">
                <div style="font-weight:700;margin-bottom:12px;color:#111827;">4. Fecha y hora</div>
                <input type="date" value="@_date.ToString("yyyy-MM-dd")" @onchange="OnDateChangedAsync"
                       style="border:1px solid #e5e7eb;border-radius:10px;padding:8px 10px;font-size:14px;" />
                <div style="margin-top:12px;">
                    @if (_loadingSlots)
                    {
                        <p style="color:#6b7280;font-size:13px;margin:0;">Buscando horarios...</p>
                    }
                    else if (_slots.Count == 0)
                    {
                        <p style="color:#6b7280;font-size:13px;margin:0;">No hay horarios libres ese dia. Prueba otra fecha.</p>
                    }
                    else
                    {
                        <div style="display:flex;gap:8px;flex-wrap:wrap;">
                            @foreach (var t in _slots)
                            {
                                var sel = _time == t;
                                <button type="button" @onclick="() => _time = t"
                                        style="border:2px solid @(sel ? "#7c3aed" : "#e5e7eb");background:@(sel ? "#7c3aed" : "#fff");color:@(sel ? "#fff" : "#374151");border-radius:10px;padding:7px 14px;cursor:pointer;font-size:13px;font-weight:600;">@t</button>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        @* ---- Paso 4: datos + confirmar ---- *@
        @if (_advisor is not null && _chosen.Count > 0 && _time is not null)
        {
            <div style="background:#fff;border-radius:16px;padding:18px;margin-bottom:14px;box-shadow:0 4px 20px rgba(0,0,0,.05);">
                <div style="font-weight:700;margin-bottom:12px;color:#111827;">5. Tus datos</div>
                <input placeholder="Tu nombre" @bind="_clientName"
                       style="width:100%;box-sizing:border-box;border:1px solid #e5e7eb;border-radius:10px;padding:10px;font-size:14px;margin-bottom:10px;" />
                <input placeholder="WhatsApp (ej. +57 300 000 0000)" @bind="_clientPhone"
                       style="width:100%;box-sizing:border-box;border:1px solid #e5e7eb;border-radius:10px;padding:10px;font-size:14px;" />
                @if (_error is not null) { <div style="color:#dc2626;font-size:13px;margin-top:10px;">@_error</div> }
                <button type="button" @onclick="ConfirmAsync" disabled="@_booking"
                        style="width:100%;margin-top:14px;background:#7c3aed;color:#fff;border:none;border-radius:12px;padding:13px;font-weight:700;font-size:15px;cursor:pointer;@(_booking ? "opacity:.6;" : "")">
                    @(_booking ? "Reservando..." : "Confirmar reserva")
                </button>
            </div>
        }
    }
  </div>
</div>

@code {
    [Parameter] public string Token { get; set; } = "";

    private static readonly (HairLength, string)[] _hairOptions =
    {
        (HairLength.Corto, "Corto"), (HairLength.Medio, "Medio"), (HairLength.Largo, "Largo"), (HairLength.MuyLargo, "Muy largo")
    };

    private bool _loading = true;
    private PublicSalonDto? _salon;
    private List<PublicAdvisorDto> _advisors = new();
    private PublicAdvisorDto? _advisor;
    private List<ServiceOptionDto> _services = new();
    private readonly List<Guid> _chosen = new();
    private bool _needsHair;
    private HairLength? _hairLength;
    private bool _classifying;
    private string? _classifyMsg;
    private DateOnly _date = DateOnly.FromDateTime(DateTime.Today);
    private List<string> _slots = new();
    private bool _loadingSlots;
    private string? _time;
    private string _clientName = "";
    private string _clientPhone = "";
    private bool _booking;
    private string? _error;
    private bool _done;
    private string _doneSummary = "";

    protected override async Task OnInitializedAsync()
    {
        _salon = await Booking.ResolveAsync(Token);
        if (_salon is not null)
        {
            _advisors = (await Booking.GetAdvisorsAsync(_salon.TenantId)).ToList();
        }
        _loading = false;
    }

    private async Task SelectAdvisorAsync(PublicAdvisorDto a)
    {
        _advisor = a; _chosen.Clear(); _needsHair = false; _hairLength = null;
        _slots.Clear(); _time = null; _classifyMsg = null; _error = null;
        _services = (await Booking.GetServicesAsync(_salon!.TenantId, a.Id)).ToList();
    }

    private async Task ToggleServiceAsync(Guid id)
    {
        if (!_chosen.Remove(id)) { _chosen.Add(id); }
        _needsHair = _chosen.Any(cid => _services.FirstOrDefault(s => s.Id == cid)?.Tiers is { Count: > 0 });
        if (!_needsHair) { _hairLength = null; }
        _time = null;
        await RefreshSlotsAsync();
    }

    private async Task OnPhotoAsync(InputFileChangeEventArgs e)
    {
        _classifyMsg = null;
        var file = e.File;
        if (file is null) { return; }
        const long max = 8 * 1024 * 1024;
        if (file.Size <= 0 || file.Size > max) { _classifyMsg = "La foto debe pesar menos de 8MB."; return; }
        _classifying = true;
        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(max).CopyToAsync(ms);
            var b64 = Convert.ToBase64String(ms.ToArray());
            var mime = string.IsNullOrWhiteSpace(file.ContentType) ? "image/jpeg" : file.ContentType;
            var res = await Booking.ClassifyAsync(_salon!.TenantId, b64, mime);
            if (!res.Ok) { _classifyMsg = res.Error ?? "No se pudo analizar la foto."; return; }
            var mapped = Booking.MapHairLength(res.CategoryName);
            if (mapped is HairLength hl)
            {
                _hairLength = hl;
                _classifyMsg = $"Detectamos: {res.CategoryName} ({res.Confidence}%). Confirma o ajusta abajo.";
                await RefreshSlotsAsync();
            }
            else
            {
                _classifyMsg = $"Detectamos \"{res.CategoryName}\", pero elige tu largo abajo para continuar.";
            }
        }
        catch { _classifyMsg = "No se pudo leer la imagen."; }
        finally { _classifying = false; }
    }

    private async Task SetHairAsync(HairLength val)
    {
        _hairLength = val; _time = null;
        await RefreshSlotsAsync();
    }

    private async Task OnDateChangedAsync(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var d)) { _date = d; }
        _time = null;
        await RefreshSlotsAsync();
    }

    private async Task RefreshSlotsAsync()
    {
        if (_advisor is null || _chosen.Count == 0 || (_needsHair && _hairLength is null)) { _slots = new(); return; }
        _loadingSlots = true;
        try
        {
            _slots = (await Booking.GetAvailableStartsAsync(_salon!.TenantId, _advisor.Id, _chosen.ToList(), _hairLength, _date)).ToList();
        }
        finally { _loadingSlots = false; }
    }

    private async Task ConfirmAsync()
    {
        _error = null; _booking = true;
        try
        {
            var input = new PublicBookingInput(_advisor!.Id, _date, _time!, _chosen.ToList(), _clientName, _clientPhone, _hairLength);
            var res = await Booking.BookAsync(_salon!.TenantId, input);
            if (!res.Ok) { _error = res.Error ?? "No se pudo reservar."; return; }
            _doneSummary = $"{_advisor.Name} - {_date:yyyy-MM-dd} a las {_time}";
            _done = true;
        }
        finally { _booking = false; }
    }

    private static string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) { return "?"; }
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1 ? parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant() : $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
    }
}
