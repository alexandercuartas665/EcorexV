@page "/reservas-online"
@attribute [Authorize(Policy = "TenantMember")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using Ecorex.Application.Tenancy
@inject IOnlineBookingService OnlineBooking
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Reservas online - ECOREX.tareas</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            </div>
            <span>Configuracion del salon</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Reservas online</h1>
        <p class="page-sub" style="margin-bottom:0;">Activa un link publico para que tus clientas reserven solas (eligen asesor, servicio y horario). El agente de IA puede enviar este link cuando alguien quiera agendar.</p>
    </div>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="card" style="padding:20px;max-width:720px;">
        <label style="display:flex;align-items:center;gap:12px;cursor:pointer;">
            <input type="checkbox" checked="@_settings.Enabled" @onchange="ToggleAsync" disabled="@_busy" style="width:18px;height:18px;" />
            <span style="font-weight:700;">Reservas online activas</span>
        </label>

        @if (_settings.Enabled && _link is not null)
        {
            <div style="margin-top:18px;">
                <label class="form-label">Link publico de reserva</label>
                <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                    <input class="form-control" readonly value="@_link" style="flex:1;min-width:260px;font-family:monospace;font-size:13px;" />
                    <button class="btn btn-primary" @onclick="CopyAsync">@(_copied ? "Copiado!" : "Copiar")</button>
                    <a class="btn btn-outline-secondary" href="@_link" target="_blank" rel="noopener">Abrir</a>
                </div>
                <p class="text-muted" style="font-size:12px;margin-top:8px;">
                    Comparte este link en tus redes o WhatsApp. El agente de IA tambien lo enviara cuando una clienta quiera agendar
                    (herramienta <code>obtener_link_reserva</code>). Las citas que llegan por aqui quedan agendadas y ocupan el cupo;
                    el motor impide cruces de horario.
                </p>
                <button class="btn btn-sm btn-outline-danger" style="margin-top:6px;" @onclick="RegenerateAsync" disabled="@_busy">Regenerar link (invalida el anterior)</button>
            </div>
        }
        else if (_settings.Enabled)
        {
            <p class="text-muted" style="margin-top:14px;">Activado. Recarga para ver el link.</p>
        }
        else
        {
            <p class="text-muted" style="margin-top:14px;">Actívalo para generar el link publico de reservas.</p>
        }
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _busy;
    private bool _copied;
    private OnlineBookingSettingsDto _settings = new(false, null, null, null);
    private string? _link;

    protected override async Task OnInitializedAsync()
    {
        _settings = await OnlineBooking.GetAsync();
        RecomputeLink();
        _loading = false;
    }

    private async Task ToggleAsync(ChangeEventArgs e)
    {
        var enabled = e.Value is bool b && b;
        _busy = true; _copied = false;
        try
        {
            _settings = await OnlineBooking.SetEnabledAsync(enabled, Origin(), await ActorAsync());
            RecomputeLink();
        }
        finally { _busy = false; }
    }

    private async Task RegenerateAsync()
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Regenerar el link? El link anterior dejara de funcionar.")) { return; }
        _busy = true; _copied = false;
        try
        {
            _settings = await OnlineBooking.RegenerateTokenAsync(Origin(), await ActorAsync());
            RecomputeLink();
        }
        finally { _busy = false; }
    }

    private async Task CopyAsync()
    {
        if (_link is null) { return; }
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", _link); _copied = true; }
        catch { /* clipboard no disponible */ }
    }

    private void RecomputeLink()
        => _link = string.IsNullOrWhiteSpace(_settings.Path) ? null : Origin() + _settings.Path;

    private string Origin() => Nav.BaseUri.TrimEnd('/');

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }
}
