@page "/sedes"
@attribute [Authorize(Policy = "TenantMember")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.Application.Tenancy
@inject ISedeService Svc
@inject IJSRuntime JS

<PageTitle>Sedes - ECOREX.tareas</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <span>Configuracion del salon</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Sedes</h1>
        <p class="page-sub" style="margin-bottom:0;">Locales del salon. Cada asesor o estacion se vincula a una sede desde su ficha en Asesores de imagen.</p>
    </div>
    <button class="btn btn-primary" @onclick="() => OpenForm(null)">+ Nueva sede</button>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="kpi-grid" style="margin-bottom:22px;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));max-width:620px;">
        <div class="kpi-card"><div class="kpi-label">Sedes activas</div><div class="kpi-value">@_items.Count(s => s.IsActive)</div><div class="kpi-hint">Locales del salon</div></div>
        <div class="kpi-card"><div class="kpi-label">Ciudades</div><div class="kpi-value">@_items.Select(s => s.City).Distinct().Count()</div></div>
    </div>

    @if (_items.Count == 0)
    {
        <p class="text-muted">Aun no hay sedes. Crea la primera con "+ Nueva sede".</p>
    }
    else
    {
        <div class="card" style="max-width:980px;padding:6px 16px;">
            <table class="table table-hover align-middle" style="margin-bottom:0;">
                <thead>
                    <tr><th>Sede</th><th>Ciudad</th><th>Direccion</th><th>Telefono</th><th class="text-end">Asesores</th><th>Estado</th><th class="text-end">Acciones</th></tr>
                </thead>
                <tbody>
                    @foreach (var s in _items)
                    {
                        <tr>
                            <td><strong>@s.Name</strong></td>
                            <td>@s.City</td>
                            <td class="text-muted">@(string.IsNullOrWhiteSpace(s.Address) ? "-" : s.Address)</td>
                            <td class="text-muted">@(string.IsNullOrWhiteSpace(s.Phone) ? "-" : s.Phone)</td>
                            <td class="text-end"><span class="badge bg-secondary">@s.ResourceCount</span></td>
                            <td>@if (s.IsActive) {<span class="badge bg-success">Activa</span>} else {<span class="badge bg-secondary">Inactiva</span>}</td>
                            <td class="text-end" style="white-space:nowrap;">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenForm(s)">Editar</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleActiveAsync(s)" disabled="@_busy">@(s.IsActive ? "Desactivar" : "Activar")</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(s)" disabled="@_busy">Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (_formOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog">
            <div class="modal-head">
                <h3>@(_editingId is null ? "Nueva sede" : "Editar sede")</h3>
                <button class="modal-close" @onclick="() => _formOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field-row">
                    <div class="field"><label class="form-label">Nombre *</label><input class="form-control" @bind="_form.Name" placeholder="Sede Norte" /></div>
                    <div class="field"><label class="form-label">Ciudad *</label><input class="form-control" @bind="_form.City" placeholder="Cali" /></div>
                </div>
                <div class="field"><label class="form-label">Direccion</label><input class="form-control" @bind="_form.Address" placeholder="Cra 100 #1-23" /></div>
                <div class="field"><label class="form-label">Telefono</label><input class="form-control" @bind="_form.Phone" placeholder="+57 ..." /></div>
                @if (_error is not null) { <div class="text-danger small">@_error</div> }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _formOpen = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_form.Name) || string.IsNullOrWhiteSpace(_form.City))">Guardar</button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _busy;
    private bool _formOpen;
    private string? _error;
    private Guid? _editingId;
    private List<SedeDto> _items = new();
    private FormModel _form = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _items = (await Svc.ListAsync()).ToList();
        _loading = false;
    }

    private void OpenForm(SedeDto? s)
    {
        _error = null;
        _editingId = s?.Id;
        _form = s is null ? new FormModel() : new FormModel { Name = s.Name, City = s.City, Address = s.Address, Phone = s.Phone };
        _formOpen = true;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Name) || string.IsNullOrWhiteSpace(_form.City)) { _error = "Nombre y ciudad son obligatorios."; return; }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var req = new SaveSedeRequest(_form.Name, _form.City, _form.Address, _form.Phone);
            var result = _editingId is Guid id ? await Svc.UpdateAsync(id, req, actor) : await Svc.CreateAsync(req, actor);
            if (result is null) { _error = "No se pudo guardar."; return; }
            _formOpen = false;
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

    private async Task ToggleActiveAsync(SedeDto s)
    {
        _busy = true;
        try { await Svc.SetActiveAsync(s.Id, !s.IsActive, await ActorAsync()); await ReloadAsync(); }
        finally { _busy = false; }
    }

    private async Task DeleteAsync(SedeDto s)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Eliminar la sede \"{s.Name}\"? Los asesores quedaran sin sede.")) { return; }
        _busy = true;
        try { await Svc.DeleteAsync(s.Id, await ActorAsync()); await ReloadAsync(); }
        finally { _busy = false; }
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private sealed class FormModel
    {
        public string Name { get; set; } = "";
        public string City { get; set; } = "";
        public string? Address { get; set; }
        public string? Phone { get; set; }
    }
}
