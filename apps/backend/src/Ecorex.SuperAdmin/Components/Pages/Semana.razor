@page "/semana"
@attribute [Authorize(Policy = "TenantMember")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Ecorex.Application.Tenancy
@using Ecorex.Domain.Enums
@inject IResourceService Resources
@inject IAgendaService Agenda

<PageTitle>Vista semanal - ECOREX.tareas</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/><path d="M15 3v18"/></svg>
            </div>
            <span>Operacion diaria</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Vista semanal</h1>
        <p class="page-sub" style="margin-bottom:0;">Todos los asesores en el mismo grid; cada cita con el color de su asesor. Clic en una cita para abrirla.</p>
    </div>
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        @if (_resources.Count > 0)
        {
            <select class="form-control form-control-sm" style="max-width:200px;" @bind="_filterStr" @bind:after="LoadAsync">
                <option value="ALL">Todos los asesores</option>
                @foreach (var r in _resources)
                {
                    <option value="@r.Id">@r.Name</option>
                }
            </select>
        }
        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ChangeWeek(-1)">&lsaquo;</button>
        <span style="font-weight:700;font-size:13px;">@_weekLabel</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ChangeWeek(1)">&rsaquo;</button>
    </div>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else if (_week is null)
{
    <p class="text-muted">Sin datos.</p>
}
else
{
    @if (_week.Resources.Count > 0)
    {
        <div class="card" style="padding:12px 16px;margin-bottom:14px;">
            <div style="display:flex;flex-wrap:wrap;gap:8px;">
                @foreach (var r in _week.Resources)
                {
                    <span style="display:inline-flex;align-items:center;gap:7px;background:var(--card);border:1px solid var(--border);padding:4px 11px;border-radius:99px;font-size:12px;font-weight:600;">
                        <span style="width:13px;height:13px;border-radius:4px;background:@r.Color;"></span> @r.Name
                    </span>
                }
            </div>
        </div>
    }

    <div class="card" style="padding:14px;overflow-x:auto;">
        <div style="display:grid;grid-template-columns:64px repeat(7,minmax(120px,1fr));gap:4px;min-width:max-content;">
            <div class="week-h"></div>
            @for (var i = 0; i < 7; i++)
            {
                var d = _weekStart.AddDays(i);
                <div style="font-weight:700;font-size:12px;text-align:center;padding:6px 0;">@_dayLabels[i] <strong>@d.Day</strong></div>
            }
            @for (var h = 8; h <= 20; h++)
            {
                var hour = h;
                <div class="text-muted" style="font-size:11px;text-align:right;padding-right:6px;padding-top:2px;">@hour.ToString("D2"):00</div>
                @for (var i = 0; i < 7; i++)
                {
                    var day = _weekStart.AddDays(i);
                    var cellAppts = _week.Appointments.Where(a => a.Date == day && a.StartTime.Hour == hour).ToList();
                    <div style="min-height:44px;border-radius:7px;background:var(--card);border:1px solid var(--border);padding:2px;">
                        @foreach (var a in cellAppts)
                        {
                            <div style="color:#fff;font-size:11px;font-weight:700;border-radius:5px;padding:3px 5px;line-height:1.2;margin-bottom:2px;cursor:pointer;background:@a.Color;@ChainRing(a.ChainId)"
                                 @onclick="() => OpenEdit(a.Id)" title="@a.ResourceFirstName">
                                @a.StartTime.ToString("HH\\:mm") <strong>@a.ClientFirstName</strong>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
}

<BookingModal @ref="_modal" Resources="_resources" OnSaved="LoadAsync" />

@code {
    private bool _loading = true;
    private DateOnly _weekStart;
    private string _filterStr = "ALL";
    private string _weekLabel = "";
    private WeekDto? _week;
    private List<ResourceDto> _resources = new();
    private BookingModal _modal = default!;

    private static readonly string[] _dayLabels = { "Lun", "Mar", "Mie", "Jue", "Vie", "Sab", "Dom" };

    protected override async Task OnInitializedAsync()
    {
        _resources = (await Resources.ListAsync()).ToList();
        var today = DateOnly.FromDateTime(DateTime.Today);
        _weekStart = today.AddDays(-(((int)today.DayOfWeek + 6) % 7)); // lunes de esta semana
        await LoadAsync();
        _loading = false;
    }

    private async Task LoadAsync()
    {
        Guid? filter = Guid.TryParse(_filterStr, out var f) ? f : null;
        _week = await Agenda.GetWeekAsync(_weekStart, filter);
        var end = _weekStart.AddDays(6);
        _weekLabel = $"{_weekStart:dd MMM} - {end:dd MMM}";
    }

    private async Task ChangeWeek(int dir)
    {
        _weekStart = _weekStart.AddDays(dir * 7);
        await LoadAsync();
    }

    private async Task OpenEdit(Guid id) => await _modal.OpenForEditAsync(id);

    private static string ChainRing(Guid? chainId) => chainId is null ? "" : "box-shadow:0 0 0 2px #C7398B;";
}
