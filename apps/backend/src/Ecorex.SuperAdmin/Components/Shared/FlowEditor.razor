    private async Task OnToolAsync(string toolId)
    {
        _error = null;
        switch (toolId)
        {
            case "sel" or "conn" or "del":
                _tool = toolId;
                _connFrom = null;
                break;
            case "task":
                await AddNodeAsync(WorkflowNodeType.Task);
                break;
            case "event":
                // Como el prototipo agrega "eventos": si ya hay startEvent (el motor exige
                // exactamente uno), el evento nuevo es un endEvent.
                var type = _nodes.Any(n => n.Type == WorkflowNodeType.StartEvent)
                    ? WorkflowNodeType.EndEvent
                    : WorkflowNodeType.StartEvent;
                await AddNodeAsync(type);
                break;
            case "gw":
                await AddNodeAsync(WorkflowNodeType.ExclusiveGateway);
                break;
        }
    }

    private async Task AddNodeAsync(WorkflowNodeType type)
    {
        if (_canvas is null || !RequireEditable()) { return; }
        _addSeq++;
        var (w, h) = type switch
        {
            WorkflowNodeType.StartEvent or WorkflowNodeType.EndEvent => (46, 46),
            WorkflowNodeType.ExclusiveGateway => (56, 56),
            _ => (140, 64)
        };
        var x = CanvasW / 2 - w / 2 + (_addSeq % 3) * 20;
        var y = CanvasH / 2 - h / 2 + (_addSeq % 3) * 20;
        var result = await DesignSvc.AddNodeAsync(_canvas.DefinitionId, type, x, y);
        if (!result.IsOk || result.Value is null)
        {
            _error = result.Error ?? "No se pudo agregar el nodo.";
            return;
        }
        await RefreshAsync();
        _selectedId = result.Value.Id;
        _tool = "sel";
    }

    // ---- Interaccion del canvas ----

    private void OnCanvasPointerDown(PointerEventArgs e)
    {
        if (_tool != "conn")
        {
            _selectedId = null;
            _connFrom = null;
        }
    }

    private void OnNodePointerDown(NodeVm node, PointerEventArgs e)
    {
        if (_tool is "conn" or "del" || _canvas is null || !_canvas.IsEditable) { return; }
        _dragId = node.Id;
        _dragStartX = e.ClientX;
        _dragStartY = e.ClientY;
        _dragOriginX = node.X;
        _dragOriginY = node.Y;
        _dragMoved = false;
        _selectedId = node.Id;
    }

    private void OnCanvasPointerMove(PointerEventArgs e)
    {
        if (_dragId is not Guid id || FindNode(id) is not NodeVm node) { return; }
        var dx = (int)Math.Round(e.ClientX - _dragStartX);
        var dy = (int)Math.Round(e.ClientY - _dragStartY);
        if (Math.Abs(dx) > 2 || Math.Abs(dy) > 2) { _dragMoved = true; }
        node.X = Math.Max(0, _dragOriginX + dx);
        node.Y = Math.Max(0, _dragOriginY + dy);
        // Throttle del render (los pointermove llegan por SignalR): ~30 fps.
        var now = DateTime.UtcNow;
        if ((now - _lastDragRender).TotalMilliseconds < 33) { return; }
        _lastDragRender = now;
        StateHasChanged();
    }

    private async Task OnCanvasPointerUp(PointerEventArgs e)
    {
        if (_dragId is not Guid id) { return; }
        _dragId = null;
        if (!_dragMoved || FindNode(id) is not NodeVm node) { return; }
        // Persistencia del layout al soltar (regenera el BpmnXml con el DI nuevo).
        var result = await DesignSvc.MoveNodeAsync(id, node.X, node.Y);
        if (!result.IsOk)
        {
            _error = result.Error ?? "No se pudo mover el nodo.";
            await RefreshAsync();
        }
    }

    private async Task OnNodeClickAsync(NodeVm node)
    {
        _error = null;
        if (_tool == "conn")
        {
            if (!RequireEditable()) { return; }
            if (_connFrom is null)
            {
                _connFrom = node.Id;
            }
            else if (_connFrom != node.Id)
            {
                var result = await DesignSvc.ConnectAsync(_connFrom.Value, node.Id);
                if (!result.IsOk)
                {
                    _error = result.Error ?? "No se pudo conectar.";
                }
                _connFrom = null;
                _selectedId = node.Id;
                await RefreshAsync();
            }
            else
            {
                _connFrom = null;
            }
            return;
        }
        if (_tool == "del")
        {
            if (!RequireEditable()) { return; }
            var result = await DesignSvc.DeleteNodeAsync(node.Id);
            if (!result.IsOk)
            {
                _error = result.Error ?? "No se pudo eliminar el nodo.";
            }
            if (_selectedId == node.Id) { _selectedId = null; }
            await RefreshAsync();
            return;
        }
        _selectedId = node.Id;
    }

    private bool RequireEditable()
    {
        if (_canvas is null) { return false; }
        if (_canvas.IsEditable) { return true; }
        _error = "El grafo publicado no se edita: usa 'Editar (crear version borrador)'.";
        return false;
    }

