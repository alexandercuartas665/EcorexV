@using System.Globalization
@using Ecorex.Application.Forms
@using Ecorex.Application.Workflows
@using Ecorex.Domain.Enums
@inject IWorkflowDesignService DesignSvc
@inject IWorkflowEngine Engine
@inject IFormDefinitionService FormsSvc
@inject IJSRuntime JS

@* ============================================================
   EDITOR DE FLUJOS (modal grande del prototipo ECOREX.dc.html,
   bloque flowEditorOpen, ADR-0022). Canvas PROPIO (sin bpmn-js):
   toolbar flotante, nodos absolutos por tipo, aristas SVG
   ortogonales con flechas, caja de stats + hint contextual y
   panel derecho con 6 acordeones + "Saltar a otro flujo".
   El grafo solo se edita en BORRADORES; una publicada ofrece
   "Editar" que crea/reusa la version borrador (EnsureDraft).
   ============================================================ *@

@if (_canvas is null)
{
    <div class="fe-overlay"><div class="fe-loading">Cargando editor...</div></div>
}
else
{
    <div class="fe-overlay">
        <div class="fe-shell" @onclick:stopPropagation>
            <div class="fe-left">
                @* ---- Header del editor ---- *@
                <div class="fe-head">
                    <button class="fe-back" title="Volver a la lista" @onclick="CloseAsync">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 6-6 6 6 6"/></svg>
                    </button>
                    <span class="fe-flow-id">FLUJO @_canvas.ProcessCode v@(_canvas.Version)</span>
                    <input class="fe-name" placeholder="Nombre del flujo" @bind="_name" @bind:event="oninput" />
                    <div class="fe-cat-wrap">
                        <select class="fe-cat" @bind="_categoryValue">
                            @foreach (var option in CategoryOptions)
                            {
                                <option value="@option">@option</option>
                            }
                        </select>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--ink-3)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="fe-cat-chev"><path d="m6 9 6 6 6-6"/></svg>
                    </div>
                    <div class="fe-head-actions">
                        <button class="fe-btn" title="Propiedades del flujo" @onclick="OpenProps">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3.2"/><path d="M19.4 15a1.6 1.6 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.6 1.6 0 0 0-2.7 1.1V21a2 2 0 1 1-4 0v-.1A1.6 1.6 0 0 0 7 19.4a1.6 1.6 0 0 0-1.8.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1A1.6 1.6 0 0 0 2.6 15H2.5a2 2 0 1 1 0-4h.1A1.6 1.6 0 0 0 4 9.4l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1A1.6 1.6 0 0 0 9 4.6h.1A1.6 1.6 0 0 0 11 3V2.9a2 2 0 1 1 4 0V3a1.6 1.6 0 0 0 2.7 1.1l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.6 1.6 0 0 0-.3 1.8Z"/></svg>
                            Propiedades
                        </button>
                        <button class="fe-btn" title="Importar JSON" @onclick="@(() => OpenIo(export: false))">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12M7 10l5 5 5-5M5 21h14"/></svg>
                            Importar
                        </button>
                        <button class="fe-btn" title="Exportar JSON" @onclick="@(() => OpenIo(export: true))">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15V3M7 8l5-5 5 5M5 21h14"/></svg>
                            Exportar
                        </button>
                        @if (!_canvas.IsPublished)
                        {
                            <button class="fe-btn" title="Publicar esta version (despublica la anterior)" @onclick="PublishAsync" disabled="@_busy">Publicar</button>
                        }
                        <button class="fe-btn-brand" @onclick="SaveAsync" disabled="@_busy">Guardar cambios</button>
                        <button class="fe-btn" @onclick="CloseAsync">Cerrar</button>
                    </div>
                </div>

                @if (_error is not null)
                {
                    <div class="fe-error">@_error</div>
                }
                @if (_notice is not null)
                {
                    <div class="fe-notice">@_notice</div>
                }
                @if (!_canvas.IsEditable)
                {
                    <div class="fe-readonly">
                        Esta version esta @_canvas.Estado.ToLowerInvariant(): el grafo publicado no se edita.
                        <button class="fe-readonly-btn" @onclick="EnsureDraftAsync" disabled="@_busy">Editar (crear version borrador)</button>
                    </div>
                }

                @* ---- Canvas con puntos, toolbar flotante y stats ---- *@
                <div class="fe-canvas-zone">
                    <div class="fe-tools">
                        @foreach (var tool in ToolDefs)
                        {
                            <button class="fe-tool @(_tool == tool.Id && tool.Sticky ? "on" : "")"
                                    title="@tool.Name"
                                    style="@(_tool == tool.Id && tool.Sticky ? "" : $"color:{tool.Fg}")"
                                    @onclick="@(() => OnToolAsync(tool.Id))">
                                @((MarkupString)tool.Svg)
                            </button>
                        }
                    </div>
                    <div class="fe-stats">
                        <span>@_nodes.Count nodos - @_edges.Count conexiones</span>
                        <span class="fe-stats-sep"></span>
                        <span class="fe-hint">@ConnHint</span>
                    </div>
                    <div class="fe-scroll">
                        <div class="fe-canvas" style="width:@(CanvasW)px;height:@(CanvasH)px"
                             @onpointerdown="OnCanvasPointerDown"
                             @onpointermove="OnCanvasPointerMove"
                             @onpointerup="OnCanvasPointerUp"
                             @onpointerleave="OnCanvasPointerUp">
                            <svg width="@CanvasW" height="@CanvasH" class="fe-edges">
                                <defs>
                                    <marker id="fe-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
                                        <path d="M0 0 10 5 0 10z" fill="var(--ink-3)"/>
                                    </marker>
                                    <marker id="fe-arrow-brand" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
                                        <path d="M0 0 10 5 0 10z" fill="var(--brand)"/>
                                    </marker>
                                </defs>
                                @foreach (var edge in _edges)
                                {
                                    var a = FindNode(edge.SourceNodeId);
                                    var b = FindNode(edge.TargetNodeId);
                                    if (a is null || b is null) { continue; }
                                    var conditional = !string.IsNullOrWhiteSpace(edge.ConditionExpression);
                                    <path d="@EdgePath(a, b)" fill="none"
                                          stroke="@(conditional ? "var(--brand)" : "var(--ink-3)")"
                                          stroke-width="@(conditional ? "2.4" : "2")"
                                          stroke-dasharray="@(conditional ? "7 5" : "0")"
                                          marker-end="@(conditional ? "url(#fe-arrow-brand)" : "url(#fe-arrow)")" />
                                }
                            </svg>
                            @foreach (var node in _nodes)
                            {
                                var selected = _selectedId == node.Id;
                                var isFrom = _connFrom == node.Id;
                                <div class="fe-node @NodeShapeClass(node.Type) @(selected ? "sel" : "") @(isFrom ? "from" : "")"
                                     data-element-id="@node.ElementId"
                                     style="left:@(node.X)px;top:@(node.Y)px;width:@(node.W)px;height:@(node.H)px;cursor:@NodeCursor"
                                     @onpointerdown="@(e => OnNodePointerDown(node, e))"
                                     @onpointerdown:stopPropagation
                                     @onclick="@(() => OnNodeClickAsync(node))"
                                     @onclick:stopPropagation>
                                    @if (node.Type == WorkflowNodeType.ExclusiveGateway)
                                    {
                                        <span class="fe-gw-label">@NodeLabel(node)</span>
                                    }
                                    else
                                    {
                                        @NodeLabel(node)
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @* ---- Panel derecho: detalle de actividad + acordeones ---- *@
            <aside class="fe-panel">
                <div class="fe-panel-head">
                    <div class="fe-panel-eyebrow">DETALLE DE ACTIVIDAD</div>
                    <div class="fe-panel-name">@(Selected is null ? "Ningun nodo seleccionado" : NodeLabel(Selected))</div>
                    <input class="fe-panel-input" placeholder="Nombre del nodo"
                           value="@(Selected?.Name ?? "")"
                           disabled="@(Selected is null || !_canvas.IsEditable)"
                           @oninput="OnPanelNameInput" @onchange="OnPanelNameChangeAsync" />
                </div>
                <div class="fe-panel-body">
                    @foreach (var acc in AccordionDefs)
                    {
                        var open = _openAcc == acc.Index;
                        <button class="fe-acc @(open ? "open" : "")" @onclick="@(() => _openAcc = open ? -1 : acc.Index)">
                            <span class="fe-acc-ic" style="background:@acc.IconBg;color:@acc.IconFg">@((MarkupString)acc.Svg)</span>
                            <span class="fe-acc-name">@acc.Name</span>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--ink-3)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="transition:transform .2s;transform:rotate(@(open ? 180 : 0)deg)"><path d="m6 9 6 6 6-6"/></svg>
                        </button>
                        @if (open)
                        {
                            <div class="fe-acc-body">
                                @switch (acc.Index)
                                {
                                    case 0:
                                        @ConfigBody
                                        break;
                                    case 1:
                                        @UsersBody
                                        break;
                                    case 2:
                                        @ResourcesBody
                                        break;
                                    case 3:
                                        @RulesBody
                                        break;
                                    case 4:
                                        @NotifBody
                                        break;
                                    default:
                                        @ExitBody
                                        break;
                                }
                            </div>
                        }
                    }
                    <button class="fe-jump" @onclick="OpenJumpAsync">
                        <span class="fe-acc-ic" style="background:var(--brand-soft);color:var(--brand)">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/><path d="M5 5v4"/></svg>
                        </span>
                        <span class="fe-acc-name">Saltar a otro flujo</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--ink-3)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 6 6 6-6 6"/></svg>
                    </button>
                </div>
            </aside>
        </div>
    </div>
}

@* ---- Modal: propiedades del flujo ---- *@
@if (_propsOpen && _canvas is not null)
{
    <div class="fe-modal-overlay" @onclick="@(() => _propsOpen = false)">
        <div class="fe-modal" style="width:min(520px,95vw)" @onclick:stopPropagation>
            <div class="fe-modal-head">
                <div>
                    <div class="fe-modal-title">Propiedades del flujo</div>
                    <div class="fe-modal-sub">Nombre, categoria, estado y descripcion - @_canvas.ProcessCode</div>
                </div>
                <button class="fe-modal-x" @onclick="@(() => _propsOpen = false)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
                </button>
            </div>
            <div class="fe-modal-body">
                <div>
                    <label class="fe-label">NOMBRE DEL FLUJO</label>
                    <input class="fe-input" @bind="_name" placeholder="Nombre del flujo" />
                </div>
                <div class="fe-grid-2">
                    <div>
                        <label class="fe-label">CATEGORIA</label>
                        <select class="fe-input" @bind="_categoryValue">
                            @foreach (var option in CategoryOptions)
                            {
                                <option value="@option">@option</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="fe-label">ESTADO</label>
                        <select class="fe-input" @bind="_estadoValue">
                            @foreach (var option in EstadoOptions)
                            {
                                <option value="@option">@option</option>
                            }
                        </select>
                    </div>
                </div>
                <div>
                    <label class="fe-label">DESCRIPCION</label>
                    <textarea class="fe-textarea" @bind="_description" placeholder="Describe el proposito del flujo..."></textarea>
                </div>
            </div>
            <div class="fe-modal-foot">
                <button class="fe-btn-ghost" @onclick="@(() => _propsOpen = false)">Cancelar</button>
                <button class="fe-btn-save" @onclick="SavePropsAsync" disabled="@_busy">Guardar</button>
            </div>
        </div>
    </div>
}

@* ---- Modal: exportar / importar JSON ---- *@
@if (_ioOpen)
{
    <div class="fe-modal-overlay" @onclick="@(() => _ioOpen = false)">
        <div class="fe-modal" style="width:min(620px,95vw)" @onclick:stopPropagation>
            <div class="fe-modal-head">
                <div>
                    <div class="fe-modal-title">@(_ioExport ? "Exportar flujo (JSON)" : "Importar flujo (JSON)")</div>
                    <div class="fe-modal-sub">Todas las propiedades del flujo: nodos, conexiones y metadatos</div>
                </div>
                <button class="fe-modal-x" @onclick="@(() => _ioOpen = false)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
                </button>
            </div>
            <div class="fe-modal-body">
                @if (_ioExport)
                {
                    <pre class="fe-json">@_exportJson</pre>
                }
                else
                {
                    <label class="fe-label">Pega el JSON del flujo</label>
                    <textarea class="fe-json-input" spellcheck="false" @bind="_importJson"
                              placeholder='{ "nombre": "...", "nodos": [...], "conexiones": [...] }'></textarea>
                    @if (_ioError is not null)
                    {
                        <div class="fe-error">@_ioError</div>
                    }
                }
            </div>
            <div class="fe-modal-foot">
                <button class="fe-btn-ghost" @onclick="@(() => _ioOpen = false)">Cerrar</button>
                @if (_ioExport)
                {
                    <button class="fe-btn-save with-ic" @onclick="CopyJsonAsync">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>
                        Copiar JSON
                    </button>
                }
                else
                {
                    <button class="fe-btn-save" @onclick="ImportJsonAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_importJson))">Importar flujo</button>
                }
            </div>
        </div>
    </div>
}

@* ---- Modal: agregar formulario (acordeon Recursos) ---- *@
@if (_formPickerOpen)
{
    <div class="fe-modal-overlay" @onclick="@(() => _formPickerOpen = false)">
        <div class="fe-modal" style="width:min(640px,95vw)" @onclick:stopPropagation>
            <div class="fe-modal-head">
                <div>
                    <div class="fe-modal-title">Agregar formulario</div>
                    <div class="fe-modal-sub">Elige el formulario que se adjunta a esta actividad</div>
                </div>
                <button class="fe-modal-x" @onclick="@(() => _formPickerOpen = false)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
                </button>
            </div>
            <div class="fe-modal-search">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--ink-3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
                <input value="@_formPickerQuery" @oninput="@(e => _formPickerQuery = e.Value?.ToString() ?? "")" placeholder="Buscar formulario..." />
            </div>
            <div class="fe-form-grid">
                @foreach (var form in FilteredForms)
                {
                    <button class="fe-form-card" @onclick="@(() => LinkFormAsync(form.Id))">
                        <span class="fe-form-ic">
                            <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="14" height="18" rx="2.5"/><path d="M9 8h6M9 12h6M9 16h3"/></svg>
                        </span>
                        <span class="fe-form-name">@form.Title</span>
                        <span class="fe-form-code">FORX-@form.Code</span>
                    </button>
                }
                @if (!FilteredForms.Any())
                {
                    <div class="fe-empty">No hay formularios publicados para vincular.</div>
                }
            </div>
        </div>
    </div>
}

@* ---- Modal: agregar regla (acordeon Reglas) ---- *@
@if (_rulePickerOpen)
{
    <div class="fe-modal-overlay" @onclick="@(() => _rulePickerOpen = false)">
        <div class="fe-modal" style="width:min(520px,95vw)" @onclick:stopPropagation>
            <div class="fe-modal-head">
                <div>
                    <div class="fe-modal-title">Agregar regla</div>
                    <div class="fe-modal-sub">Catalogo de reglas del tenant (modulo 000802)</div>
                </div>
                <button class="fe-modal-x" @onclick="@(() => _rulePickerOpen = false)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
                </button>
            </div>
            <div class="fe-rule-list">
                @foreach (var rule in AvailableRules)
                {
                    <button class="fe-rule-option" @onclick="@(() => LinkRuleAsync(rule.RuleId))">
                        <span class="fe-rule-verb">@rule.VerbName</span>
                        <span class="fe-rule-name">@rule.Name</span>
                        <span class="fe-rule-doc">@rule.DocumentName</span>
                    </button>
                }
                @if (!AvailableRules.Any())
                {
                    <div class="fe-empty">No hay reglas disponibles (todas vinculadas o catalogo vacio).</div>
                }
            </div>
        </div>
    </div>
}

@* ---- Modal: saltar a otro flujo ---- *@
@if (_jumpOpen && _canvas is not null)
{
    <div class="fe-modal-overlay" @onclick="@(() => _jumpOpen = false)">
        <div class="fe-modal" style="width:min(500px,95vw)" @onclick:stopPropagation>
            <div class="fe-modal-head">
                <div>
                    <div class="fe-modal-title">Saltar a otro flujo</div>
                    <div class="fe-modal-sub">Desde "@_canvas.Name" - elige el flujo destino de la conexion</div>
                </div>
                <button class="fe-modal-x" @onclick="@(() => _jumpOpen = false)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
                </button>
            </div>
            <div class="fe-modal-search">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--ink-3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
                <input value="@_jumpQuery" @oninput="@(e => _jumpQuery = e.Value?.ToString() ?? "")" placeholder="Buscar flujo..." />
            </div>
            <div class="fe-jump-list">
                @foreach (var option in JumpOptions)
                {
                    <button class="fe-jump-option @(_jumpSelected == option.DefinitionId ? "sel" : "")"
                            @onclick="@(() => _jumpSelected = option.DefinitionId)">
                        <span class="fe-jump-ic">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="6" height="6" rx="1.4"/><rect x="16" y="15" width="6" height="6" rx="1.4"/><path d="M5 9v3a4 4 0 0 0 4 4h7"/></svg>
                        </span>
                        <span class="fe-jump-tx">
                            <span class="fe-jump-name">@option.Name</span>
                            <span class="fe-jump-meta">@option.ProcessCode - @(option.Category ?? "General")</span>
                        </span>
                        @if (_jumpSelected == option.DefinitionId)
                        {
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 10 17 19 7"/></svg>
                        }
                    </button>
                }
            </div>
            <div class="fe-modal-foot">
                <button class="fe-btn-ghost" @onclick="@(() => _jumpOpen = false)">Cancelar</button>
                @if (_jumpSelected is not null)
                {
                    <button class="fe-btn-save" @onclick="ConfirmJump">Conectar flujo</button>
                }
            </div>
        </div>
    </div>
}

@code {
    // ---- Parametros ----
    [Parameter] public Guid DefinitionId { get; set; }
    [Parameter] public IReadOnlyList<string> Categories { get; set; } = [];
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Guid> OnDefinitionSwitched { get; set; }

    // Canvas logico del prototipo (FW=900, FH=540).
    private const int CanvasW = 900;
    private const int CanvasH = 540;

    private FlowCanvasDto? _canvas;
    private List<NodeVm> _nodes = [];
    private List<FlowCanvasEdgeDto> _edges = [];
    private Guid _loadedId;

    private string _name = "";
    private string _categoryValue = "General";
    private string _estadoValue = "";
    private string? _description;

    private bool _busy;
    private string? _error;
    private string? _notice;

    // Herramientas: sel / conn / del son "sticky"; task / event / gw agregan de una vez.
    private string _tool = "sel";
    private Guid? _connFrom;
    private Guid? _selectedId;
    private int _addSeq;

    // Drag (pointer events, sin JS externo; persiste al soltar).
    private Guid? _dragId;
    private double _dragStartX, _dragStartY;
    private int _dragOriginX, _dragOriginY;
    private bool _dragMoved;
    private DateTime _lastDragRender = DateTime.MinValue;

    private int _openAcc;

    // Modales.
    private bool _propsOpen;
    private bool _ioOpen;
    private bool _ioExport = true;
    private string? _exportJson;
    private string _importJson = "";
    private string? _ioError;
    private bool _formPickerOpen;
    private string _formPickerQuery = "";
    private List<FormDefinitionListItemDto> _forms = [];
    private bool _rulePickerOpen;
    private IReadOnlyList<FlowRuleCatalogItemDto> _ruleCatalog = [];
    private bool _jumpOpen;
    private string _jumpQuery = "";
    private Guid? _jumpSelected;
    private IReadOnlyList<FlowCardDto> _jumpFlows = [];

    private sealed class NodeVm
    {
        public Guid Id;
        public string ElementId = "";
        public string? Name;
        public WorkflowNodeType Type;
        public int X, Y, W, H;
        public bool AllowsAssignment;
        public Guid? RestartNodeId;
        public Guid? FormDefinitionId;
        public string? FormCode;
        public string? FormTitle;
        public IReadOnlyList<FlowNodeRuleDto> Rules = [];
    }

    private NodeVm? Selected => _selectedId is Guid id ? FindNode(id) : null;
    private NodeVm? FindNode(Guid id) => _nodes.FirstOrDefault(n => n.Id == id);

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId != DefinitionId)
        {
            _loadedId = DefinitionId;
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _canvas = await DesignSvc.GetCanvasAsync(DefinitionId);
        if (_canvas is null)
        {
            _error = "El flujo no existe.";
            return;
        }
        _name = _canvas.Name;
        _categoryValue = _canvas.Category ?? "General";
        _estadoValue = _canvas.Estado;
        _description = _canvas.Description;
        RebuildVm();
    }

    private void RebuildVm()
    {
        if (_canvas is null) { return; }
        _nodes = _canvas.Nodes.Select(n => new NodeVm
        {
            Id = n.Id, ElementId = n.BpmnElementId, Name = n.Name, Type = n.NodeType,
            X = n.X, Y = n.Y, W = n.W, H = n.H,
            AllowsAssignment = n.AllowsAssignment, RestartNodeId = n.RestartNodeId,
            FormDefinitionId = n.FormDefinitionId, FormCode = n.FormCode, FormTitle = n.FormTitle,
            Rules = n.Rules
        }).ToList();
        _edges = _canvas.Edges.ToList();
        if (_selectedId is Guid id && FindNode(id) is null)
        {
            _selectedId = null;
        }
    }

    /// <summary>Recarga el canvas desde la BD (tras una mutacion) conservando seleccion.</summary>
    private async Task RefreshAsync()
    {
        _canvas = await DesignSvc.GetCanvasAsync(DefinitionId);
        RebuildVm();
    }

