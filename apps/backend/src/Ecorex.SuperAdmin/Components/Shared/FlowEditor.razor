    /// <summary>Ruta ortogonal del prototipo: H-V-H hacia adelante; V-H-V hacia atras.</summary>
    private static string EdgePath(NodeVm a, NodeVm b)
    {
        var sx = a.X + a.W;
        var sy = a.Y + a.H / 2;
        var tx = b.X;
        var ty = b.Y + b.H / 2;
        if (tx >= sx + 20)
        {
            var mx = (sx + tx) / 2;
            return FormattableString.Invariant($"M{sx} {sy} H{mx} V{ty} H{tx}");
        }
        var sx2 = a.X + a.W / 2;
        var sy2 = a.Y + a.H;
        var tx2 = b.X + b.W / 2;
        var ty2 = b.Y;
        var my = Math.Max(sy2, ty2) + 30;
        return FormattableString.Invariant($"M{sx2} {sy2} V{my} H{tx2} V{ty2}");
    }

