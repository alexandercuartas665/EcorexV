        var result = await DesignSvc.SetNodeRuleAutonomousAsync(rule.LinkId, isAutonomous);
        if (!result.IsOk) { _error = result.Error; }
        await RefreshAsync();
    }

    // ---- Header: guardar / publicar / props / io / draft ----

    private async Task SaveAsync()
    {
        if (_canvas is null) { return; }
        _busy = true;
        _error = null;
        _notice = null;
        try
        {
            var result = await DesignSvc.UpdateDefinitionPropsAsync(
                _canvas.DefinitionId, _name, _categoryValue, _description);
            if (!result.IsOk)
            {
                _error = result.Error ?? "No se pudo guardar.";
                return;
            }
            await RefreshAsync();
            _notice = "Cambios guardados.";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task PublishAsync()
    {
        if (_canvas is null) { return; }
        _busy = true;
        _error = null;
        try
        {
            var result = await Engine.PublishAsync(_canvas.DefinitionId);
            if (!result.IsOk)
            {
                _error = result.Error ?? "No se pudo publicar.";
                return;
            }
            await RefreshAsync();
            _notice = $"Version {_canvas!.Version} publicada.";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task EnsureDraftAsync()
    {
        if (_canvas is null) { return; }
        _busy = true;
        _error = null;
        try
        {
            var result = await DesignSvc.EnsureDraftAsync(_canvas.DefinitionId);
            if (!result.IsOk || result.Value is null)
            {
                _error = result.Error ?? "No se pudo crear la version borrador.";
                return;
            }
            _notice = $"Editando la version borrador v{result.Value.Version}.";
            await OnDefinitionSwitched.InvokeAsync(result.Value.DefinitionId);
        }
        finally
        {
            _busy = false;
        }
    }

    private void OpenProps()
    {
        _estadoValue = _canvas?.Estado ?? "Borrador";
        _propsOpen = true;
    }

    private async Task SavePropsAsync()
    {
        if (_canvas is null) { return; }
        _busy = true;
        _error = null;
        try
        {
            var props = await DesignSvc.UpdateDefinitionPropsAsync(
                _canvas.DefinitionId, _name, _categoryValue, _description);
            if (!props.IsOk)
            {
                _error = props.Error ?? "No se pudo guardar.";
                return;
            }
            // Transicion de estado del modal: Borrador->En marcha publica; En marcha<->Pausado.
            if (_estadoValue != _canvas.Estado)
            {
                if (_estadoValue == "En marcha" && !_canvas.IsPublished)
                {
                    var publish = await Engine.PublishAsync(_canvas.DefinitionId);
                    if (!publish.IsOk) { _error = publish.Error; }
                }
                else if (_estadoValue == "En marcha" && _canvas.IsPaused)
                {
                    var resume = await DesignSvc.ResumeAsync(_canvas.DefinitionId);
                    if (!resume.IsOk) { _error = resume.Error; }
                }
                else if (_estadoValue == "Pausado")
                {
                    var pause = await DesignSvc.PauseAsync(_canvas.DefinitionId);
                    if (!pause.IsOk) { _error = pause.Error; }
                }
            }
            _propsOpen = false;
            await RefreshAsync();
            _notice = "Propiedades guardadas.";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task OpenIo(bool export)
    {
        _ioExport = export;
        _ioError = null;
        _importJson = "";
        if (export && _canvas is not null)
        {
            _exportJson = await DesignSvc.ExportJsonAsync(_canvas.DefinitionId);
        }
        _ioOpen = true;
    }

    private async Task CopyJsonAsync()
    {
        if (_exportJson is not null)
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _exportJson);
            _notice = "JSON copiado al portapapeles.";
            _ioOpen = false;
        }
    }

    private async Task ImportJsonAsync()
    {
        _busy = true;
        _ioError = null;
        try
        {
            var result = await DesignSvc.ImportJsonAsync(_importJson);
            if (!result.IsOk || result.Value is null)
            {
                _ioError = result.Error ?? "No se pudo importar.";
                return;
            }
            _ioOpen = false;
            _notice = $"Flujo importado como {result.Value.ProcessCode} v{result.Value.Version} (Borrador).";
            await OnDefinitionSwitched.InvokeAsync(result.Value.DefinitionId);
        }
        finally
        {
            _busy = false;
        }
    }

    // ---- Saltar a otro flujo (visual; el vinculo real es deuda del ADR-0022) ----

    private async Task OpenJumpAsync()
    {
        _jumpQuery = "";
        _jumpSelected = null;
        _jumpFlows = (await DesignSvc.ListForIndexAsync()).Cards
            .Where(c => c.ProcessCode != _canvas?.ProcessCode)
            .ToList();
        _jumpOpen = true;
    }

    private IEnumerable<FlowCardDto> JumpOptions
        => string.IsNullOrWhiteSpace(_jumpQuery)
            ? _jumpFlows
            : _jumpFlows.Where(f => f.Name.Contains(_jumpQuery.Trim(), StringComparison.OrdinalIgnoreCase)
                || f.ProcessCode.Contains(_jumpQuery.Trim(), StringComparison.OrdinalIgnoreCase));

    private void ConfirmJump()
    {
        // Deuda documentada (ADR-0022): el modelo de salto entre flujos (subprocess /
        // call activity) aun no existe en el motor; el modal replica el prototipo.
        _jumpOpen = false;
        _notice = "TODO: el vinculo real entre flujos (call activity) esta pendiente en el motor.";
    }

    private async Task CloseAsync() => await OnClose.InvokeAsync();
}
