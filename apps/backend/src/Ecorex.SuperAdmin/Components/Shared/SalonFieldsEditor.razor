@using Ecorex.Application.Tenancy
@using Ecorex.Domain.Enums

@* Editor generico de campos configurables del salon. Pinta un input por campo segun su tipo y
   escribe sobre el diccionario Values (clave -> valor string). Lo usan el modal de cita y la ficha. *@

@if (Fields is { Count: > 0 })
{
    <div class="sf-grid">
        @foreach (var f in Fields)
        {
            @if (f.FieldType == SalonFieldType.Separator)
            {
                <div class="sf-sep"><span>@f.Label</span></div>
            }
            else
            {
                <div class="sf-field @(f.Column == 2 ? "sf-col2" : "")">
                    <label class="form-label">@f.Label @if (f.IsRequired) {<span style="color:var(--destructive);">*</span>}</label>
                    @if (!string.IsNullOrWhiteSpace(f.Description))
                    {
                        <div class="text-muted" style="font-size:11px;margin-bottom:3px;">@f.Description</div>
                    }
                    @switch (f.FieldType)
                    {
                        case SalonFieldType.TextArea:
                            <textarea class="form-control" rows="2" value="@GetVal(f.FieldKey)" @onchange="e => SetVal(f.FieldKey, e.Value?.ToString())"></textarea>
                            break;
                        case SalonFieldType.Number:
                            <input class="form-control" type="number" value="@GetVal(f.FieldKey)" @onchange="e => SetVal(f.FieldKey, e.Value?.ToString())" />
                            break;
                        case SalonFieldType.Currency:
                            <input class="form-control" type="number" step="any" inputmode="numeric" placeholder="$" value="@GetVal(f.FieldKey)" @onchange="e => SetVal(f.FieldKey, e.Value?.ToString())" />
                            break;
                        case SalonFieldType.Date:
                            <input class="form-control" type="date" value="@GetVal(f.FieldKey)" @onchange="e => SetVal(f.FieldKey, e.Value?.ToString())" />
                            break;
                        case SalonFieldType.Time:
                            <input class="form-control" type="time" value="@GetVal(f.FieldKey)" @onchange="e => SetVal(f.FieldKey, e.Value?.ToString())" />
                            break;
                        case SalonFieldType.Phone:
                            <input class="form-control" type="tel" value="@GetVal(f.FieldKey)" @onchange="e => SetVal(f.FieldKey, e.Value?.ToString())" />
                            break;
                        case SalonFieldType.Boolean:
                            <label class="sf-check">
                                <input type="checkbox" checked="@(GetVal(f.FieldKey) == "true")" @onchange="e => SetBool(f.FieldKey, (bool)e.Value!)" />
                                <span>Si</span>
                            </label>
                            break;
                        case SalonFieldType.Select:
                            <select class="form-control" value="@GetVal(f.FieldKey)" @onchange="e => SetVal(f.FieldKey, e.Value?.ToString())">
                                <option value="">-</option>
                                @foreach (var opt in SelectOptions(f.Options))
                                {
                                    <option value="@opt">@opt</option>
                                }
                            </select>
                            break;
                        default:
                            <input class="form-control" type="text" value="@GetVal(f.FieldKey)" @onchange="e => SetVal(f.FieldKey, e.Value?.ToString())" />
                            break;
                    }
                </div>
            }
        }
    </div>
}

@code {
    [Parameter] public IReadOnlyList<SalonFieldDto> Fields { get; set; } = Array.Empty<SalonFieldDto>();
    [Parameter] public Dictionary<string, string?> Values { get; set; } = new();
    [Parameter] public EventCallback OnChanged { get; set; }

    private string GetVal(string key) => Values.TryGetValue(key, out var v) ? (v ?? "") : "";

    private async Task SetVal(string key, string? value)
    {
        Values[key] = value;
        if (OnChanged.HasDelegate) { await OnChanged.InvokeAsync(); }
    }

    private Task SetBool(string key, bool value) => SetVal(key, value ? "true" : "false");

    private static IEnumerable<string> SelectOptions(string? options)
        => string.IsNullOrWhiteSpace(options)
            ? Array.Empty<string>()
            : options.Replace("\r", "").Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
}
